<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>

      <!-- ASP.NET Core Module — all requests go through the app -->
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\SMART_HRMS_SYSTEM.Server.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess" />

      <!-- APK MIME type — prevents IIS Request Filtering from blocking .apk downloads -->
      <staticContent>
        <remove fileExtension=".apk" />
        <mimeMap fileExtension=".apk" mimeType="application/vnd.android.package-archive" />
      </staticContent>

      <!-- Remove X-Powered-By header (security) -->
      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
        </customHeaders>
      </httpProtocol>

      <!-- No-cache headers for service worker files at IIS level (belt + suspenders) -->
      <rewrite>
        <outboundRules>
          <rule name="NoCache-ServiceWorker" preCondition="IsServiceWorkerFile">
            <match serverVariable="RESPONSE_Cache_Control" pattern=".*" />
            <action type="Rewrite" value="no-cache, no-store, must-revalidate" />
          </rule>
          <rule name="NoCache-ServiceWorker-Pragma">
            <match serverVariable="RESPONSE_Pragma" pattern=".*" />
            <conditions>
              <add input="{REQUEST_URI}" pattern="service-worker" />
            </conditions>
            <action type="Rewrite" value="no-cache" />
          </rule>
          <preConditions>
            <preCondition name="IsServiceWorkerFile">
              <add input="{REQUEST_URI}" pattern="service-worker" />
            </preCondition>
          </preConditions>
        </outboundRules>
      </rewrite>

    </system.webServer>
  </location>
</configuration>
