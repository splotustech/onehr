@code {
    // ── State ──────────────────────────────────────────────────────────────
    private bool IsMenuOpen = false;
    private string EmployeeName = string.Empty;
    private string EmployeeDepartment = string.Empty;
    private string EmployeeId = string.Empty;

    // iOS Guide Modal
    private bool ShowIosModal = false;
    private bool LinkCopied = false;
    private string AppBaseUrl = string.Empty;
    private string QrCodeUrl =>
$"https://api.qrserver.com/v1/create-qr-code/?size=160x160&data={Uri.EscapeDataString(AppBaseUrl)}&bgcolor=ffffff&color=000000&margin=4";

    // APK info (reserved for future size display)
    private string ApkSizeMb = "";

    // Version / Update check
    private string? _knownVersion;
    private bool ShowUpdateBanner = false;
    private string NewVersionLabel = "";
    private int UpdateCountdown = 30;
    private CancellationTokenSource _versionCts = new();
    private CancellationTokenSource _countdownCts = new();

    // ── Init ───────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        EmployeeName = await JS.InvokeAsync<string>("localStorage.getItem", "empName") ?? "";
        EmployeeDepartment = await JS.InvokeAsync<string>("localStorage.getItem", "empDept") ?? "";
        EmployeeId = await JS.InvokeAsync<string>("localStorage.getItem", "empId") ?? "";
        AppBaseUrl = NavManager.BaseUri.TrimEnd('/');

        // Start background version polling loop (Task.Delay is reliable in Blazor WASM)
        _ = VersionPollingLoop(_versionCts.Token);
    }

    // ── Version Polling Loop ───────────────────────────────────────────────
    // Uses Task.Delay (backed by JS setTimeout) — works correctly in WASM.
    // System.Timers.Timer is unreliable in single-threaded WASM environment.

    private async Task VersionPollingLoop(CancellationToken ct)
    {
        // Step 1: wait 3 seconds then record baseline version (no banner on first load)
        await Task.Delay(3_000, ct);
        _knownVersion = await FetchVersion(ct);

        // Step 2: poll every 30 seconds and compare
        while (!ct.IsCancellationRequested)
        {
            await Task.Delay(30_000, ct);
            if (ct.IsCancellationRequested) break;

            var latest = await FetchVersion(ct);
            if (latest != null && _knownVersion != null && latest != _knownVersion && !ShowUpdateBanner)
            {
                NewVersionLabel = latest;
                ShowUpdateBanner = true;
                UpdateCountdown = 30;
                await InvokeAsync(StateHasChanged);

                // Start countdown loop on UI thread
                _ = CountdownLoop(_countdownCts.Token);
            }
        }
    }

    private async Task CountdownLoop(CancellationToken ct)
    {
        while (UpdateCountdown > 0 && !ct.IsCancellationRequested)
        {
            await Task.Delay(1_000, ct);
            UpdateCountdown--;
            await InvokeAsync(StateHasChanged);
        }
        if (!ct.IsCancellationRequested && ShowUpdateBanner)
            await InvokeAsync(ApplyUpdate);
    }

    // Fetches version with cache-busting — browser must NOT cache this response
    private async Task<string?> FetchVersion(CancellationToken ct = default)
    {
        try
        {
            var tick = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
            using var req = new HttpRequestMessage(HttpMethod.Get, $"api/version?t={tick}");
            req.Headers.CacheControl = new System.Net.Http.Headers.CacheControlHeaderValue
            {
                NoCache = true,
                NoStore = true
            };
            using var resp = await Http.SendAsync(req, ct);
            if (!resp.IsSuccessStatusCode) return null;

            var result = await resp.Content.ReadFromJsonAsync<VersionResponse>(cancellationToken: ct);
            return result?.Version;
        }
        catch { return null; }
    }

    private async Task ApplyUpdate()
    {
        ShowUpdateBanner = false;
        _countdownCts.Cancel();
        await JS.InvokeVoidAsync("forceAppUpdate");
    }

    // ── iOS Guide ──────────────────────────────────────────────────────────

    private void ToggleMenu() => IsMenuOpen = !IsMenuOpen;
    private void OpenIosGuide() { LinkCopied = false; ShowIosModal = true; }
    private void CloseIosGuide() => ShowIosModal = false;

    private async Task CopyAppLink()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", AppBaseUrl);
            LinkCopied = true;
            StateHasChanged();
            await Task.Delay(2500);
            LinkCopied = false;
            StateHasChanged();
        }
        catch
        {
            await JS.InvokeVoidAsync("alert", $"App link: {AppBaseUrl}");
        }
    }

    // ── Auth ───────────────────────────────────────────────────────────────

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.clear");
        NavManager.NavigateTo("/", true);
    }

    private async Task ForceRefresh()
    {
        await JS.InvokeVoidAsync("forceAppUpdate");
    }

    // ── Cleanup ────────────────────────────────────────────────────────────

    public async ValueTask DisposeAsync()
    {
        _versionCts.Cancel();
        _versionCts.Dispose();
        _countdownCts.Cancel();
        _countdownCts.Dispose();
        await Task.CompletedTask;
    }

    // ── Response Models ────────────────────────────────────────────────────

    private class VersionResponse
    {
        public string? Version { get; set; }
        public string? Label { get; set; }
    }

}