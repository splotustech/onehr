@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject NavigationManager NavManager
@inject HttpClient Http
@implements IAsyncDisposable

<!-- ── NEW VERSION UPDATE BANNER ───────────────────────────────────────── -->
@if (ShowUpdateBanner)
{
    <div class="update-banner">
        <div class="update-banner-left">
            <span class="update-pulse"></span>
            <span class="update-text">
                <strong>New Update Available!</strong>
                &nbsp;Version @NewVersionLabel is ready.
            </span>
        </div>
        <div class="update-banner-right">
            @if (UpdateCountdown > 0)
            {
                <span class="update-countdown">Auto-updating in @UpdateCountdown sec</span>
            }
            <button class="update-now-btn" @onclick="ApplyUpdate">
                <i class="bi bi-arrow-clockwise"></i> Update Now
            </button>
            <button class="update-later-btn" @onclick="() => ShowUpdateBanner = false">Later</button>
        </div>
    </div>
}

<!-- 🔥 TOP NAVBAR -->
<div class="top-navbar shadow-sm">
    <div class="brand-logo">
        <span style="color: #4f46e5; font-size: 22px;"><img src="icon-512.png" style="height:18px" /></span> SP ONEHR
    </div>
    @if (!string.IsNullOrEmpty(EmployeeName))
    {
        <button class="menu-toggle-btn" @onclick="ToggleMenu">
            ☰
        </button>
    }
</div>

<!-- 🔥 SIDE MENU -->
<div class="side-menu-overlay @(IsMenuOpen ? "show" : "")" @onclick="ToggleMenu"></div>

<div class="side-menu @(IsMenuOpen ? "open" : "")">

    <!-- HEADER -->
    <div class="side-menu-header">
        @if (!string.IsNullOrEmpty(EmployeeName))
        {
            <h5 class="mb-0 fw-bold text-white">
                <i class="bi bi-person me-2"></i> @EmployeeName
            </h5>
            <p class="mb-0 small text-light opacity-75 ms-4">@EmployeeDepartment</p>

            <!-- Refresh + Download buttons row -->
            <div class="header-action-row">
                <button class="hdr-btn hdr-refresh" @onclick="ForceRefresh">
                    <i class="bi bi-arrow-clockwise"></i>
                    <span>Refresh</span>
                </button>
                <a href="/api/download/apk" class="hdr-btn hdr-android" title="Download SP OneHR Android App">
                    <i class="bi bi-android2"></i>
                    <span>Android</span>
                </a>
                <button class="hdr-btn hdr-ios" @onclick="OpenIosGuide" title="iOS Install Guide">
                    <i class="bi bi-apple"></i>
                    <span>iOS</span>
                </button>
            </div>
        }

        <button class="close-menu-btn" @onclick="ToggleMenu">×</button>
    </div>

    <!-- ── iOS Install Guide Modal ──────────────────────────────────────── -->
    @if (ShowIosModal)
    {
        <div class="ios-modal-overlay" @onclick="CloseIosGuide">
            <div class="ios-modal" @onclick:stopPropagation="true">

                <div class="ios-modal-header">
                    <div class="ios-modal-title">
                        <i class="bi bi-apple me-2"></i> Install SP OneHR on iPhone
                    </div>
                    <button class="ios-modal-close" @onclick="CloseIosGuide">×</button>
                </div>

                <div class="ios-modal-body">

                    <!-- QR Code — scan to open app on phone -->
                    <div class="qr-section">
                        <img src="@QrCodeUrl" alt="Scan QR to open SP OneHR" class="qr-img"
                             onerror="this.style.display='none'" />
                        <p class="qr-label">Scan with iPhone camera to open the app</p>
                    </div>

                    <div class="ios-divider"><span>then follow these steps</span></div>

                    <!-- Step-by-step Safari guide -->
                    <div class="ios-steps">
                        <div class="ios-step">
                            <div class="step-num">1</div>
                            <div class="step-text">
                                Open the app link in <strong>Safari</strong> browser
                                <span class="step-note">(Chrome/Edge won't work for install)</span>
                            </div>
                        </div>
                        <div class="ios-step">
                            <div class="step-num">2</div>
                            <div class="step-text">
                                Tap the <strong>Share</strong> button
                                <i class="bi bi-box-arrow-up ms-1 text-primary"></i>
                                at the bottom of Safari
                            </div>
                        </div>
                        <div class="ios-step">
                            <div class="step-num">3</div>
                            <div class="step-text">
                                Scroll down and tap
                                <strong>"Add to Home Screen"</strong>
                                <i class="bi bi-plus-square ms-1 text-primary"></i>
                            </div>
                        </div>
                        <div class="ios-step">
                            <div class="step-num">4</div>
                            <div class="step-text">
                                Tap <strong>"Add"</strong> — the app icon appears on your home screen
                            </div>
                        </div>
                        <div class="ios-step">
                            <div class="step-num">5</div>
                            <div class="step-text">
                                Open the app from home screen and allow
                                <strong>Location</strong> permission when prompted
                            </div>
                        </div>
                    </div>

                    <div class="ios-note">
                        <i class="bi bi-info-circle me-1"></i>
                        <strong>Note:</strong> iOS Safari limits background GPS.
                        Keep the app open and screen on while Working From Home for accurate tracking.
                    </div>

                    <!-- Copy link button -->
                    <button class="ios-copy-btn" @onclick="CopyAppLink">
                        <i class="bi bi-link-45deg me-1"></i>
                        @(LinkCopied ? "✓ Link Copied!" : "Copy App Link")
                    </button>
                </div>

            </div>
        </div>
    }

    <!-- BODY -->
    <div class="side-menu-body">

        <!-- MAIN -->
        <label class="menu-category">MAIN MENU</label>

        <NavLink href="/attendance" class="menu-item" ActiveClass="active" @onclick="ToggleMenu">
            <i class="bi bi-clock"></i> Mark Attendance
        </NavLink>

        <a href="/apply-leave" class="menu-item">
            <i class="bi bi-calendar-plus"></i> Apply Leave Request
        </a>

        @if (!string.IsNullOrEmpty(EmployeeName) && (EmployeeDepartment == "Human  Resources" || EmployeeId == "1" ||
        EmployeeId == "7" || EmployeeId == "12"))
        {
            <!-- HR MENU -->
            <label class="menu-category mt-3">HR MODULE</label>

            <NavLink href="/manual-attendance" class="menu-item" ActiveClass="active" @onclick="ToggleMenu">
                <i class="bi bi-clock"></i> Manual Attendance
            </NavLink>
            <NavLink href="/hr_daily_attendance" class="menu-item" ActiveClass="active" @onclick="ToggleMenu">
                <i class="bi bi-bar-chart"></i> Daily / Monthly Attendance Report
            </NavLink>

            <NavLink href="/outpass-request" class="menu-item" ActiveClass="active" @onclick="ToggleMenu">
                <i class="bi bi-box-arrow-right"></i> Out Pass Request
            </NavLink>

            <NavLink href="/leave-request" class="menu-item" ActiveClass="active" @onclick="ToggleMenu">
                <i class="bi bi-calendar-check"></i> Leave/EarlyOut/WFH Request
            </NavLink>

            <NavLink href="/movement-register-report" class="menu-item" ActiveClass="active" @onclick="ToggleMenu">
                <i class="bi bi-calendar-check"></i> Movement Register(Tea/Lunch/Short Exit)
            </NavLink>

            <NavLink href="/wfh-monitoring" class="menu-item" ActiveClass="active" @onclick="ToggleMenu">
                <i class="bi bi-geo-alt-fill"></i> WFH Live Monitoring
            </NavLink>

           
           
            @* <NavLink href="/early-out" class="menu-item" ActiveClass="active" @onclick="ToggleMenu">
                <i class="bi bi-arrow-right-circle"></i> Early Exit Request
        </NavLink> *@

        }
        <!-- EXTRA -->
        @if (!string.IsNullOrEmpty(EmployeeName) && (EmployeeId == "12" || EmployeeId == "10" || EmployeeId == "1061" ||
        EmployeeId == "6" || EmployeeId == "1058"))
        {
            <!-- HR MENU -->
            <label class="menu-category mt-3">TL MODULE</label>

            <NavLink href="/team-leave-requests" class="menu-item" ActiveClass="active" @onclick="ToggleMenu">
                <i class="bi bi-calendar-check"></i> Leave/EarlyOut/WFH Request
            </NavLink>

           

        }

        <!-- EXTRA -->
        <label class="menu-category mt-3">Report</label>
        <NavLink href="/my-report" class="menu-item" ActiveClass="active" @onclick="ToggleMenu">
            <i class="bi bi-file-earmark-text"></i> My Attendance Report
        </NavLink>
        <NavLink href="/outpass-report" class="menu-item" ActiveClass="active" @onclick="ToggleMenu">
            <i class="bi bi-file-earmark-text"></i> My In/Out Pass Report
        </NavLink>
        <NavLink href="/leave-report" class="menu-item" ActiveClass="active" @onclick="ToggleMenu">
            <i class="bi bi-file-earmark-text"></i> My Leave Report
        </NavLink>
        <NavLink href="/mymovement-register-report" class="menu-item" ActiveClass="active" @onclick="ToggleMenu">
            <i class="bi bi-calendar-check"></i> My (Tea/Lunch/Short Exit) Register
        </NavLink>
        <label class="menu-category mt-3">OTHERS</label>

        <a href="/holidayscalender" class="menu-item">
            <i class="bi bi-flag"></i> Holidays Calendar
        </a>

        <div class="menu-divider"></div>

        <a href="javascript:void(0)" class="menu-item text-danger mt-2" @onclick="Logout">
            <i class="bi bi-box-arrow-left"></i> Secure Logout
        </a>

    </div>
</div>

<!-- MAIN CONTENT -->
<main class="main-content">
    @Body
</main>

