@page "/apply-leave"
@using Microsoft.AspNetCore.Components.Forms
@using SMART_HRMS_SYSTEM.Shared.Models
@using SMART_HRMS_SYSTEM.Shared.ViewModel
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavManager

<div class="page-bg">
    <div class="container-form">

        <!-- HEADER -->
        <div class="header">
            <div class="icon">
                <i class="bi bi-calendar-event"></i>
            </div>
            <h2>Apply Leave / Early Out / WFH / Client Visit</h2>
            <p>Fill the form below to submit your request</p>
        </div>

        <!-- CARD -->
        <div class="card-form">

           

            <EditForm Model="@leaveModel" OnSubmit="SubmitRequest">

                <!-- SECTION 1 -->
                <div class="section">
                    <div class="section-header">
                        <span>01</span> Request Details
                    </div>

                    <div class="grid-2">

                        <div class="field full">
                            <label>Request Type *</label>
                            <select class="input"
                                    @bind="leaveModel.RequestType"
                                    @bind:after="OnRequestTypeChanged">
                                <option>Work From Home</option> <!-- नवीन पर्याय -->
                                <option>Early Out</option>
                                <option>Full Day Leave</option>
                                <option>First Half Day</option>
                                <option>Second Half Day</option>                         
                                <option>Client Meeting</option>  <!-- नवीन पर्याय -->
                            </select>
                        </div>

                        <div class="field">
                            <label>Leave Category *</label>
                            <select class="input" @bind="leaveModel.LeaveCategory">
                                <option>Casual</option>
                                <option>Sick</option>
                                <option>Planned</option>
                                <option>Official Work</option> <!-- Meeting/WFH साठी योग्य -->
                                <option>Other</option>
                            </select>
                        </div>

                        <div class="field">
                            <label>Leave Type *</label>
                            <select class="input" @bind="leaveModel.LeaveType">
                                <option>Paid</option>
                                <option>Unpaid</option>
                                <option>On-Duty</option> <!-- Meeting साठी योग्य -->
                                <option>Other</option>
                            </select>
                        </div>

                    </div>
                </div>

                <!-- SECTION 2 -->
                <div class="section">
                    <div class="section-header">
                        <span>02</span> Leave Information
                    </div>

                    <div class="grid-2">

                        @if (leaveModel.RequestType == "Full Day Leave" || leaveModel.RequestType == "Work From Home" || leaveModel.RequestType == "Client Meeting")
                        {
                            <div class="field">
                                <label>From Date *</label>
                                <input type="date" class="input" @bind="leaveModel.FromDate" />
                            </div>

                            <div class="field">
                                <label>To Date *</label>
                                <input type="date" class="input" @bind="leaveModel.ToDate" />
                            </div>
                        }
                        else
                        {
                            <div class="field">
                                <label>Date *</label>
                                <input type="date" class="input" @bind="leaveModel.FromDate" />
                            </div>
                            @if (leaveModel.RequestType == "First Half Day")
                            {
                                <div class="field">
                                    <label>In Time *</label>
                                    <input type="text" class="input" @bind="OutTimeDisplay" />
                                </div>
                            }
                            else if (leaveModel.RequestType == "Early Out" || leaveModel.RequestType == "Second Half Day")
    
                            {

                                <div class="field">
                                    <label>Out Time *</label>
                                    <input type="text" class="input" @bind="OutTimeDisplay" />
                                </div>
                            }
                        }

                    </div>
                </div>

                <!-- SECTION 3 -->
                <div class="section">
                    <div class="section-header">
                        <span>03</span> Additional Info
                    </div>

                    <div class="grid-2">

                        <div class="field full">
                            <label>Subject *</label>
                            <select class="input" @bind="leaveModel.Subject">
                                <option value="">-- Select Subject --</option>
                                <option>Personal Work</option>
                                <option>Medical Leave</option>
                                <option>Emergency WFH</option>
                                <option>Client Visit / Meeting</option>
                                <option>Project Discussion</option>
                                <option>Family Function</option>
                                <option>Other</option>
                            </select>
                        </div>
                        @if (leaveModel.RequestType == "Client Meeting" )
                        {
                            <div class="field full">
                                <label>Detailed Reason / Meeting Location *</label>
                                <textarea class="input textarea"
                                @bind="leaveModel.Reason"
                                placeholder="Provide more details (e.g. Client name, Location, or Emergency reason)"></textarea>
                            </div>
                        }else{ 
                        <div class="field full">
                            <label>Detailed Reason *</label>
                            <textarea class="input textarea"
                                      @bind="leaveModel.Reason"
                                      placeholder="Provide more details (e.g.Emergency reason)"></textarea>
                        </div>
                        }

                        <div class="field full">
                            <label>Attach Document (Optional)</label>
                            <div class="file-upload-box">
                                <i class="bi bi-paperclip file-upload-icon"></i>
                                <span class="file-upload-text">
                                    @(string.IsNullOrEmpty(FileName) ? "Click to browse or drop a file" : FileName)
                                </span>
                                <InputFile OnChange="HandleFileUpload" class="file-upload-input" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ACTIONS -->
                <div class="actions">
                    <button type="button" class="btn cancel" @onclick="GoBack">
                        Cancel
                    </button>

                    <button type="submit" class="btn submit" disabled="@IsSubmitting">
                        @if (IsSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Submit Request
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

<style>

/* ===== PAGE ===== */
.page-bg {
    background: #f5f7fb;
    min-height: 100vh;
    padding: 50px 15px;
    font-family: 'Inter', sans-serif;
}

.container-form {
    max-width: 820px;
    margin: auto;
}

/* ===== HEADER ===== */
.header {
    text-align: center;
    margin-bottom: 30px;
}

.header .icon {
    width: 48px;
    height: 48px;
    background: white;
    border-radius: 12px;
    margin: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4f46e5;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
}

.header h2 {
    margin-top: 10px;
    font-weight: 700;
    color: #1e293b;
}

.header p {
    color: #64748b;
    font-size: 14px;
}

/* ===== CARD ===== */
.card-form {
    background: white;
    padding: 30px;
    border-radius: 14px;
    border: 1px solid #e5e7eb;
}

/* ===== SECTION ===== */
.section {
    margin-bottom: 30px;
}

.section-header {
    font-weight: 600;
    margin-bottom: 15px;
    border-bottom: 1px solid #e5e7eb;
    padding-bottom: 8px;
    color: #1e293b;
}

.section-header span {
    color: #4f46e5;
    font-weight: 700;
    margin-right: 8px;
}

/* ===== GRID ===== */
.grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
}

.field {
    display: flex;
    flex-direction: column;
}

.field.full {
    grid-column: span 2;
}

/* ===== FILE UPLOAD ===== */
.file-upload-box {
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1.5px dashed #c7d2fe;
    border-radius: 10px;
    padding: 12px 14px;
    background: #f8fafc;
    cursor: pointer;
    transition: 0.15s;
    overflow: hidden;
}
.file-upload-box:hover { border-color: #4f46e5; background: #eef2ff; }
.file-upload-icon { color: #4f46e5; font-size: 18px; flex-shrink: 0; }
.file-upload-text { font-size: 13px; color: #64748b; font-weight: 500; }
.file-upload-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
}

/* ===== INPUT ===== */
.input {
    height: 42px;
    padding: 8px 12px;
    border-radius: 8px;
    border: 1px solid #d1d5db;
    font-size: 14px;
}

.textarea {
    height: 90px;
    resize: none;
}

/* focus */
.input:focus {
    border-color: #4f46e5;
    outline: none;
    box-shadow: 0 0 0 2px rgba(79,70,229,0.15);
}

/* ===== LABEL ===== */
label {
    font-size: 13px;
    margin-bottom: 5px;
    font-weight: 600;
    color: #374151;
}

/* ===== BUTTONS ===== */
.actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    border-top: 1px solid #e5e7eb;
    padding-top: 20px;
}

.btn {
    padding: 8px 20px;
    border-radius: 8px;
    font-weight: 600;
}

.cancel {
    background: #f3f4f6;
}

.submit {
    background: #4f46e5;
    color: white;
    border: none;
}

/* ===== MOBILE ===== */
@@media(max-width:768px){
    .grid-2 {
        grid-template-columns: 1fr;
    }

    .field.full {
        grid-column: span 1;
    }
}
    /* Toast */
    .custom-toast {
        position: fixed;
        bottom: 20px;
        right: 20px;
        padding: 12px 20px;
        border-radius: 10px;
        font-weight: 600;
        color: white;
        z-index: 3000;
        animation: slideUp 0.3s ease;
    }

    .toast-success {
        background: #10b981;
    }

    .toast-error {
        background: #ef4444;
    }
</style>
@* !-- Toast Alert --> *@
@if (!string.IsNullOrEmpty(ToastMessage))
{
    <div class="custom-toast @ToastCssClass">
        @ToastMessage
    </div>
}
@code {

    private bool IsSubmitting = false;
    private string Message = "";
    private string AlertClass = "";

    private IBrowserFile selectedFile;
    private string FileName = "";
    // Toast

    private string ToastMessage = "";
    private string ToastCssClass = "";
    private string EmployeeName = string.Empty;
    private string EmployeeDepartment = string.Empty;
    private LeaveRequestModel leaveModel = new LeaveRequestModel
    {
        RequestType = "Full Day Leave",
        LeaveCategory = "Casual",
        LeaveType = "Paid",
        FromDate = DateTime.Today
    };

    protected override async Task OnInitializedAsync()
    {

    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var empIdStr = await JS.InvokeAsync<string>("localStorage.getItem", "empId");
                if (!string.IsNullOrEmpty(empIdStr))
                {
                    leaveModel.EmpId = int.Parse(empIdStr);
                    StateHasChanged(); // Refresh UI after loading data
                }
                EmployeeName = await JS.InvokeAsync<string>("localStorage.getItem", "empName");
                if (string.IsNullOrEmpty(EmployeeName)) NavManager.NavigateTo("/", true);
                var dept = await JS.InvokeAsync<string>("localStorage.getItem", "empDept");
                if (!string.IsNullOrEmpty(dept)) EmployeeDepartment = dept;

            }
            catch { /* Handle JS not available */ }
        }
    }

    private void OnRequestTypeChanged()
    {
        if (leaveModel.RequestType == "Full Day Leave" || leaveModel.RequestType == "Work From Home")
        {
            leaveModel.OutTime = null;
            leaveModel.ToDate ??= leaveModel.FromDate;
        }
        else if (leaveModel.RequestType == "First Half Day")
        {
            leaveModel.ToDate = null;
            // 9:30 AM
            leaveModel.OutTime = new TimeSpan(14, 30, 0);
        }
        else if (leaveModel.RequestType == "Work From Home")
        {
            leaveModel.ToDate ??= leaveModel.FromDate;
            // 9:30 AM
            leaveModel.OutTime =null;
        }
        else if (leaveModel.RequestType == "Client Meeting")
        {
            leaveModel.ToDate ??= leaveModel.FromDate;
            // 9:30 AM
            leaveModel.OutTime =null;
        }
        else if (leaveModel.RequestType == "Second Half Day")
        {
            leaveModel.ToDate = null;
            // 2:00 PM
            leaveModel.OutTime = new TimeSpan(14, 0, 0);
        }
        else if (leaveModel.RequestType == "Early Out")
        {
            leaveModel.ToDate = null;
            // 5:00 PM
            leaveModel.OutTime = new TimeSpan(17, 0, 0);
        }
        StateHasChanged();
    }

    private string OutTimeDisplay
    {
        get => leaveModel.OutTime.HasValue
               ? DateTime.Today.Add(leaveModel.OutTime.Value).ToString("hh:mm tt")
               : "";
        set
        {
            // Try parsing common time formats
            if (DateTime.TryParse(value, out var dt))
            {
                leaveModel.OutTime = dt.TimeOfDay;
            }
            else if (TimeSpan.TryParse(value, out var ts))
            {
                leaveModel.OutTime = ts;
            }
        }
    }

    private async Task SubmitRequest()
    {
        if (string.IsNullOrWhiteSpace(leaveModel.Subject))
        {
            ShowToast("Subject required", "toast-error");
            return;
        }

        if (string.IsNullOrWhiteSpace(leaveModel.Reason))
        {
            ShowToast("Reason required", "toast-error");
            return;
        }

        IsSubmitting = true;

        try
        {

            var response = await Http.PostAsJsonAsync("api/LeaveRequest/Save", leaveModel);

            if (response.IsSuccessStatusCode)
            {          
                ShowToast("Request submitted successfully", "toast-success");

                // =========================================================
                // 🔥 NEW: Outpass Save झाल्यावर लगेच Notification API ला कॉल करा
                // =========================================================
                try
                {
                    if (EmployeeDepartment != "Human  Resources")
                    {
                        string title = "New Leave Request";
                        string body = $"{EmployeeName} has requested an {leaveModel.RequestType}. Please review.";
                        string link = "/leave-request";

                        var notification = new NotificationRequest
                        {
                            EmployeeName = EmployeeName,
                            Title = title,
                            Body = body,
                            Link = link
                        };

                        await Http.PostAsJsonAsync("api/Notifications/sendHRNotification", notification);

                    }
                   

                    // -------------------------------------------------------------
                    // अप्लाय करणारा व्यक्ती स्वतः Team Leader आहे का ते तपासा
                    // -------------------------------------------------------------
                    List<int> teamLeaderIds = new List<int> { 10, 1061, 6, 1053, 12, 1047, 1058 };

                    if (teamLeaderIds.Contains(leaveModel.EmpId))
                    {
                        // ✅ जर अप्लाय करणारा व्यक्ती Team Leader असेल:
                        // तर नोटिफिकेशन TL ला न जाता, थेट 2 Admin लोकांना जाईल.

                        // टीप: इथे त्या 2 Admin चे खरे Employee ID टाका (मी उदाहरणासाठी 1 आणि 2 घेतले आहेत)
                        List<int> adminIds = new List<int> { 1, 7 };

                        foreach (var adminId in adminIds)
                        {
                            var adminNotification = new NotificationRequest
                            {
                                EmpId = adminId,
                                Title = $"TL Leave Request: {EmployeeName}",
                                Body = $"{EmployeeName} (Team Leader) has applied for {leaveModel.RequestType}.",
                                Link = "/leave-request" // Admin च्या अप्रूव्हल पेजची लिंक
                            };
                            await Http.PostAsJsonAsync("api/Notifications/sendEmployeeNotification", adminNotification);
                        }
                    }
                    else
                    {
                        // ✅ जर अप्लाय करणारा व्यक्ती सामान्य Employee असेल:
                        // तर त्याच्या डिपार्टमेंटनुसार त्याच्या TL ला नोटिफिकेशन पाठवा.

                        int teamLeaderId = 0;

                        if (EmployeeDepartment == "Development" || EmployeeDepartment == "Software Testing" || EmployeeDepartment == "Deployment")
                        {
                            teamLeaderId = 10;
                        }
                        else if (EmployeeDepartment == "Support")
                        {
                            teamLeaderId = 1061;
                        }
                        else if (EmployeeDepartment == "Operation")
                        {
                            teamLeaderId = 1058;
                        }
                        else if (EmployeeDepartment == "Sale")
                        {
                            teamLeaderId = 6;
                        }
                        
                        // स्वतःलाच नोटिफिकेशन जाऊ नये याची काळजी (just for safety)
                        if (teamLeaderId > 0 && teamLeaderId != leaveModel.EmpId)
                        {
                            var tlNotification = new NotificationRequest
                            {
                                EmpId = teamLeaderId, // TL चा ID
                                Title = "Action Required: Team Member Leave Request",
                                Body = $"{EmployeeName} from your team applied for {leaveModel.RequestType}.",
                                Link = "/tl-leave-approvals" // TL च्या पेजची लिंक
                            };
                            await Http.PostAsJsonAsync("api/Notifications/sendEmployeeNotification", tlNotification);
                        }
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine("Notification send failed: " + ex.Message);
                }
                leaveModel.Subject = null;
                leaveModel.Reason = null;


            }
            else
            {
                ShowToast("Submission failed", "toast-error");
            }
        }
        catch (Exception ex)
        {
            ShowToast("Submission failed", "toast-error");
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    // Helpers
    private async void ShowToast(string msg, string css)
    {
        ToastMessage = msg;
        ToastCssClass = css;
        StateHasChanged();
        await Task.Delay(3000);
        ToastMessage = "";
        StateHasChanged();
    }

    private void GoBack()
    {
        NavManager.NavigateTo("/attendance");
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        FileName = selectedFile.Name;

        // Convert to Base64 (DB मध्ये store करायला सोपं)
        using var stream = selectedFile.OpenReadStream(5 * 1024 * 1024); // 5MB limit
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        var bytes = ms.ToArray();
        leaveModel.DocumentAttachament = Convert.ToBase64String(bytes);
    }
}