        display: flex;
        gap: 12px;
        justify-content: center;
        margin-top: 10px;
    }

    .btn-modal-red, .btn-modal-green {
        flex: 1;
        padding: 12px 20px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 15px;
        border: none;
        transition: transform 0.1s, opacity 0.2s;
