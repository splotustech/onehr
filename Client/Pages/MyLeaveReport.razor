        .report-wrapper {
            padding: 15px 10px;
        }

        .filter-row {
            flex-wrap: wrap;
        }

        .filter-item {
            flex: 1 1 100%;
        }

        .search-item {
            flex: 1 1 100%;
        }

        .btn-item {
            flex: 1 1 100%;
            margin-top: 5px;
        }

        .custom-select {
            padding: 8px 10px;
            font-size: 13px;
        }

        .stat-card {
            flex-direction: column;
            text-align: center;
            gap: 8px;
        }

        .report-table-wrapper {
            background: transparent;
            box-shadow: none;
        }

        .modern-table thead {
            display: none;
        }

        .modern-table, .modern-table tbody, .modern-table tr, .modern-table td {
            display: block;
            width: 100%;
            box-sizing: border-box;
        }

            .modern-table tr {
                margin-bottom: 15px;
                background: white;
                padding: 15px;
                border-radius: 16px;
                box-shadow: 0 4px 10px rgba(0,0,0,0.03);
                border: 1px solid #e2e8f0;
            }

            .modern-table td {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 8px 0;
                border: none;
                font-size: 13px;
                gap: 15px;
                text-align: right;
            }

                .modern-table td::before {
                    content: attr(data-label);
                    font-weight: 600;
                    color: #64748b;
                    min-width: 110px;
                    text-transform: uppercase;
                    font-size: 11px;
                    text-align: left;
                }
        /* Mobile specific adjustments for inner cell content */
        .employee-cell {
            justify-content: flex-end;
            text-align: right;
        }

        .emp-info {
            text-align: right;
        }

        .action-buttons {
            justify-content: flex-end !important;
            width: 100%;
        }

        .reason-cell {
            text-align: right;
        }

            .reason-cell p {
                text-align: right;
            }

        .confirm-modal {
            padding: 25px 15px;
        }
    }
</style>

@code {
    private bool IsLoading = true;
    private bool IsProcessing = false;
    private string FilterType = "Monthly";
    private DateTime SelectedDate = DateTime.Today;
    private int SelectedMonth = DateTime.Today.Month;
    private int SelectedYear = DateTime.Today.Year;
    private string FilterStatus = "All";
    private string SearchText = "";

    private List<LeaveRequestModel> AllRecords = new();
    private List<LeaveRequestModel> FilteredRecords = new();

    private int TotalRequests, PendingCount, ApprovedCount, RejectedCount;
    private bool ShowApproveModal, ShowRejectModal;
    private LeaveRequestModel SelectedRequest;
    private string EmployeeName = string.Empty;
    private string EmployeeId = string.Empty;
    private string HRComment = "";
    private string ToastMsg, ToastClass;

    protected override async Task OnInitializedAsync() => await LoadRequests();
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                EmployeeName = await JS.InvokeAsync<string>("localStorage.getItem", "empName");
                if (string.IsNullOrEmpty(EmployeeName))
                {
                    NavManager.NavigateTo("/", true);
                }
                EmployeeId = await JS.InvokeAsync<string>("localStorage.getItem", "empId");
               
                StateHasChanged();
            }
            catch
            {
            }
        }
    }
    private async Task LoadRequests()
    {
        IsLoading = true;
        try
        {
            // Update URL to your actual API Controller
            string url = $"api/LeaveRequest/GetAllRequests?viewType={FilterType}";
            if (FilterType == "Daily") url += $"&date={SelectedDate:yyyy-MM-dd}";
            else url += $"&month={SelectedMonth}&year={SelectedYear}";

            var response = await Http.GetFromJsonAsync<List<LeaveRequestModel>>(url);
            AllRecords = response.Where(t => t.EmpId ==Convert.ToInt32(EmployeeId)).ToList() ?? new();
            ApplyFilters();
        }
        catch (Exception ex) { ShowToast("Server Error: " + ex.Message, "t-error"); }
        finally { IsLoading = false; }
    }

    private void ApplyFilters()
    {
        var query = AllRecords.Where(t => t.EmpId == Convert.ToInt32(EmployeeId)).ToList().AsEnumerable();
        if (FilterStatus != "All") query = query.Where(x => x.Status == FilterStatus);
        if (!string.IsNullOrWhiteSpace(SearchText))
            query = query.Where(x => x.EmpName.Contains(SearchText, StringComparison.OrdinalIgnoreCase) || x.Subject.Contains(SearchText, StringComparison.OrdinalIgnoreCase));

        FilteredRecords = query.ToList();

        TotalRequests = FilteredRecords.Where(t => t.EmpId == Convert.ToInt32(EmployeeId)).ToList().Count;
        PendingCount = FilteredRecords.Where(t => t.EmpId == Convert.ToInt32(EmployeeId)).ToList().Count(x => x.Status == "Pending");
        ApprovedCount = FilteredRecords.Where(t => t.EmpId == Convert.ToInt32(EmployeeId)).ToList().Count(x => x.Status == "Approved");
        RejectedCount = FilteredRecords.Where(t => t.EmpId == Convert.ToInt32(EmployeeId)).ToList().Count(x => x.Status == "Rejected");

        StateHasChanged(); // UI रिफ्रेश करण्यासाठी
    }

    private void OnSearchInput(ChangeEventArgs e) { SearchText = e.Value?.ToString() ?? ""; ApplyFilters(); }
    private void ResetFilters() { FilterStatus = "All"; SearchText = ""; LoadRequests(); }

    private void OpenApproveModal(LeaveRequestModel r) { SelectedRequest = r; ShowApproveModal = true; }
    private void OpenRejectModal(LeaveRequestModel r) { SelectedRequest = r; HRComment = ""; ShowRejectModal = true; }
    private void CloseModals() { ShowApproveModal = ShowRejectModal = false; SelectedRequest = null; }

  

    private async Task ConfirmDelete()
    {
          IsProcessing = true;
        try
        {
           
            var res = await Http.DeleteAsync($"api/LeaveRequest/Delete/{SelectedRequest.Id}");
            if (res.IsSuccessStatusCode)
            {
                ShowToast("Leave Deleted", "t-success");
              
                await LoadRequests();
                CloseModals();
            }
        }
        catch { ShowToast("Operation failed", "t-error"); }
        finally { IsProcessing = false; }
    }

    private void ShowToast(string msg, string cls)
    {
        ToastMsg = msg; ToastClass = cls; StateHasChanged();
        Task.Delay(3000).ContinueWith(_ => { ToastMsg = ""; InvokeAsync(StateHasChanged); });
    }

    private string GetStatusCss(string s) => s switch { "Approved" => "st-approved", "Rejected" => "st-rejected", _ => "st-pending" };
    private string GetInitials(string n) => string.IsNullOrWhiteSpace(n)
    ? "?"
    : string.Concat(n.Split(' ').Where(x => !string.IsNullOrWhiteSpace(x)).Select(x => x[0])).ToUpper(); private void ShowFullDetails(LeaveRequestModel r) => JS.InvokeVoidAsync("alert", $"Leave Detail:\n{r.Subject}\nReason: {r.Reason}\nTL Comment: {r.TLComment}\nHR Comment: {r.HRComment}");
