@code {
    private bool IsLoading = false;
    private bool IsProcessing = false;

    // Filters
    private string FilterType = "Daily"; // Daily or Monthly
    private DateTime SelectedDate = DateTime.Today;
    private int SelectedMonth = DateTime.Today.Month;
    private int SelectedYear = DateTime.Today.Year;
    private string FilterStatus = "All";
    private string SearchText = "";

    // Stats
    private int TotalRequests, PendingCount, ApprovedCount, RejectedCount;

    // Data - Explicitly initialized with new List<T>()
    private List<InOutPassViewModel> AllRecords = new List<InOutPassViewModel>();
    private List<InOutPassViewModel> FilteredRecords = new List<InOutPassViewModel>();

    // Modal Variables
    private bool ShowApproveModal  = false;
    private bool ShowRejectModal   = false;
    private bool ShowDetailsModal  = false;
    private InOutPassViewModel SelectedRequest = null;
    private string RejectReason = "";

    // Toast
    private string ToastMessage = "";
    private string ToastCssClass = "";
    private string EmployeeName = string.Empty;
    private string EmployeeId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadRequests();
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                EmployeeName = await JS.InvokeAsync<string>("localStorage.getItem", "empName");
                if (string.IsNullOrEmpty(EmployeeName))
                {
                    NavManager.NavigateTo("/", true);
                }
                EmployeeId = await JS.InvokeAsync<string>("localStorage.getItem", "empId");
                
                StateHasChanged();
            }
            catch
            {
            }
        }
    }
    private async Task LoadRequests()
    {
        IsLoading = true;
        try
        {
            // Build the URL based on the View Type (Daily or Monthly)
            string url = $"api/InOutPass/GetPassRequests?filterType={FilterType}";

            if (FilterType == "Daily")
            {
                url += $"&date={SelectedDate:yyyy-MM-dd}";
            }
            else
            {
                url += $"&month={SelectedMonth}&year={SelectedYear}";
            }

            // Fetch actual data from the database
            var response = await Http.GetFromJsonAsync<List<InOutPassViewModel>>(url);

            if (response != null)
            {
                AllRecords = response.Where(t => t.Empid == Convert.ToInt32(EmployeeId)).ToList();
            }
            else
            {
                AllRecords = new List<InOutPassViewModel>();
            }

            // Apply local text-search and status filters
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            ShowToast("Failed to load data from server", "toast-error");
            AllRecords = new List<InOutPassViewModel>();
            FilteredRecords = new List<InOutPassViewModel>();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ApplyFilters()
    {
        var q = AllRecords.Where(t => t.Empid == Convert.ToInt32(EmployeeId)).ToList().AsEnumerable();

        // Local Status Filter
        if (FilterStatus != "All")
            q = q.Where(x => x.Status == FilterStatus);

        // Local Search Filter
        if (!string.IsNullOrWhiteSpace(SearchText))
            q = q.Where(x => !string.IsNullOrEmpty(x.EmpName) && x.EmpName.Contains(SearchText, StringComparison.OrdinalIgnoreCase));

        FilteredRecords = q.ToList();

        // Calculate Stats based on currently fetched records
        TotalRequests = FilteredRecords.Where(t => t.Empid == Convert.ToInt32(EmployeeId)).Count();
        PendingCount = FilteredRecords.Where(t => t.Empid == Convert.ToInt32(EmployeeId)).Count(x => x.Status == "Pending");
        ApprovedCount = FilteredRecords.Where(t => t.Empid == Convert.ToInt32(EmployeeId)).Count(x => x.Status == "Approved");
        RejectedCount = FilteredRecords.Where(t => t.Empid == Convert.ToInt32(EmployeeId)).Count(x => x.Status == "Rejected");
        StateHasChanged(); // UI रिफ्रेश करण्यासाठी
    }



    private void ResetFilters()
    {
        SearchText = "";
        FilterStatus = "All";
        FilterType = "Daily";
        SelectedDate = DateTime.Today;
        ApplyFilters();
    }

    // Input Handlers
    private void OnSearchInput(ChangeEventArgs e)
    {
        SearchText = e.Value?.ToString() ?? string.Empty;
        ApplyFilters();
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var parsedDate))
        {
            SelectedDate = parsedDate;
            await LoadRequests();
        }
    }

    // Modals
    private void PromptApprove(InOutPassViewModel req)
    {
        SelectedRequest = req;
        ShowApproveModal = true;
    }

    private void PromptReject(InOutPassViewModel req)
    {
        SelectedRequest = req;
        RejectReason = "";
        ShowRejectModal = true;
    }

    private void CloseModals()
    {
        ShowApproveModal = false;
        ShowRejectModal  = false;
        ShowDetailsModal = false;
        SelectedRequest  = null;
    }

    private void ShowDetails(InOutPassViewModel r)
    {
        SelectedRequest  = r;
        ShowDetailsModal = true;
        ShowRejectModal  = false;
        ShowApproveModal = false;
    }

    

    private async Task ConfirmDelete()
    {
        

        IsProcessing = true;
        try
        {
            await Http.DeleteAsync($"api/InOutPass/Delete/{SelectedRequest.Id}");
            await Task.Delay(800); // Simulate API           
            
            ShowToast("Request Deleted.", "toast-success");
            CloseModals();
            ResetFilters();
            await LoadRequests();
        }
        catch
        {
            ShowToast("Error Deleted request.", "toast-error");
        }
        IsProcessing = false;
    }

    // Helpers
    private async void ShowToast(string msg, string css)
    {
        ToastMessage = msg;
        ToastCssClass = css;
        StateHasChanged();
        await Task.Delay(3000);
        ToastMessage = "";
        StateHasChanged();
    }

    private string GetStatusCss(string? status) => status switch
    {
        "Approved" => "bg-present",
        "Pending"  => "bg-late",
        "Rejected" => "bg-absent",
        _          => "bg-secondary"
    };

    private string GetStatusCardCss(string? status) => status switch
    {
        "Approved" => "ip-card-green",
        "Rejected" => "ip-card-red",
        _          => "ip-card-gray"
    };

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return (parts[0].Substring(0, 1) + parts[1].Substring(0, 1)).ToUpper();
    }
}