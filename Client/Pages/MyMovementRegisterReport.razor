@code {
    private bool IsLoading = false;
    private string FilterType = "Daily";
    private DateTime SelectedDate = DateTime.Today;
    private int SelectedMonth = DateTime.Today.Month;
    private int SelectedYear = DateTime.Today.Year;
    private string SearchText = "";
    private string EmployeeName = string.Empty;
    private string EmployeeId = string.Empty;

    private int TotalRequests, OutsideCount, ReturnedCount, TeaBreakCount;

    private List<MovementViewModel> AllRecords = new();
    private List<MovementViewModel> FilteredRecords = new();

    protected override async Task OnInitializedAsync() => await LoadRecords();
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                EmployeeName = await JS.InvokeAsync<string>("localStorage.getItem", "empName");
                if (string.IsNullOrEmpty(EmployeeName))
                {
                    NavManager.NavigateTo("/", true);
                }
                var empid = await JS.InvokeAsync<string>("localStorage.getItem", "empId");
                if (!string.IsNullOrEmpty(empid)) EmployeeId = empid;
                StateHasChanged();
            }
            catch
            {
            }
        }
    }
    private async Task LoadRecords()
    {
        IsLoading = true;
        try
        {
            // १. आधी empId मिळवा आणि त्याला int मध्ये कन्व्हर्ट करा
            var empIdStr = await JS.InvokeAsync<string>("localStorage.getItem", "empId");
            int currentEmpId = string.IsNullOrEmpty(empIdStr) ? 0 : int.Parse(empIdStr);

            string url = $"api/Movement/GetMovementRecords?filterType={FilterType}";
            url += FilterType == "Daily" ? $"&date={SelectedDate:yyyy-MM-dd}" : $"&month={SelectedMonth}&year={SelectedYear}";

            var response = await Http.GetFromJsonAsync<List<MovementViewModel>>(url);

            if (response != null)
            {
                // २. तुलना करताना int vs int करा
                AllRecords = response.Where(t => t.EmpId == currentEmpId).ToList();
            }

            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error: " + ex.Message);
            AllRecords = new();
        }
        finally { IsLoading = false; }
    }

    private void ApplyFilters()
    {
        var q = AllRecords.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(SearchText))
            q = q.Where(x => x.EmpName.Contains(SearchText, StringComparison.OrdinalIgnoreCase));

        FilteredRecords = q.ToList();

        // Stats Calculation
        TotalRequests = FilteredRecords.Count;
        OutsideCount = FilteredRecords.Count(x => !x.EntryTime.HasValue);
        ReturnedCount = FilteredRecords.Count(x => x.EntryTime.HasValue);
        TeaBreakCount = FilteredRecords.Count(x =>
     !string.IsNullOrEmpty(x.Reason) &&
     (x.Reason.Contains("Tea", StringComparison.OrdinalIgnoreCase) ||
      x.Reason.Contains("Lunch", StringComparison.OrdinalIgnoreCase)));
        StateHasChanged(); // UI रिफ्रेश करण्यासाठी
    }

    private void OnSearchInput(ChangeEventArgs e) { SearchText = e.Value?.ToString() ?? ""; ApplyFilters(); }
    private async Task OnDateChanged(ChangeEventArgs e) { if (DateTime.TryParse(e.Value?.ToString(), out var d)) { SelectedDate = d; await LoadRecords(); } }
    private void ResetFilters() { SearchText = ""; FilterType = "Daily"; SelectedDate = DateTime.Today; ApplyFilters(); }

    private string GetTimeStr(TimeSpan? ts) => ts.HasValue ? DateTime.Today.Add(ts.Value).ToString("hh:mm tt") : "-";
    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return (parts[0].Substring(0, 1) + parts[1].Substring(0, 1)).ToUpper();
        return parts[0].Substring(0, 1).ToUpper();
    }

    // ViewModel (Should match backend)
    public class MovementViewModel
    {
        public int EmpId { get; set; }
        public string EmpName { get; set; }
        public string Designation { get; set; }
        public DateTime LogDate { get; set; }
        public TimeSpan? ExitTime { get; set; }
        public TimeSpan? EntryTime { get; set; }
        public int? DurationMinutes { get; set; }
        public string Reason { get; set; }
    }
}