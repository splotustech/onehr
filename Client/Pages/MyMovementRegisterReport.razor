@page "/mymovement-register-report"
@using SMART_HRMS_SYSTEM.Shared.ViewModel
@using SMART_HRMS_SYSTEM.Shared.Models
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavManager

<div class="report-wrapper">
    <div class="report-container">

        <!-- Header -->
        <div class="report-header">
            <h2> My Movement Register Log</h2>
            <p>Monitor short breaks, tea, and lunch movements Details.</p>
        </div>

        <!-- Stats Row -->
        <div class="stats-row mb-4">
            <div class="stat-card stat-total shadow-sm">
                <div class="stat-icon"><i class="bi bi-person-walking"></i></div>
                <div class="stat-details">
                    <p class="stat-title">Total Movements</p>
                    <h3 class="stat-count">@TotalRequests</h3>
                </div>
            </div>

            <div class="stat-card stat-late shadow-sm" style="border-left: 4px solid #f59e0b;">
                <div class="stat-icon" style="background: #fef3c7; color: #d97706;"><i class="bi bi-door-open-fill"></i></div>
                <div class="stat-details">
                    <p class="stat-title">Currently Outside</p>
                    <h3 class="stat-count text-warning">@OutsideCount</h3>
                </div>
            </div>

            <div class="stat-card stat-present shadow-sm">
                <div class="stat-icon"><i class="bi bi-check-circle-fill"></i></div>
                <div class="stat-details">
                    <p class="stat-title">Returned</p>
                    <h3 class="stat-count">@ReturnedCount</h3>
                </div>
            </div>

            <div class="stat-card stat-absent shadow-sm">
                <div class="stat-icon"><i class="bi bi-cup-hot-fill"></i></div>
                <div class="stat-details">
                    <p class="stat-title">Tea / Lunch Breaks</p>
                    <h3 class="stat-count">@TeaBreakCount</h3>
                </div>
            </div>
        </div>

        <!-- Filter Card -->
        <div class="filter-card shadow-sm mb-4">
            <div class="filter-row">
                <div class="filter-item">
                    <label class="filter-label">VIEW TYPE</label>
                    <select class="form-select custom-select" @bind="FilterType" @bind:after="LoadRecords">
                        <option value="Daily">Daily View</option>
                        <option value="Monthly">Monthly View</option>
                    </select>
                </div>

                @if (FilterType == "Daily")
                {
                    <div class="filter-item">
                        <label class="filter-label">SELECT DATE</label>
                        <input type="date" class="form-control custom-select"
                               value="@SelectedDate.ToString("yyyy-MM-dd")"
                               @onchange="OnDateChanged" />
                    </div>
                }
                else
                {
                    <div class="filter-item">
                        <label class="filter-label">MONTH</label>
                        <select class="form-select custom-select" @bind="SelectedMonth" @bind:after="LoadRecords">
                            @for (int m = 1; m <= 12; m++)
                            {
                                <option value="@m">@System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(m)</option>
                            }
                        </select>
                    </div>
                    <div class="filter-item">
                        <label class="filter-label">YEAR</label>
                        <select class="form-select custom-select" @bind="SelectedYear" @bind:after="LoadRecords">
                            @for (int i = DateTime.Now.Year; i >= 2024; i--)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>
                    </div>
                }

                @* <div class="filter-item search-item">
                    <label class="filter-label">SEARCH EMPLOYEE</label>
                    <div class="search-box">
                        <i class="bi bi-search search-icon"></i>
                        <input class="form-control custom-select pl-search" style="width:70%"
                               placeholder="Name..."
                               value="@SearchText"
                               @oninput="OnSearchInput" />
                    </div>
                </div> *@

                <div class="filter-item btn-item">
                    <label class="filter-label d-none d-md-block">&nbsp;</label>
                    <button class="btn-search w-100" @onclick="ResetFilters" disabled="@IsLoading">
                        <i class="bi bi-arrow-repeat me-1"></i> Reset
                    </button>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="report-table-wrapper">
            @if (IsLoading)
            {
                <div class="empty-state"><h5>Loading Data...</h5></div>
            }
            else if (!FilteredRecords.Any())
            {
                <div class="empty-state"><h5>No Records Found</h5></div>
            }
            else
            {
                <table class="table modern-table">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Date / Times</th>
                            <th>Reason</th>
                            <th>Duration</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in FilteredRecords)
                        {
                            <tr>
                                <td data-label="Employee">
                                    <div class="employee-cell text-value">
                                        <div class="avatar">@GetInitials(r.EmpName)</div>
                                        <div>
                                            <span class="fw-bold d-block text-dark">@r.EmpName</span>
                                            <small class="text-muted">@r.Designation</small>
                                        </div>
                                    </div>
                                </td>
                                <td data-label="Date & Times">
                                    <div class="text-value">
                                        <span class="fw-bold text-dark">@r.LogDate.ToString("dd MMM yyyy")</span><br />
                                        <small class="text-muted">
                                            Out: <b class="text-danger">@GetTimeStr(r.ExitTime)</b> |
                                            In: <b class="text-success">@GetTimeStr(r.EntryTime)</b>
                                        </small>
                                    </div>
                                </td>
                                <td data-label="Reason">
                                    <span class="text-value text-muted">@r.Reason</span>
                                </td>
                                <td data-label="Duration">
                                    <span class="text-value fw-bold text-primary">
                                        @(r.DurationMinutes.HasValue ? $"{r.DurationMinutes} min" : "---")
                                    </span>
                                </td>
                                <td data-label="Status">
                                    <span class="status-badge @(r.EntryTime.HasValue ? "bg-present" : "bg-late")">
                                        @(r.EntryTime.HasValue ? "Returned" : "Outside")
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

