@page "/"
@page "/login"
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Forms
@using SMART_HRMS_SYSTEM.Shared.ViewModel

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-header">
            <h2>SPLOTUSTECH <br /> SOFTWARE</h2>
            <p>Welcome back! Please login to your account.</p>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="error-box">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="error-icon">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="8" x2="12" y2="12"></line>
                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
                <span>@ErrorMessage</span>
            </div>
        }

        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="input-group">
                <label>Username</label>
                <InputText placeholder="Enter your username" @bind-Value="loginModel.Username" autocomplete="off" />
                <ValidationMessage For="@(() => loginModel.Username)" class="text-danger-custom" />
            </div>

            <div class="input-group">
                <label>Password</label>
                <InputText type="password" placeholder="Enter your password" @bind-Value="loginModel.Password" />
                <ValidationMessage For="@(() => loginModel.Password)" class="text-danger-custom" />
            </div>

            <button type="submit" class="submit-btn" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <span class="spinner"></span> <span>Logging in...</span>
                }
                else
                {
                    <span>Login</span>
                }
            </button>
        </EditForm>

        <div class="login-footer">
            Attendance & Payroll System v1.0
        </div>
    </div>
</div>

<style>
    /* ===== RESET & BODY ===== */
    /* Blazor chya default padding la hatvnyasathi */
    :global(body), :global(html) {
        margin: 0;
        padding: 0;
        height: 100%;
    }

    /* ===== WRAPPER ===== */
    .login-wrapper {
        position: absolute; /* Full screen cover karnyasathi */
        top: 0;
        left: 0;
        width: 100%;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center; /* Vertically Center */
        padding: 20px;
        background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%);
        font-family: 'Segoe UI', Roboto, sans-serif;
        box-sizing: border-box;
    }

    /* ===== CARD ===== */
    .login-card {
        background: #ffffff;
        padding: 40px;
        border-radius: 24px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
        width: 100%;
        max-width: 400px;
        transition: transform 0.3s ease;
        margin: auto; /* Center alignment secure karnyasathi */
    }

    .login-card:hover {
        transform: translateY(-5px);
    }

    /* ===== HEADER ===== */
    .login-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .login-header h2 {
        margin: 0;
        color: #0f172a;
        font-size: 26px;
        font-weight: 800;
        letter-spacing: 0.5px;
        line-height: 1.3;
    }

    .login-header p {
        color: #64748b;
        font-size: 14px;
        margin-top: 8px;
    }

    /* ===== INPUT ===== */
    .input-group {
        margin-bottom: 20px;
    }

    .input-group label {
        display: block;
        margin-bottom: 6px;
        color: #334155;
        font-weight: 600;
        font-size: 13px;
    }

    .input-group input {
        width: 100%;
        padding: 14px 16px;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        font-size: 16px; /* 16px prevents zoom on iOS/Android */
        color: #1e293b;
        transition: all 0.25s ease;
        box-sizing: border-box;
        background: #f8fafc;
    }

    .input-group input:focus {
        border-color: #6366f1;
        background: #ffffff;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
        outline: none;
    }

    /* ===== VALIDATION ===== */
    .text-danger-custom {
        color: #ef4444;
        font-size: 12px;
        margin-top: 5px;
        display: block;
        font-weight: 500;
    }

    /* ===== BUTTON ===== */
    .submit-btn {
        width: 100%;
        padding: 15px;
        background: linear-gradient(135deg, #6366f1, #0ea5e9);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        margin-top: 15px;
        box-shadow: 0 8px 20px rgba(99, 102, 241, 0.3);
    }

    .submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(99, 102, 241, 0.4);
    }

    .submit-btn:active {
        transform: scale(0.98);
    }

    .submit-btn:disabled {
        background: #c7d2fe;
        cursor: not-allowed;
        box-shadow: none;
    }

    /* ===== ERROR BOX ===== */
    .error-box {
        background: #fef2f2;
        color: #dc2626;
        padding: 12px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
        border: 1px solid #fecaca;
    }

    .error-icon {
        width: 20px;
        height: 20px;
    }

    /* ===== FOOTER ===== */
    .login-footer {
        text-align: center;
        margin-top: 25px;
        font-size: 12px;
        color: #94a3b8;
    }

    /* ===== SPINNER ===== */
    .spinner {
        border: 3px solid rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        border-top: 3px solid white;
        width: 18px;
        height: 18px;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    /* ===================================== */
    /* 🔥🔥🔥 MOBILE PERFECT UI FIX 🔥🔥🔥 */
    /* ===================================== */
    @@media (max-width: 480px) {
        .login-wrapper {
            padding: 15px; 
            /* Gradient background mobile var pan disel aata */
        }

        .login-card {
            padding: 35px 20px;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1); /* Card la shadow asel */
        }

        .login-header h2 {
            font-size: 24px;
        }

        .login-header p {
            font-size: 13px;
        }

        .submit-btn {
            padding: 14px;
            font-size: 15px;
        }
    }
</style>

@code {
    private LoginRequestViewModel loginModel = new LoginRequestViewModel();
    private bool IsLoading = false;
    private string ErrorMessage = "";
    private string EmployeeName = string.Empty;
     protected override async Task OnInitializedAsync()
    {
        try
            {
                EmployeeName = await JS.InvokeAsync<string>("localStorage.getItem", "empName");
                if (!string.IsNullOrEmpty(EmployeeName))
                {
                  NavManager.NavigateTo("/attendance", true);
                }
                StateHasChanged();               
            }
            catch
            {
            }
    }

    
   private async Task HandleLogin()
    {
        IsLoading = true;
        ErrorMessage = "";

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponseViewModel>();

                await JS.InvokeVoidAsync("localStorage.setItem", "empId", result.EmployeeId.ToString());
                await JS.InvokeVoidAsync("localStorage.setItem", "empName", result.Name);
                await JS.InvokeVoidAsync("localStorage.setItem", "empDept", result.Department);
                await JS.InvokeVoidAsync("localStorage.setItem", "empMobile", result.MobileNo);
                await JS.InvokeVoidAsync("localStorage.setItem", "empBirthDay", result.BirthDay);

               
               NavManager.NavigateTo("/attendance", true);
            }
            else
            {
                ErrorMessage = "Invalid Username or Password! Please try again.";
            }
        }
        catch (Exception)
        {
            // Fallback for demo
            if (loginModel.Username == "admin" && loginModel.Password == "admin")
            {
                 await JS.InvokeVoidAsync("localStorage.setItem", "empId", "12");
                await JS.InvokeVoidAsync("localStorage.setItem", "empName", "Yuvaraj Jadhav");
                await JS.InvokeVoidAsync("localStorage.setItem", "empDept", "Development");
                await JS.InvokeVoidAsync("localStorage.setItem", "empMobile", "8793931564");
                   await JS.InvokeVoidAsync("localStorage.setItem", "empBirthDay", "02/04/2026");

                try 
                    {
                        // JavaScript मधील subscribe फंक्शन कॉल करणे
                        await JS.InvokeVoidAsync("window.pushNotifications.subscribe", 12,"Development");
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine("Push notification setup failed: " + ex.Message);
                    }
               NavManager.NavigateTo("/attendance", true);
            }
            else
            {
                ErrorMessage = "Wrong credentials kiva Server band ahe.";
            }
        }
        finally
        {
            IsLoading = false;
        }
    }
}