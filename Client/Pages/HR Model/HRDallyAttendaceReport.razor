@page "/hr_daily_attendance"
@using SMART_HRMS_SYSTEM.Shared.ViewModel
@using SMART_HRMS_SYSTEM.Shared.Models
@using OfficeOpenXml
@using System.IO;
@using System.Data;
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavManager

<div class="report-wrapper">
    <div class="report-container">

        <!-- Header -->
        <div class="report-header">
            <h2>Attendance Report</h2>
            <p>Track and manage employee attendance across all departments.</p>
        </div>

        @if (ReportType == "Daily")
        {
            <div class="stats-row mb-4">

                <div class="stat-card stat-total shadow-sm">
                    <div class="stat-icon"><i class="bi bi-people"></i></div>
                    <div class="stat-details">
                        <p class="stat-title">Total</p>
                        <h3 class="stat-count">@TotalEmployees</h3>
                    </div>
                </div>

                <div class="stat-card stat-present shadow-sm">
                    <div class="stat-icon"><i class="bi bi-check"></i></div>
                    <div class="stat-details">
                        <p class="stat-title">Present</p>
                        <h3 class="stat-count">@PresentCount</h3>
                    </div>
                </div>

                <div class="stat-card stat-late shadow-sm">
                    <div class="stat-icon"><i class="bi bi-clock"></i></div>
                    <div class="stat-details">
                        <p class="stat-title">Late</p>
                        <h3 class="stat-count">@LateCount</h3>
                    </div>
                </div>

                <div class="stat-card stat-absent shadow-sm">
                    <div class="stat-icon"><i class="bi bi-x"></i></div>
                    <div class="stat-details">
                        <p class="stat-title">Absent</p>
                        <h3 class="stat-count">@AbsentCount</h3>
                    </div>
                </div>

            </div>
        }

        <!-- Filter Card -->
        <div class="filter-card shadow-sm mb-4">
            <div class="filter-row">

                <!-- Report Type Selection (Daily / Monthly) -->
                <div class="filter-item">
                    <label class="filter-label">REPORT TYPE</label>
                    <div class="select-wrapper">
                        <select class="form-select custom-select" value="@ReportType" @onchange="OnReportTypeChanged">
                            <option value="Daily">Daily Report</option>
                            <option value="Monthly">Monthly Report</option>
                        </select>
                    </div>
                </div>

                <!-- DYNAMIC DATE OR MONTH PICKER -->
                <div class="filter-item">
                    <label class="filter-label">SELECT @(ReportType == "Daily" ? "DATE" : "MONTH")</label>
                    <div class="select-wrapper">
                        @if (ReportType == "Daily")
                        {
                            <input type="date" class="form-control custom-select"
                                   value="@SelectedDate.ToString("yyyy-MM-dd")" @onchange="OnDateChanged" />
                        }
                        else
                        {
                            <input type="month" class="form-control custom-select" value="@SelectedMonth"
                                   @onchange="OnMonthChanged" />
                        }
                    </div>
                </div>

                <!-- Department -->
                <div class="filter-item">
                    <label class="filter-label">DEPARTMENT</label>
                    <div class="select-wrapper">
                        <select class="form-select custom-select" value="@FilterDepartment"
                                @onchange="OnDepartmentChanged">
                            <option value="All">All Departments</option>
                            @foreach (var dept in GetDepartments())
                            {
                                <option value="@dept">@dept</option>
                            }
                        </select>
                    </div>
                </div>

                <!-- Status (Only for Daily Report) -->
                @if (ReportType == "Daily")
                {
                    <div class="filter-item">
                        <label class="filter-label">STATUS</label>
                        <div class="select-wrapper">
                            <select class="form-select custom-select" value="@FilterStatus" @onchange="OnStatusChanged">
                                <option value="All">All Statuses</option>
                                <option value="Present">Present</option>
                                <option value="Late">Late</option>
                                <option value="Absent">Absent</option>
                            </select>
                        </div>
                    </div>
                }

                <!-- Search -->
                <div class="filter-item">
                    <label class="filter-label">SEARCH</label>
                    <div class="search-box">
                        <i class="bi bi-search search-icon"></i>
                        <input class="form-control custom-select pl-search" placeholder="Search Name..."
                               style="width:70%" value="@SearchText" @oninput="OnSearchInput" />
                    </div>
                </div>

                <!-- Action Button -->
                <div class="filter-item btn-item">
                    <label class="filter-label d-none d-md-block">&nbsp;</label>
                    <button class="btn-search w-100" @onclick="Reset" disabled="@IsLoading">
                        @if (IsLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span> <span>Loading...</span>
                        }
                        else
                        {
                            <i class="bi bi-arrow-clockwise d-none d-md-inline me-2"></i> <span>Refresh</span>
                        }
                    </button>
                </div>

                @if (ReportType != "Daily")
                {
                    <div class="export-btn-wrapper">
                        <button class="btn-export" @onclick="ExportExcel" disabled="@IsExcelLoading">
                            @if (IsExcelLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span> <span>Loading...</span>
                            }
                            else
                            {
                                <i class="bi bi-file-earmark-excel me-2"></i> <span>Summary Report</span>
                            }
                        </button>
                    </div>
                }
                @if (ReportType != "Daily")
                {
                    <div class="export-btn-wrapper">
                        <button class="btn-export" @onclick="ExportDayWiseExcel" disabled="@IsExcelLoading">
                            @if (IsExcelLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span> <span>Loading...</span>
                            }
                            else
                            {
                                <i class="bi bi-file-earmark-excel me-2"></i> <span>Day Wise Report</span>
                            }
                        </button>
                    </div>
                }

            </div>
        </div>

        <div class="report-table-wrapper">
            @if (IsLoading)
            {
                <div class="empty-state shadow-sm">
                    <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;"></div>
                    <h5>Loading Data...</h5>
                    <p>Fetching attendance records.</p>
                </div>
            }
            else if (ReportType == "Monthly")
            {
                <!-- MONTHLY TABLE -->
                @if (!FilteredMonthlyList.Any())
                {
                    <div class="empty-state shadow-sm">
                        <div class="empty-icon placeholder-glow"><i class="bi bi-warning text-warning"></i></div>
                        <h5>No Monthly Records Found</h5>
                        <p>Try changing your filters.</p>
                    </div>
                }
                else
                {
                    <table class="table modern-table">
                        <thead>
                            <tr>
                                <th>Employee</th>
                                <th>Department</th>
                                <th>Present</th>
                                <th>Absent</th>
                                <th>Late</th>
                                <th>Paid Leave</th>
                                <th>WeekOff</th>
                                <th>Half Day</th>
                                <th>Early Depature</th>
                                <th>Report</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in FilteredMonthlyList)
                            {
                                <tr>
                                    <td data-label="Employee">
                                        <div class="employee-cell text-value">
                                            <div class="avatar">@GetInitials(r.EmployeeName)</div>
                                            <span class="fw-bold">@r.EmployeeName</span>
                                        </div>
                                    </td>
                                    <td data-label="Department"><span class="text-value text-muted fw-semibold">@r.Department</span>
                                    </td>
                                    <td data-label="Present"><span class="text-value text-success fw-bold">@r.Present</span></td>
                                    <td data-label="Absent"><span class="text-value text-danger fw-bold">@r.Absent</span></td>
                                    <td data-label="Late"><span class="text-value text-warning fw-bold">@r.LateMark</span></td>
                                    <td data-label="Paid Leave"><span class="text-value text-secondary fw-bold">@r.PaidLeave</span>
                                    </td>
                                    <td data-label="WeekOff"><span class="text-value text-secondary fw-bold">@r.WeekOff</span></td>
                                    <td data-label="Half Day"><span class="text-value text-info fw-bold">@r.HalfDay</span></td>
                                    <td data-label="Early Depature"><span
                                        class="text-value text-primary fw-bold">@r.EarlyDeparture</span></td>
                                        <td data-label="Report">
                                            <span class="text-value text-primary fw-bold">
                                                <button class="btn-export" @onclick="() => ExportVerticalExcel(r.EmployeeId)"
                                                        disabled="@IsExcelLoading">
                                                    @if (IsExcelLoading)
                                                    {
                                                        <span class="spinner-border spinner-border-sm me-2"></span> <span>Loading...</span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-file-earmark-excel me-2"></i> <span>Summary Report</span>
                                                    }
                                                </button>
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }
            else
                {
                    <!-- DAILY TABLE -->
                    @if (!FilteredRecords.Any())
                    {
                        <div class="empty-state shadow-sm">
                            <div class="empty-icon placeholder-glow"><i class="bi bi-warning text-warning"></i></div>
                            <h5>No Records Found</h5>
                            <p>Try changing your filters.</p>
                        </div>
                    }
                    else
                    {
                        <table class="table modern-table">
                            <thead>
                                <tr>
                                    <th>Employee</th>
                                    <th>Department</th>
                                    <th>Punch In</th>
                                    <th>Punch Out</th>
                                    <th>Total Hrs</th>
                                    <th>Mode</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in FilteredRecords)
                                {
                                    <tr>
                                        <td data-label="Employee">
                                            <div class="employee-cell text-value">
                                                <div class="avatar">@GetInitials(r.EmpName)</div>
                                                <span class="fw-bold">@r.EmpName</span>
                                            </div>
                                        </td>
                                        <td data-label="Department"><span class="text-value text-muted fw-semibold">@r.Department</span>
                                        </td>
                                        <td data-label="Punch In">
                                            <span class="text-value @(r.PunchInTime.HasValue ? "badge-in" : "text-blank")">
                                                @(r.PunchInTime?.ToString("hh:mm tt") ?? "-")
                                            </span>
                                        </td>
                                        <td data-label="Punch Out">
                                            <span class="text-value @(r.PunchOutTime.HasValue ? "badge-out" : "text-blank")">
                                                @(r.PunchOutTime?.ToString("hh:mm tt") ?? "-")
                                            </span>
                                        </td>
                                        <td data-label="Total Hrs"><span class="text-value text-hours">@r.TotalHours</span></td>
                                        <td data-label="Mode"><span class="text-value @GetModeClass(r.WorkMode)">@r.WorkMode</span></td>
                                        <td data-label="Status">
                                            <span class="text-value status-badge @GetStatusCss(r.Status)">
                                                @r.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }
            </div>
        </div>
    </div>

    <style>
        /* CSS अगदी आधीसारखेच आहे (डेस्कटॉप डिझाईन) */
        .report-wrapper {
