            padding: 30px 15px;
            font-family: 'Inter', 'Segoe UI', sans-serif;
        }

        .report-container {
            max-width: 1200px;
            margin: auto;
        }

        .report-header {
            text-align: left;
            margin-bottom: 25px;
        }

        .report-header h2 {
            font-weight: 800;
            font-size: 26px;
            color: #0f172a;
