        /* =========================================
       📱 MOBILE RESPONSIVE (Updated for List View)
    ========================================= */
        @@media (max-width: 768px) {
            .report-wrapper {
                padding: 15px 10px;
            }

            .filter-row {
                flex-wrap: wrap;
            }

            .filter-item {
                flex: 1 1 45%;
            }

