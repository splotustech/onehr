    private List<DayWiseModel> DayWiseList = new();

    private async Task LoadDayWise()
    {
        var year = SelectedMonth.Split('-')[0];
        var month = SelectedMonth.Split('-')[1];

        DayWiseList = await Http.GetFromJsonAsync<List<DayWiseModel>>(
            $"api/attendance/EmployeeMonthlyDayWiseReport?Year={year}&Month={month}"
        ) ?? new();
    }
    private async Task ExportDayWiseExcel()
    {
        try
        {
            IsExcelLoading = true;
            StateHasChanged();

            OfficeOpenXml.ExcelPackage.LicenseContext = OfficeOpenXml.LicenseContext.NonCommercial;

            await LoadDayWise();

            using (var package = new OfficeOpenXml.ExcelPackage())
            {
                var ws = package.Workbook.Worksheets.Add("Day Wise Report");

                int year = int.Parse(SelectedMonth.Split('-')[0]);
                int month = int.Parse(SelectedMonth.Split('-')[1]);
                int totalDays = DateTime.DaysInMonth(year, month);

                int row = 1;

                // =========================
                // ✅ TITLE
                // =========================
                ws.Cells[row, 1].Value = $"Attendance Report - {SelectedMonth}";
                ws.Cells[row, 1, row, totalDays + 1].Merge = true;
                ws.Cells[row, 1].Style.Font.Size = 16;
                ws.Cells[row, 1].Style.Font.Bold = true;
                ws.Cells[row, 1].Style.HorizontalAlignment = OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;

                row += 2;

                // =========================
                // ✅ HEADER
                // =========================
                ws.Cells[row, 1].Value = "Employee Name";

                for (int d = 1; d <= totalDays; d++)
                {
                    ws.Cells[row, d + 1].Value = d;
                }

                // Header Style
                using (var header = ws.Cells[row, 1, row, totalDays + 1])
                {
                    header.Style.Font.Bold = true;
                    header.Style.Font.Size = 12;
                    header.Style.HorizontalAlignment = OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;
                    header.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                    header.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.DarkBlue);
                    header.Style.Font.Color.SetColor(System.Drawing.Color.White);
                }

                // Freeze header
                ws.View.FreezePanes(row + 1, 2);

                row++;

                // =========================
                // ✅ DATA
                // =========================
                foreach (var emp in DayWiseList)
                {
                    ws.Cells[row, 1].Value = emp.EmployeeName;

                    for (int d = 0; d < emp.Days.Count; d++)
                    {
                        var cell = ws.Cells[row, d + 2];
                        var value = emp.Days[d];

                        cell.Value = value;

                        // 🎨 Color Coding
                        if (value == "P")
                        {
                            cell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                            cell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightGreen);
                        }
                        else if (value == "A")
                        {
                            cell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                            cell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightCoral);
                        }
                        else if (value == "L")
                        {
                            cell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                            cell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.Khaki);
                        }
                        // ── Full Day Paid Leaves ──────────────────────────
                        else if (value == "CL") // Casual Leave
                        {
                            cell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                            cell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.Orange);
                            cell.Style.Font.Color.SetColor(System.Drawing.Color.White);
                            cell.Style.Font.Bold = true;
                        }
                        else if (value == "SL") // Sick Leave
                        {
                            cell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                            cell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.HotPink);
                            cell.Style.Font.Color.SetColor(System.Drawing.Color.White);
                            cell.Style.Font.Bold = true;
                        }
                        else if (value == "PL") // Plan Leave
                        {
                            cell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                            cell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.MediumPurple);
                            cell.Style.Font.Color.SetColor(System.Drawing.Color.White);
                            cell.Style.Font.Bold = true;
                        }
                        // ── Half Day Paid Leaves ─────────────────────────
                        else if (value == "HCL") // Half Day Casual Leave
                        {
                            cell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                            cell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.SandyBrown);
                            cell.Style.Font.Color.SetColor(System.Drawing.Color.White);
                            cell.Style.Font.Bold = true;
                        }
                        else if (value == "HSL") // Half Day Sick Leave
                        {
                            cell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                            cell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightPink);
                            cell.Style.Font.Bold = true;
                        }
                        else if (value == "HPL") // Half Day Plan Leave
                        {
                            cell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                            cell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.Plum);
                            cell.Style.Font.Bold = true;
                        }
                        // ── Unpaid Half Day ───────────────────────────────
                        else if (value == "UH") // Unpaid Half Day
                        {
                            cell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                            cell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightSkyBlue);
                            cell.Style.Font.Bold = true;
                        }

                        cell.Style.HorizontalAlignment = OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;
                    }

                    row++;
                }

                int dataEndRow = row - 1;

                // =========================
                // ✅ COLUMN STYLE
                // =========================
                ws.Column(1).Width = 25;
