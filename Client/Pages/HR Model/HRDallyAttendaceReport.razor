                font-weight: 500;
                color: #64748b;
                min-width: 90px;
                text-transform: uppercase;
                font-size: 11px;
            }

            .text-value {
                text-align: right;
                word-wrap: break-word;
                white-space: normal;
                max-width: 65%;
            }

            .employee-cell {
                justify-content: flex-end;
            }
        }
    </style>

@code {
    private bool IsLoading = false;
    private bool IsExcelLoading = false;
    private string EmployeeName = "";

    // Report Type (Daily or Monthly)
    private string ReportType = "Daily";

    // Dates variables
    private DateTime SelectedDate = DateTime.Today;
    private string SelectedMonth = DateTime.Today.ToString("yyyy-MM");

    // Stats
    private int TotalEmployees, PresentCount, LateCount, AbsentCount;
    private Decimal MonthPresentCount, MonthLateCount, MonthAbsentCount, MonthPaidLeaveCount, MonthWeekOffCount,
MonthHalfDayCount, MonthEarlyOutCount;

    // Filters
    private string SearchText = "";
    private string FilterDepartment = "All";
    private string FilterStatus = "All";

    // Daily Data
    private List<HrAttendanceModel> AllRecords = new();
    private List<HrAttendanceModel> FilteredRecords = new();

    // Monthly Data
    private List<MonthlySummaryModel> MonthlyList = new();
    private List<MonthlySummaryModel> FilteredMonthlyList = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                EmployeeName = await JS.InvokeAsync<string>("localStorage.getItem", "empName");
                if (string.IsNullOrEmpty(EmployeeName)) NavManager.NavigateTo("/", true);
                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task LoadData()
    {
        IsLoading = true;
        try
        {
            await Task.Delay(300);

            if (ReportType == "Daily")
            {
                string url = $"api/attendance/AttendacereportByDate?ReportDate={SelectedDate:yyyy-MM-dd}";
                AllRecords = await Http.GetFromJsonAsync<List<HrAttendanceModel>>(url) ?? new();

                CalculateStats();
                ApplyFilters(); // Daily Filters Apply करणे
            }
            else
            {
                await LoadMonthlyList();

                // Monthly Stats
                TotalEmployees = MonthlyList.Count;
                MonthPresentCount = MonthlyList.Sum(x => x.Present);
                MonthLateCount = MonthlyList.Sum(x => x.LateMark);
                MonthAbsentCount = MonthlyList.Sum(x => x.Absent);

                ApplyFilters(); // Monthly डेटा लोड झाल्यावरही Filter Apply करणे गरजेचे आहे
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadMonthlyList()
    {
        var year = SelectedMonth.Split('-')[0];
        var month = SelectedMonth.Split('-')[1];

        MonthlyList = await Http.GetFromJsonAsync<List<MonthlySummaryModel>>(
            $"api/attendance/MonthlySummaryList?Year={year}&Month={month}"
        ) ?? new();
    }

    private void CalculateStats()
    {
        TotalEmployees = AllRecords.Count;
        PresentCount = AllRecords.Count(x => x.Status == "Present" || x.Status == "Late");
        LateCount = AllRecords.Count(x => x.Status == "Late");
        AbsentCount = AllRecords.Count(x => x.Status == "Absent");
    }

    // डायनॅमिक डिपार्टमेंट ड्रॉपडाऊन
    private IEnumerable<string> GetDepartments()
    {
        if (ReportType == "Daily")
            return AllRecords.Where(x => !string.IsNullOrEmpty(x.Department)).Select(x => x.Department).Distinct().OrderBy(x => x);
        else
            return MonthlyList.Where(x => !string.IsNullOrEmpty(x.Department)).Select(x => x.Department).Distinct().OrderBy(x => x);
    }

    private void Reset()
    {
        SearchText = "";
        FilterDepartment = "All";
        FilterStatus = "All";
        ApplyFilters();
    }

    private async Task OnReportTypeChanged(ChangeEventArgs e)
    {
        ReportType = e.Value?.ToString() ?? "Daily";
        SearchText = "";
        FilterDepartment = "All";
        FilterStatus = "All";
        await LoadData();
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var parsedDate))
        {
            SelectedDate = parsedDate;
            await LoadData();
        }
    }

    private async Task OnMonthChanged(ChangeEventArgs e)
    {
        SelectedMonth = e.Value?.ToString() ?? DateTime.Today.ToString("yyyy-MM");
        await LoadData();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        SearchText = e.Value?.ToString() ?? string.Empty;
        ApplyFilters();
    }

    private void OnDepartmentChanged(ChangeEventArgs e)
    {
        FilterDepartment = e.Value?.ToString() ?? "All";
        ApplyFilters();
    }

    private void OnStatusChanged(ChangeEventArgs e)
    {
        FilterStatus = e.Value?.ToString() ?? "All";
        ApplyFilters();
    }

    // अपडेटेड फिल्टर लॉजिक (Daily आणि Monthly दोन्हीसाठी)
    private async Task ApplyFilters()
    {
        if (ReportType == "Daily")
        {
            var q = AllRecords.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(SearchText))
                q = q.Where(x => !string.IsNullOrEmpty(x.EmpName) && x.EmpName.Contains(SearchText,
StringComparison.OrdinalIgnoreCase));

            if (FilterDepartment != "All")
                q = q.Where(x => x.Department == FilterDepartment);

            if (FilterStatus != "All")
                q = q.Where(x => x.Status == FilterStatus);

            FilteredRecords = q.ToList();
        }
        else // Monthly Report Filters
        {
            var q = MonthlyList.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(SearchText))
                q = q.Where(x => !string.IsNullOrEmpty(x.EmployeeName) && x.EmployeeName.Contains(SearchText,
StringComparison.OrdinalIgnoreCase));

            if (FilterDepartment != "All")
                q = q.Where(x => x.Department == FilterDepartment);

            FilteredMonthlyList = q.ToList();
        }
        TotalEmployees = FilteredRecords.Count;
        PresentCount = FilteredRecords.Count(x => x.Status == "Present" || x.Status == "Late");
        LateCount = FilteredRecords.Count(x => x.Status == "Late");
        AbsentCount = FilteredRecords.Count(x => x.Status == "Absent");
        StateHasChanged();
    }

    // Dynamic Classes
    private string GetModeClass(string mode) => mode == "-" ? "text-blank" : "badge-mode";
    private string GetStatusCss(string status) => status switch
    {
        "Present" => "bg-present",
        "Late" => "bg-late",
        "Absent" => "bg-absent",
        _ => "bg-secondary"
    };
    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1 ? parts[0].Substring(0, 1).ToUpper() : (parts[0].Substring(0, 1) + parts[1].Substring(0,
1)).ToUpper();
    }

    private async Task ExportExcel()
    {
        try
        {
            IsExcelLoading = true;
            StateHasChanged();

            var data = MonthlyList;

            OfficeOpenXml.ExcelPackage.LicenseContext = OfficeOpenXml.LicenseContext.NonCommercial;

            using (var package = new OfficeOpenXml.ExcelPackage())
            {
                var ws = package.Workbook.Worksheets.Add("Monthly Report");

                int row = 1;

                // =========================
                // ✅ TITLE
                // =========================
                ws.Cells[row, 1].Value = $"Monthly Attendance Report - {SelectedMonth}";
                ws.Cells[row, 1, row, 10].Merge = true;
                ws.Cells[row, 1].Style.Font.Size = 16;
                ws.Cells[row, 1].Style.Font.Bold = true;
                ws.Cells[row, 1].Style.HorizontalAlignment = OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;

                row += 2;

                // =========================
                // ✅ HEADER
                // =========================
                ws.Cells[row, 1].Value = "Month";
                ws.Cells[row, 2].Value = "Employee Name";
                ws.Cells[row, 3].Value = "Present";
                ws.Cells[row, 4].Value = "Absent";
                ws.Cells[row, 5].Value = "Late Mark";
                ws.Cells[row, 6].Value = "Paid Leave";
                ws.Cells[row, 7].Value = "Week Off";
                ws.Cells[row, 8].Value = "Half Day";
                ws.Cells[row, 9].Value = "Early Departure";
                ws.Cells[row, 10].Value = "Attendance %";

                using (var header = ws.Cells[row, 1, row, 10])
                {
                    header.Style.Font.Bold = true;
                    header.Style.HorizontalAlignment = OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;
                    header.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                    header.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.DarkBlue);
                    header.Style.Font.Color.SetColor(System.Drawing.Color.White);
                }

                // Freeze header
                ws.View.FreezePanes(row + 1, 1);

                row++;

                // =========================
                // ✅ DATA
                // =========================
                foreach (var item in data)
                {
                    ws.Cells[row, 1].Value = SelectedMonth;
                    ws.Cells[row, 2].Value = item.EmployeeName;
                    ws.Cells[row, 3].Value = item.Present;
                    ws.Cells[row, 4].Value = item.Absent;
                    ws.Cells[row, 5].Value = item.LateMark;
                    ws.Cells[row, 6].Value = item.PaidLeave;
                    ws.Cells[row, 7].Value = item.WeekOff;
                    ws.Cells[row, 8].Value = item.HalfDay;
                    ws.Cells[row, 9].Value = item.EarlyDeparture;

                    // ✅ Attendance %
                    decimal total = item.Present + item.Absent + item.PaidLeave + item.WeekOff;
                    decimal percent = total > 0 ? (item.Present / total) : 0;

                    ws.Cells[row, 10].Value = percent;
                    ws.Cells[row, 10].Style.Numberformat.Format = "0.00%";

                    // Center align
                    ws.Cells[row, 3, row, 10].Style.HorizontalAlignment =
                        OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;

                    // 🎨 Color Coding
                    ws.Cells[row, 3].Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                    ws.Cells[row, 3].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightGreen);

                    ws.Cells[row, 4].Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                    ws.Cells[row, 4].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightCoral);

                    ws.Cells[row, 5].Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                    ws.Cells[row, 5].Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.Khaki);

                    row++;
                }

                int dataEndRow = row - 1;

                // =========================
                // ✅ BORDERS
                // =========================
                var table = ws.Cells[3, 1, dataEndRow, 10];

                table.Style.Border.Top.Style = OfficeOpenXml.Style.ExcelBorderStyle.Thin;
                table.Style.Border.Bottom.Style = OfficeOpenXml.Style.ExcelBorderStyle.Thin;
                table.Style.Border.Left.Style = OfficeOpenXml.Style.ExcelBorderStyle.Thin;
                table.Style.Border.Right.Style = OfficeOpenXml.Style.ExcelBorderStyle.Thin;

                // =========================
                // ✅ FILTER
                // =========================
                ws.Cells[3, 1, dataEndRow, 10].AutoFilter = true;

                // =========================
                // ✅ AUTO FIT
                // =========================
                ws.Cells.AutoFitColumns();

                // =========================
                // ✅ DOWNLOAD
                // =========================
                var bytes = package.GetAsByteArray();
                var base64 = Convert.ToBase64String(bytes);

                await JS.InvokeVoidAsync("downloadFile",
                    $"MonthlyReport_{SelectedMonth}.xlsx",
                    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                    base64);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Excel Error: {ex.Message}");
        }
        finally
        {
            IsExcelLoading = false;
            StateHasChanged();
        }
    }

