            align-items: center;
            border: none;
            flex: 1;
            min-width: 150px;
        }

        .stat-icon {
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            font-size: 20px;
            flex-shrink: 0;
        }

        .stat-total .stat-icon {
            background: #eff6ff;
            color: #4f46e5;
        }

        .stat-present .stat-icon {
            background: #dcfce7;
            color: #16a34a;
        }

        .stat-late .stat-icon {
            background: #fef3c7;
            color: #d97706;
        }

        .stat-absent .stat-icon {
            background: #fee2e2;
            color: #dc2626;
        }

        .stat-title {
            font-size: 11px;
            color: #64748b;
            font-weight: 700;
            text-transform: uppercase;
            margin: 0 0 2px 0;
        }

        .stat-count {
            font-size: 24px;
            font-weight: 800;
            color: #0f172a;
            margin: 0;
            line-height: 1.2;
        }

        .filter-card {
            background: #ffffff;
            border-radius: 16px;
            padding: 20px;
            border: none;
        }

        .filter-row {
            display: flex;
            gap: 15px;
            align-items: flex-end;
