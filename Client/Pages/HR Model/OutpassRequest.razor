@code {
    private bool IsLoading = false;
    private bool IsProcessing = false;

    // Filters
    private string FilterType = "Daily"; // Daily or Monthly
    private DateTime SelectedDate = DateTime.Today;
    private int SelectedMonth = DateTime.Today.Month;
    private int SelectedYear = DateTime.Today.Year;
    private string FilterStatus = "All";
    private string SearchText = "";

    // Stats
    private int TotalRequests, PendingCount, ApprovedCount, RejectedCount;

    // Data - Explicitly initialized with new List<T>()
    private List<InOutPassViewModel> AllRecords = new List<InOutPassViewModel>();
    private List<InOutPassViewModel> FilteredRecords = new List<InOutPassViewModel>();

    // Modal Variables
    private bool ShowApproveModal = false;
    private bool ShowRejectModal = false;
    private InOutPassViewModel SelectedRequest = null;
    private string RejectReason = "";

    // Toast
    private string ToastMessage = "";
    private string ToastCssClass = "";
    private string EmployeeName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadRequests();
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                EmployeeName = await JS.InvokeAsync<string>("localStorage.getItem", "empName");
                if (string.IsNullOrEmpty(EmployeeName))
                {
                    NavManager.NavigateTo("/", true);
                }
                StateHasChanged();
            }
            catch
            {
            }
        }
    }
    private async Task LoadRequests()
    {
        IsLoading = true;
        try
        {
            // Build the URL based on the View Type (Daily or Monthly)
            string url = $"api/InOutPass/GetPassRequests?filterType={FilterType}";

            if (FilterType == "Daily")
            {
                url += $"&date={SelectedDate:yyyy-MM-dd}";
            }
            else
            {
                url += $"&month={SelectedMonth}&year={SelectedYear}";
            }

            // Fetch actual data from the database
            var response = await Http.GetFromJsonAsync<List<InOutPassViewModel>>(url);

            if (response != null)
            {
                AllRecords = response;
            }
            else
            {
                AllRecords = new List<InOutPassViewModel>();
            }

            // Apply local text-search and status filters
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            ShowToast("Failed to load data from server", "toast-error");
            AllRecords = new List<InOutPassViewModel>();
            FilteredRecords = new List<InOutPassViewModel>();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ApplyFilters()
    {
        var q = AllRecords.AsEnumerable();

        // Local Status Filter
        if (FilterStatus != "All")
            q = q.Where(x => x.Status == FilterStatus);

        // Local Search Filter
        if (!string.IsNullOrWhiteSpace(SearchText))
            q = q.Where(x => !string.IsNullOrEmpty(x.EmpName) && x.EmpName.Contains(SearchText, StringComparison.OrdinalIgnoreCase));

        FilteredRecords = q.ToList();

        // Calculate Stats based on currently fetched records
        TotalRequests = FilteredRecords.Count();
        PendingCount = FilteredRecords.Count(x => x.Status == "Pending");
        ApprovedCount = FilteredRecords.Count(x => x.Status == "Approved");
        RejectedCount = FilteredRecords.Count(x => x.Status == "Rejected");
        StateHasChanged(); // UI रिफ्रेश करण्यासाठी
    }



    private void ResetFilters()
    {
        SearchText = "";
        FilterStatus = "All";
        FilterType = "Daily";
        SelectedDate = DateTime.Today;
        ApplyFilters();
    }

    // Input Handlers
    private void OnSearchInput(ChangeEventArgs e)
    {
        SearchText = e.Value?.ToString() ?? string.Empty;
        ApplyFilters();
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var parsedDate))
        {
            SelectedDate = parsedDate;
            await LoadRequests();
        }
    }

    // Modals
    private void PromptApprove(InOutPassViewModel req)
    {
        SelectedRequest = req;
        ShowApproveModal = true;
    }

    private void PromptReject(InOutPassViewModel req)
    {
        SelectedRequest = req;
        RejectReason = "";
        ShowRejectModal = true;
    }

    private void CloseModals()
    {
        ShowApproveModal = false;
        ShowRejectModal = false;
        SelectedRequest = null;
    }

    private void AlertReason(string comment)
    {
        JS.InvokeVoidAsync("alert", $"Rejection Reason: \n\n{comment}");
    }

    // Actions
    private async Task ConfirmApprove()
    {
        IsProcessing = true;
        try
        {
            // IMPORTANT: Call your API
            await Http.PutAsJsonAsync($"api/InOutPass/Approve/{SelectedRequest.Id}", new object());

            await Task.Delay(800); // Simulate API

            var item = AllRecords.FirstOrDefault(x => x.Id == SelectedRequest.Id);
            if (item != null) item.Status = "Approved";
            // =========================================================
            // 🔥 NEW: Outpass Approved झाल्यावर लगेच Notification API ला कॉल करा
            // =========================================================
            try
            {
                string title = "Outpass Request Approved";
                string body = $"{SelectedRequest.EmpName}, your Outpass has been approved.";
                string link = "/attendance";

                var notification = new NotificationRequest
                {
                    EmpId = Convert.ToInt32(SelectedRequest.Empid),
                    EmployeeName = SelectedRequest.EmpName,
                    Title = title,
                    Body = body,
                    Link = link
                };

                await Http.PostAsJsonAsync("api/Notifications/sendEmployeeNotification", notification);
            }
            catch (Exception ex)
            {
                Console.WriteLine("Notification send failed: " + ex.Message);
            }
            ShowToast("Request Approved Successfully!", "toast-success");
            CloseModals();
            ResetFilters();
            await LoadRequests();
        }
        catch
        {
            ShowToast("Error approving request.", "toast-error");
        }
        IsProcessing = false;
    }

    private async Task ConfirmReject()
    {
        if (string.IsNullOrWhiteSpace(RejectReason))
        {
            ShowToast("Rejection reason is required.", "toast-error");
            return;
        }

        IsProcessing = true;
        try
        {
            // IMPORTANT: Call your API passing the reason
            await Http.PutAsJsonAsync($"api/InOutPass/Reject/{SelectedRequest.Id}", new { Comment = RejectReason });

            await Task.Delay(800); // Simulate API

            var item = AllRecords.FirstOrDefault(x => x.Id == SelectedRequest.Id);
            if (item != null)
            {
                item.Status = "Rejected";
                item.Comment = RejectReason;
            }
            // =========================================================
            // 🔥 NEW: Outpass Rejected झाल्यावर लगेच Notification API ला कॉल करा
            // =========================================================
            try
            {
                string title = "Outpass Request Rejected ❌";
                string body = $"{SelectedRequest.EmpName}, your Outpass request has been rejected.";
                string link = "/attendance";

                var notification = new NotificationRequest
                {
                    EmpId = Convert.ToInt32(SelectedRequest.Empid),
                    EmployeeName = SelectedRequest.EmpName,
                    Title = title,
                    Body = body,
                    Link = link
                };

                await Http.PostAsJsonAsync("api/Notifications/sendEmployeeNotification", notification);
            }
            catch (Exception ex)
            {
                Console.WriteLine("Notification send failed: " + ex.Message);
            }
            ShowToast("Request Rejected.", "toast-success");
            CloseModals();
            ResetFilters();
            await LoadRequests();
        }
        catch
        {
            ShowToast("Error rejecting request.", "toast-error");
        }
        IsProcessing = false;
    }

    // Helpers
    private async void ShowToast(string msg, string css)
    {
        ToastMessage = msg;
        ToastCssClass = css;
        StateHasChanged();
        await Task.Delay(3000);
        ToastMessage = "";
        StateHasChanged();
    }

    private string GetStatusCss(string status) => status switch
    {
        "Approved" => "bg-present",
        "Pending" => "bg-late",
        "Rejected" => "bg-absent",
        _ => "bg-secondary"
    };

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return (parts[0].Substring(0, 1) + parts[1].Substring(0, 1)).ToUpper();
    }
