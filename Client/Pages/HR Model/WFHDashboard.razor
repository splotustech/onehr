@code {
    private List<WFHMonitoringListItem> AllList = new();
    private List<WFHMonitoringListItem> FilteredList = new();
    private List<WFHMonitoringListItem> PagedList = new();
    private WFHDashboardStats? Stats;
    private WFHEmployeeDetail? SelectedDetail;

    private bool IsLoading = false;
    private bool ShowDetailModal = false;
    private string ActiveTab = "timeline";
    private string AlertMessage = "";
    private string AlertClass = "alert-info";
    private string LastRefreshTime = "-";

    // Filters
    private DateTime FromDate = DateTime.Today;
    private DateTime ToDate = DateTime.Today;
    private string FilterStatus = "";
    private string SearchText = "";

    // Sorting
    private string SortColumn = "";
    private bool SortAscending = true;

    // Pagination
    private int CurrentPage = 1;
    private int PageSize = 25;
    private int TotalPages => FilteredList.Count == 0 ? 1 : (int)Math.Ceiling((double)FilteredList.Count / PageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadAll();
    }

    private async Task LoadAll()
    {
        IsLoading = true;
        try
        {
            var dashTask = Http.GetFromJsonAsync<WFHDashboardStats>($"api/wfh/dashboard?date={DateTime.Today:yyyy-MM-dd}");
            var listTask = Http.GetFromJsonAsync<List<WFHMonitoringListItem>>(
                $"api/wfh/list?fromDate={FromDate:yyyy-MM-dd}&toDate={ToDate:yyyy-MM-dd}");

            await Task.WhenAll(dashTask, listTask);

            Stats   = dashTask.Result;
            AllList = listTask.Result ?? new();
            LastRefreshTime = DateTime.Now.ToString("hh:mm:ss tt");
            ApplyFilter();
        }
        catch (Exception ex)
        {
            AlertMessage = "Error loading data: " + ex.Message;
            AlertClass = "alert-danger";
        }
        finally { IsLoading = false; }
    }

    private void ApplyFilter()
    {
        var q = AllList.AsEnumerable();

        if (!string.IsNullOrEmpty(FilterStatus))
            q = q.Where(x => x.CurrentStatus == FilterStatus);

        if (!string.IsNullOrWhiteSpace(SearchText))
        {
            var s = SearchText.Trim().ToLower();
            q = q.Where(x =>
                (x.EmployeeName ?? "").ToLower().Contains(s) ||
                (x.EmployeeCode ?? "").ToLower().Contains(s) ||
                (x.Department   ?? "").ToLower().Contains(s));
        }

        // Sort
        if (!string.IsNullOrEmpty(SortColumn))
        {
            q = SortColumn switch
            {
                nameof(WFHMonitoringListItem.EmployeeCode)   => SortAscending ? q.OrderBy(x => x.EmployeeCode)   : q.OrderByDescending(x => x.EmployeeCode),
                nameof(WFHMonitoringListItem.EmployeeName)   => SortAscending ? q.OrderBy(x => x.EmployeeName)   : q.OrderByDescending(x => x.EmployeeName),
                nameof(WFHMonitoringListItem.CurrentStatus)  => SortAscending ? q.OrderBy(x => x.CurrentStatus)  : q.OrderByDescending(x => x.CurrentStatus),
                nameof(WFHMonitoringListItem.CurrentDistance)=> SortAscending ? q.OrderBy(x => x.CurrentDistance): q.OrderByDescending(x => x.CurrentDistance),
                _ => q
            };
        }

        FilteredList = q.ToList();
        CurrentPage = 1;
        UpdatePage();
    }

    private void ResetFilter()
    {
        FromDate = DateTime.Today;
        ToDate = DateTime.Today;
        FilterStatus = "";
        SearchText = "";
        SortColumn = "";
        SortAscending = true;
        ApplyFilter();
    }

    private void OnSearchChanged(ChangeEventArgs e) { SearchText = e.Value?.ToString() ?? ""; }

    private void UpdatePage()
    {
        PagedList = FilteredList
            .Skip((CurrentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();
    }

    private void SortBy(string column)
    {
        if (SortColumn == column) SortAscending = !SortAscending;
        else { SortColumn = column; SortAscending = true; }
        ApplyFilter();
    }

    private string SortIcon(string column)
    {
        if (SortColumn != column) return "";
        return SortAscending ? " ▲" : " ▼";
    }

    private void PrevPage() { if (CurrentPage > 1) { CurrentPage--; UpdatePage(); } }
    private void NextPage() { if (CurrentPage < TotalPages) { CurrentPage++; UpdatePage(); } }
    private void GoToPage(int p) { CurrentPage = p; UpdatePage(); }
    private void OnPageSizeChanged() { CurrentPage = 1; UpdatePage(); }

    private async Task OpenDetail(WFHMonitoringListItem row)
    {
        try
        {
            SelectedDetail = await Http.GetFromJsonAsync<WFHEmployeeDetail>(
                $"api/wfh/details/{row.EmployeeId}?date={row.AttendanceDate:yyyy-MM-dd}");
            ActiveTab = "timeline";
            ShowDetailModal = true;
        }
        catch (Exception ex)
        {
            AlertMessage = "Error loading details: " + ex.Message;
            AlertClass = "alert-danger";
        }
    }

    private void CloseDetail() { ShowDetailModal = false; SelectedDetail = null; }

    private string GetRowClass(string? status) =>
        status == "Outside" ? "row-outside" : "";

    private string GetStatusBadge(string? status) => status switch
    {
        "Inside"      => "badge-inside",
        "Outside"     => "badge-outside",
        "Returned"    => "badge-returned",
        _             => "badge-default"
    };

    private string GetTrackingPillClass(string? ts) => ts switch
    {
        "Active"       => "tracking-active",
        "Signal Lost"  => "tracking-signal-lost",
        _              => "tracking-off"
    };

    private string GetMapUrl()
    {
        if (SelectedDetail?.CurrentLat == null) return "";
        double lat = SelectedDetail.CurrentLat.Value;
        double lon = SelectedDetail.CurrentLong ?? 0;
        double span = 0.002; // ~200m view
        return $"https://www.openstreetmap.org/export/embed.html?" +
               $"bbox={lon - span},{lat - span},{lon + span},{lat + span}" +
               $"&layer=mapnik&marker={lat},{lon}";
    }

    private async Task ExportCSV()
    {
        try
        {
            var url = $"api/wfh/exportExcel?fromDate={FromDate:yyyy-MM-dd}&toDate={ToDate:yyyy-MM-dd}";
            var bytes = await Http.GetByteArrayAsync(url);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFile", $"WFH_Tracking_{FromDate:yyyyMMdd}.csv", "text/csv", base64);
            AlertMessage = "Export downloaded successfully.";
            AlertClass = "alert-success";
        }
        catch (Exception ex)
        {
            AlertMessage = "Export failed: " + ex.Message;
            AlertClass = "alert-danger";
        }
    }
}
