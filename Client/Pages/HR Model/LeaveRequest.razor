    // ── MONTHLY LEAVE REPORT EXCEL ─────────────────────────────────────
    private async Task ExportMonthlyLeaveReport()
    {
        try
        {
            IsExcelLoading = true;
            StateHasChanged();

            OfficeOpenXml.ExcelPackage.LicenseContext = OfficeOpenXml.LicenseContext.NonCommercial;

            // Use ALL records for the month (not just status-filtered view)
            var data = AllRecords;

            // Group by employee
            var empGroups = data
                .GroupBy(r => r.EmpName?.Trim())
                .OrderBy(g => g.Key)
                .ToList();

            using var package = new OfficeOpenXml.ExcelPackage();
            var ws = package.Workbook.Worksheets.Add("Monthly Leave Report");

            var monthName = System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(SelectedMonth);
            int row = 1;

            // ── TITLE ──────────────────────────────────────────────────
            ws.Cells[row, 1].Value = $"Monthly Leave Report — {monthName} {SelectedYear}";
            ws.Cells[row, 1, row, 14].Merge = true;
            ws.Cells[row, 1].Style.Font.Size = 15;
            ws.Cells[row, 1].Style.Font.Bold = true;
            ws.Cells[row, 1].Style.HorizontalAlignment = OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;
            using (var tr = ws.Cells[row, 1, row, 14])
            {
                tr.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                tr.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.FromArgb(30, 58, 95));
                tr.Style.Font.Color.SetColor(System.Drawing.Color.White);
            }
            row += 2;

            // ── HEADERS ────────────────────────────────────────────────
            var headers = new[]
            {
                "Employee Name",
                "Paid Casual",
                "Paid Sick",
                "Paid Plan",
                "UnPaid Casual",
                "UnPaid Sick",
                "UnPaid Plan",
                "Half Day Paid",
                "Half Day UnPaid",
                "Early Out",
                "Work From Home",
                "Client Meeting",
                "Total Requests",
                "Status"
            };

            for (int c = 0; c < headers.Length; c++)
                ws.Cells[row, c + 1].Value = headers[c];

            using (var hdr = ws.Cells[row, 1, row, headers.Length])
            {
                hdr.Style.Font.Bold = true;
                hdr.Style.Font.Size = 11;
                hdr.Style.HorizontalAlignment = OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;
                hdr.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                hdr.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.FromArgb(14, 165, 233));
                hdr.Style.Font.Color.SetColor(System.Drawing.Color.White);
            }
            ws.View.FreezePanes(row + 1, 2);
            // Status color col is now 14
            int statusCol = 14;
            row++;

            // ── DATA ROWS ──────────────────────────────────────────────
            bool altRow = false;
            foreach (var grp in empGroups)
            {
                var leaves = grp.ToList();

                // Case-insensitive, trimmed matching so DB variations don't break counts
                bool IsType(LeaveRequestModel x, string t) =>
                    string.Equals(x.RequestType?.Trim(), t, StringComparison.OrdinalIgnoreCase);
                bool IsLeaveType(LeaveRequestModel x, string t) =>
                    string.Equals(x.LeaveType?.Trim(), t, StringComparison.OrdinalIgnoreCase);
                bool IsCat(LeaveRequestModel x, string c) =>
                    string.Equals(x.LeaveCategory?.Trim(), c, StringComparison.OrdinalIgnoreCase);

                int paidCasual    = leaves.Count(x => IsType(x, "Full Day Leave") && IsLeaveType(x, "Paid")   && IsCat(x, "Casual"));
                int paidSick      = leaves.Count(x => IsType(x, "Full Day Leave") && IsLeaveType(x, "Paid")   && IsCat(x, "Sick"));
                int paidPlan      = leaves.Count(x => IsType(x, "Full Day Leave") && IsLeaveType(x, "Paid")   && IsCat(x, "Plan"));
                int unpaidCasual  = leaves.Count(x => IsType(x, "Full Day Leave") && IsLeaveType(x, "UnPaid") && IsCat(x, "Casual"));
                int unpaidSick    = leaves.Count(x => IsType(x, "Full Day Leave") && IsLeaveType(x, "UnPaid") && IsCat(x, "Sick"));
                int unpaidPlan    = leaves.Count(x => IsType(x, "Full Day Leave") && IsLeaveType(x, "UnPaid") && IsCat(x, "Plan"));
                int halfPaid      = leaves.Count(x => (IsType(x, "First Half Day") || IsType(x, "Second Half Day")) && IsLeaveType(x, "Paid"));
                int halfUnpaid    = leaves.Count(x => (IsType(x, "First Half Day") || IsType(x, "Second Half Day")) && IsLeaveType(x, "UnPaid"));
                int earlyOut      = leaves.Count(x => IsType(x, "Early Out"));
                int wfh           = leaves.Count(x => IsType(x, "Work From Home"));
                int clientMeeting = leaves.Count(x => IsType(x, "Client Meeting"));
                int total         = paidCasual + paidSick + paidPlan + unpaidCasual + unpaidSick + unpaidPlan
                                  + halfPaid + halfUnpaid + earlyOut + wfh + clientMeeting;

                // Dominant status
                string status = leaves.Any(x => x.Status == "Approved") ? "Approved"
                              : leaves.Any(x => x.Status == "Pending")  ? "Pending"
                              : "Rejected";

                ws.Cells[row, 1].Value  = grp.Key;
                ws.Cells[row, 2].Value  = paidCasual    > 0 ? paidCasual    : (object)"-";
                ws.Cells[row, 3].Value  = paidSick      > 0 ? paidSick      : (object)"-";
                ws.Cells[row, 4].Value  = paidPlan      > 0 ? paidPlan      : (object)"-";
                ws.Cells[row, 5].Value  = unpaidCasual  > 0 ? unpaidCasual  : (object)"-";
                ws.Cells[row, 6].Value  = unpaidSick    > 0 ? unpaidSick    : (object)"-";
                ws.Cells[row, 7].Value  = unpaidPlan    > 0 ? unpaidPlan    : (object)"-";
                ws.Cells[row, 8].Value  = halfPaid      > 0 ? halfPaid      : (object)"-";
                ws.Cells[row, 9].Value  = halfUnpaid    > 0 ? halfUnpaid    : (object)"-";
                ws.Cells[row, 10].Value = earlyOut      > 0 ? earlyOut      : (object)"-";
                ws.Cells[row, 11].Value = wfh           > 0 ? wfh           : (object)"-";
                ws.Cells[row, 12].Value = clientMeeting > 0 ? clientMeeting : (object)"-";
                ws.Cells[row, 13].Value = total;
                ws.Cells[row, 14].Value = status;

                // Center numeric cols
                ws.Cells[row, 2, row, 14].Style.HorizontalAlignment = OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;

                // Alternating row color
                if (altRow)
                {
                    using var altRange = ws.Cells[row, 1, row, headers.Length];
                    altRange.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                    altRange.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.FromArgb(248, 250, 252));
                }

                // Status color in last col
                var statusCell = ws.Cells[row, statusCol];
                if (status == "Approved")
                {
                    statusCell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                    statusCell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightGreen);
                }
                else if (status == "Pending")
                {
                    statusCell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                    statusCell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.Khaki);
                }
                else
                {
                    statusCell.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                    statusCell.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.LightCoral);
                }

                altRow = !altRow;
                row++;
            }

            int dataEnd = row - 1;

            // ── TOTALS ROW ─────────────────────────────────────────────
            ws.Cells[row, 1].Value = "TOTAL";
            ws.Cells[row, 1].Style.Font.Bold = true;
            for (int c = 2; c <= 13; c++)
            {
                ws.Cells[row, c].Formula = $"SUM({ws.Cells[4, c].Address}:{ws.Cells[dataEnd, c].Address})";
                ws.Cells[row, c].Style.Font.Bold = true;
                ws.Cells[row, c].Style.HorizontalAlignment = OfficeOpenXml.Style.ExcelHorizontalAlignment.Center;
            }
            using (var totRange = ws.Cells[row, 1, row, headers.Length])
            {
                totRange.Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                totRange.Style.Fill.BackgroundColor.SetColor(System.Drawing.Color.FromArgb(220, 235, 255));
                totRange.Style.Font.Bold = true;
            }
            row++;

            // ── BORDERS ────────────────────────────────────────────────
            var tableRange = ws.Cells[3, 1, row - 1, headers.Length];
            tableRange.Style.Border.Top.Style    = OfficeOpenXml.Style.ExcelBorderStyle.Thin;
            tableRange.Style.Border.Bottom.Style = OfficeOpenXml.Style.ExcelBorderStyle.Thin;
            tableRange.Style.Border.Left.Style   = OfficeOpenXml.Style.ExcelBorderStyle.Thin;
            tableRange.Style.Border.Right.Style  = OfficeOpenXml.Style.ExcelBorderStyle.Thin;

            // ── LEGEND ─────────────────────────────────────────────────
            int leg = row + 1;
            ws.Cells[leg, 1].Value = "Legend:";
            ws.Cells[leg, 1].Style.Font.Bold = true;
            var legend = new[] {
                ("Paid Casual",   System.Drawing.Color.LightBlue),
                ("Paid Sick",     System.Drawing.Color.LightYellow),
                ("Paid Plan",     System.Drawing.Color.Plum),
                ("UnPaid Casual", System.Drawing.Color.LightCoral),
                ("- = Zero",      System.Drawing.Color.WhiteSmoke)
            };
            for (int i = 0; i < legend.Length; i++)
            {
                ws.Cells[leg + 1 + i, 1].Value = legend[i].Item1;
                ws.Cells[leg + 1 + i, 2].Style.Fill.PatternType = OfficeOpenXml.Style.ExcelFillStyle.Solid;
                ws.Cells[leg + 1 + i, 2].Style.Fill.BackgroundColor.SetColor(legend[i].Item2);
            }

            // ── COLUMN WIDTHS ──────────────────────────────────────────
            ws.Column(1).Width = 28;
            for (int c = 2; c <= headers.Length; c++)
                ws.Column(c).Width = 15;

            // ── AUTO FILTER ────────────────────────────────────────────
            ws.Cells[3, 1, dataEnd, headers.Length].AutoFilter = true;

            // ── DOWNLOAD ───────────────────────────────────────────────
            var bytes  = package.GetAsByteArray();
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFile",
                $"LeaveReport_{monthName}_{SelectedYear}.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                base64);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Excel Error: {ex.Message}");
        }
        finally
        {
            IsExcelLoading = false;
            StateHasChanged();
        }
    }
}