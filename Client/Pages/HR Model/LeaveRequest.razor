@page "/leave-request"
@using SMART_HRMS_SYSTEM.Shared.ViewModel
@using SMART_HRMS_SYSTEM.Shared.Models
@using OfficeOpenXml
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavManager

<div class="report-wrapper">
    <div class="report-container">

        <!-- Header -->
        <div class="report-header">
            <div class="d-flex align-items-center gap-3">
                <div>
                    <h2>Leave Approval Management</h2>
                    <p>Manage Full Day, Half Day, and Early Out requests from employees.</p>
                </div>
            </div>
        </div>

        <!-- Stats Row -->
        <div class="stats-row mb-4">
            <div class="stat-card stat-total shadow-sm">
                <div class="stat-icon"><i class="bi bi-files"></i></div>
                <div class="stat-details">
                    <p class="stat-title">Total Requests</p>
                    <h3 class="stat-count">@TotalRequests</h3>
                </div>
            </div>

            <div class="stat-card stat-pending shadow-sm">
                <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-details">
                    <p class="stat-title">Pending</p>
                    <h3 class="stat-count text-warning">@PendingCount</h3>
                </div>
            </div>

            <div class="stat-card stat-approved shadow-sm">
                <div class="stat-icon"><i class="bi bi-check-all"></i></div>
                <div class="stat-details">
                    <p class="stat-title">Approved</p>
                    <h3 class="stat-count text-success">@ApprovedCount</h3>
                </div>
            </div>

            <div class="stat-card stat-rejected shadow-sm">
                <div class="stat-icon"><i class="bi bi-trash3"></i></div>
                <div class="stat-details">
                    <p class="stat-title">Rejected</p>
                    <h3 class="stat-count text-danger">@RejectedCount</h3>
                </div>
            </div>
        </div>

        <!-- Filter Card -->
        <div class="filter-card shadow-sm mb-4">
            <div class="filter-row">
                <div class="filter-item">
                    <label class="filter-label">VIEW TYPE</label>
                    <select class="form-select custom-select" @bind="FilterType" @bind:after="LoadRequests">
                        <option value="Daily">Daily</option>
                        <option value="Monthly">Monthly</option>
                    </select>
                </div>

                @if (FilterType == "Daily")
                {
                    <div class="filter-item">
                        <label class="filter-label">DATE</label>
                        <input type="date" class="form-control custom-select" @bind="SelectedDate" @bind:after="LoadRequests" />
                    </div>
                }
                else
                {
                    <div class="filter-item">
                        <label class="filter-label">MONTH</label>
                        <div class="d-flex gap-2">
                            <select class="form-select custom-select" @bind="SelectedMonth" @bind:after="LoadRequests">
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m">@System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(m)</option>
                                }
                            </select>

                        </div>
                    </div>
                    <div class="filter-item">
                        <label class="filter-label">YEAR</label>
                        <div class="d-flex gap-2">

                            <select class="form-select custom-select" @bind="SelectedYear" @bind:after="LoadRequests">
                                @for (int y = 2024; y <= DateTime.Now.Year + 1; y++)
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>
                    </div>
                }

                <div class="filter-item">
                    <label class="filter-label">STATUS</label>
                    <select class="form-select custom-select" @bind="FilterStatus" @bind:after="ApplyFilters">
                        <option value="All">All Status</option>
                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="Rejected">Rejected</option>
                    </select>
                </div>

                <div class="filter-item search-item">
                    <label class="filter-label">SEARCH EMPLOYEE</label>
                    <div class="search-box">
                        <i class="bi bi-search search-icon"></i>
                        <input class="form-control custom-select pl-search" placeholder="Name or Subject..." @oninput="OnSearchInput" />
                    </div>
                </div>

                <div class="filter-item btn-item">
                    <label class="filter-label d-none d-md-block">&nbsp;</label>
                    <button class="btn-reset w-100" @onclick="ResetFilters">
                        <i class="bi bi-arrow-counterclockwise"></i> Reset
                    </button>
                </div>

                @if (FilterType == "Monthly")
                {
                    <div class="filter-item btn-item">
                        <label class="filter-label d-none d-md-block">&nbsp;</label>
                        <button class="btn-export-leave w-100" @onclick="ExportMonthlyLeaveReport" disabled="@IsExcelLoading">
                            @if (IsExcelLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span><span>Exporting...</span>
                            }
                            else
                            {
                                <i class="bi bi-file-earmark-excel me-1"></i><span>Monthly Report</span>
                            }
                        </button>
                    </div>
                }
            </div>
        </div>

        <!-- Data Grid -->
        <div class="report-table-wrapper">
            @if (IsLoading)
            {
                <div class="empty-state shadow-sm">
                    <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;"></div>
                    <h5>Loading Data...</h5>
                    <p>Fetching outpass requests.</p>
                </div>
            }
            else if (!FilteredRecords.Any())
            {
                <div class="empty-state shadow-sm">
                    <div class="empty-icon placeholder-glow"><i class="bi bi-exclamation-triangle-fill text-warning" style="font-size: 2rem;"></i></div>
                    <h5 class="mt-2">No Requests Found</h5>
                    <p>No outpass requests match your current filters.</p>
                </div>
            }
            else
            {
                <table class="table modern-table">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Request Details</th>
                            <th>Schedule</th>
                            <th>Reason / Subject</th>
                            <th>TL Status</th>
                            <th>Status</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in FilteredRecords)
                        {
                            <tr>
                                <td data-label="Employee">
                                    <div class="employee-cell">
                                        <div class="avatar">@GetInitials(r.EmpName)</div>
                                        <div class="emp-info">
                                            <span class="emp-name">@r.EmpName</span>
                                            <span class="emp-id">ID: @r.EmpId</span>
                                        </div>
                                    </div>
                                </td>
                                <td data-label="Request Details">
                                    <div class="req-type-badge @r.RequestType.Replace(" ", "-").ToLower()">@r.RequestType</div>
                                    <div class="leave-meta">
                                        <span class="cat">@r.LeaveCategory</span> • <span class="type">@r.LeaveType</span>
                                    </div>
                                </td>
                                <td data-label="Schedule">
                                    <div class="schedule-wrapper">

                                        <!-- 📅 MAIN SCHEDULE (Dates & Time) -->
                                        <div class="schedule-main">
                                            @if (r.RequestType == "Full Day Leave")
                                            {
                                                <div class="date-range">
                                                    <span class="d-block fw-bold text-dark">@r.FromDate.ToString("dd MMM yyyy")</span>
                                                    @if (r.ToDate.HasValue && r.ToDate.Value.Date != r.FromDate.Date)
                                                    {
                                                        <small class="text-muted d-flex align-items-center gap-1 mt-1">
                                                            <i class="bi bi-arrow-return-right"></i> @r.ToDate.Value.ToString("dd MMM yyyy")
                                                        </small>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="date-single">
                                                    <span class="d-block fw-bold text-dark">@r.FromDate.ToString("dd MMM yyyy")</span>
                                                    <div class="time-badge mt-1">
                                                        <i class="bi bi-clock"></i>
                                                        @(r.OutTime.HasValue? DateTime.Today.Add(r.OutTime.Value).ToString("hh:mm tt") : "-")
                                                    </div>
                                                </div>
                                            }
                                        </div>

                                        <!-- 🕒 SUBMISSION TIMESTAMP -->
                                        @if (r.CreatedOn.HasValue)
                                        {
                                            <div class="request-timestamp mt-2">
                                                <i class="bi bi-calendar-plus text-primary"></i>
                                                Req: @r.CreatedOn.Value.ToString("dd MMM, hh:mm tt")
                                            </div>
                                        }

                                    </div>
                                </td>
                                <td data-label="Reason">
                                    <div class="reason-cell">
                                        <strong>@r.Subject</strong>
                                        <p class="mb-0 text-muted small text-truncate" title="@r.Reason">@r.Reason</p>
                                    </div>
                                </td>
                                <!-- TBODY मध्ये -->
                                <td data-label="TL Status">
                                    <!-- TL च्या स्टेटससाठी पिल दाखवा -->
                                    <span class="status-pill @GetStatusCss(r.TLStatus)">
                                        @(string.IsNullOrEmpty(r.TLStatus) ? "Pending" : r.TLStatus)
                                    </span>
                                </td>
                              
                                <td data-label="Status">
                                    <span class="status-pill @GetStatusCss(r.Status)">@r.Status</span>
                                </td>
                                <td data-label="Action" class="text-center">
                                    <div class="action-buttons justify-content-center">
                                        @if (r.Status == "Pending")
                                        {
                                            <button class="btn-circle btn-approve" @onclick="() => OpenApproveModal(r)" title="Approve"><i class="bi bi-check2"></i></button>
                                            <button class="btn-circle btn-reject" @onclick="() => OpenRejectModal(r)" title="Reject"><i class="bi bi-x-lg"></i></button>
                                        }
                                        else
                                        {
                                            <button class="btn-view" @onclick="() => OpenDetailsModal(r)"><i class="bi bi-info-circle"></i> Details</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
<!-- ============================================== -->
<!-- 🟢 APPROVE CONFIRM MODAL -->
<!-- ============================================== -->
@if (ShowApproveModal)
{
    <div class="modal-backdrop-custom">
        <div class="confirm-modal shadow-lg animate-pop">
            <div class="modal-icon-circle text-success"><i class="bi bi-check-circle"></i></div>
            <h5 class="fw-bold mt-2">Approve Request</h5>
            <p class="text-muted mb-4 p-modal">Are you sure you want to approve the <b>@SelectedRequest?.LeaveCategory</b> leave for <b>@SelectedRequest?.EmpName</b>?</p>
            <div class="text-start px-3 mb-4">
                <label class="reject-label">Reason / Comment </label>
                <textarea class="form-control reject-textarea-custom"
                          rows="3"
                          @bind="HRComment"
                          placeholder="Enter reason for Approve..."></textarea>
            </div>
            <div class="modal-actions-custom">
                <button class="btn-modal-red" @onclick="CloseModals">Cancel</button>
                <button class="btn-modal-green" @onclick="ConfirmApprove" disabled="@IsProcessing">
                    @(IsProcessing ? "Approving..." : "Yes, Approve")
                </button>
            </div>
        </div>
    </div>
}

<!-- ============================================== -->
<!-- 🔴 REJECT CANCEL MODAL -->
<!-- ============================================== -->
@if (ShowRejectModal)
{
    <div class="modal-backdrop-custom">
        <div class="confirm-modal shadow-lg animate-pop">
            <div class="modal-icon-circle text-dark"><i class="bi bi-x-circle"></i></div>
            <h5 class="fw-bold mt-2">Reject Request</h5>
            <p class="text-muted mb-3 p-modal">Please provide a reason for cancelling <b>@SelectedRequest?.EmpName</b>'s request.</p>

            <div class="text-start px-3 mb-4">
                <label class="reject-label">Reason / Comment <span class="text-danger">*</span></label>
                <textarea class="form-control reject-textarea-custom"
                          rows="3"
                          @bind="HRComment"
                          placeholder="Enter reason for rejection..."></textarea>
            </div>

            <div class="modal-actions-custom">
                <button class="btn-modal-red" @onclick="CloseModals">Cancel</button>
                <button class="btn-modal-green" @onclick="ConfirmReject" disabled="@IsProcessing">
                    @(IsProcessing ? "Rejecting..." : "Confirm Reject")
                </button>
            </div>
        </div>
    </div>
}
<!-- ══ DETAILS MODAL ══════════════════════════════════════════════ -->
@if (ShowDetailsModal && SelectedRequest != null)
{
    <div class="modal-backdrop-custom">
        <div class="details-modal animate-pop">

            <!-- Header -->
            <div class="dm-header">
                <div class="dm-header-icon">📋</div>
                <div class="dm-header-text">
                    <h5 class="dm-title">Leave Request Details</h5>
                    <p class="dm-sub">@SelectedRequest.EmpName</p>
                </div>
                <button class="dm-close" @onclick="CloseModals">✕</button>
            </div>

            <div class="dm-body">

                <!-- Status Badge -->
                <div class="dm-status-row">
                    <span class="dm-status-badge @GetStatusCss(SelectedRequest.Status)">
                        @SelectedRequest.Status
                    </span>
                    @if (!string.IsNullOrEmpty(SelectedRequest.TLStatus))
                    {
                        <span class="dm-tl-badge">TL: @SelectedRequest.TLStatus</span>
                    }
                </div>

                <!-- Info Grid -->
                <div class="dm-grid">
                    <div class="dm-info-item">
                        <span class="dm-lbl">📁 Request Type</span>
                        <span class="dm-val">@SelectedRequest.RequestType</span>
                    </div>
                    <div class="dm-info-item">
                        <span class="dm-lbl">🏷️ Category</span>
                        <span class="dm-val">@SelectedRequest.LeaveCategory</span>
                    </div>
                    <div class="dm-info-item">
                        <span class="dm-lbl">💳 Leave Type</span>
                        <span class="dm-val">@SelectedRequest.LeaveType</span>
                    </div>
                    <div class="dm-info-item">
                        <span class="dm-lbl">📅 From Date</span>
                        <span class="dm-val">@SelectedRequest.FromDate.ToString("dd MMM yyyy")</span>
                    </div>
                    @if (SelectedRequest.ToDate.HasValue)
                    {
                        <div class="dm-info-item">
                            <span class="dm-lbl">📅 To Date</span>
                            <span class="dm-val">@SelectedRequest.ToDate.Value.ToString("dd MMM yyyy")</span>
                        </div>
                    }
                    @if (SelectedRequest.CreatedOn.HasValue)
                    {
                        <div class="dm-info-item">
                            <span class="dm-lbl">🕐 Applied On</span>
                            <span class="dm-val">@SelectedRequest.CreatedOn.Value.ToString("dd MMM, hh:mm tt")</span>
                        </div>
                    }
                </div>

                <!-- Subject & Reason -->
                @if (!string.IsNullOrWhiteSpace(SelectedRequest.Subject))
                {
                    <div class="dm-reason-box">
                        <span class="dm-lbl">📝 Subject</span>
                        <p class="dm-reason-text">@SelectedRequest.Subject</p>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(SelectedRequest.Reason))
                {
                    <div class="dm-reason-box">
                        <span class="dm-lbl">💬 Reason</span>
                        <p class="dm-reason-text">@SelectedRequest.Reason</p>
                    </div>
                }

                <!-- Comments -->
                @if (!string.IsNullOrWhiteSpace(SelectedRequest.TLComment))
                {
                    <div class="dm-comment-box dm-comment-tl">
                        <span class="dm-lbl">👤 TL Comment</span>
                        <p class="dm-reason-text">@SelectedRequest.TLComment</p>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(SelectedRequest.HRComment))
                {
                    <div class="dm-comment-box dm-comment-hr">
                        <span class="dm-lbl">🏢 HR Comment</span>
                        <p class="dm-reason-text">@SelectedRequest.HRComment</p>
                    </div>
                }

                <!-- Reject option (only if Approved) -->
                @if (SelectedRequest.Status == "Approved")
                {
                    <div class="dm-reject-section">
                        <label class="dm-lbl">❌ Reject this approval</label>
                        <textarea class="dm-reject-input" rows="2" @bind="HRComment"
                                  placeholder="Enter reason to reject..."></textarea>
                    </div>
                }
            </div>

            <div class="dm-footer">
                <button class="dm-btn-close" @onclick="CloseModals">Close</button>
                @if (SelectedRequest.Status == "Approved")
                {
                    <button class="dm-btn-reject" @onclick="ConfirmReject" disabled="@(IsProcessing || string.IsNullOrWhiteSpace(HRComment))">
                        @(IsProcessing ? "Rejecting..." : "Reject Request")
                    </button>
                }
            </div>
        </div>
    </div>
}

<!-- TOAST -->
@if (!string.IsNullOrEmpty(ToastMsg))
{
    <div class="toast-popup @ToastClass">@ToastMsg</div>
}

<style>
    /* Schedule Column UI */
    .schedule-wrapper {
        display: flex;
        flex-direction: column;
        min-width: 140px;
    }

    .schedule-main {
        margin-bottom: 2px;
    }

    /* Time Badge for Half Day / Early Out */
    .time-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background-color: #f1f5f9;
        color: #334155;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 8px;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
    }

        .time-badge i {
            color: #3b82f6; /* Blue icon */
            font-size: 12px;
        }

    /* Requested Time Micro-Card */
    .request-timestamp {
        font-size: 11px;
        color: #64748b;
        background: #f8fafc;
        padding: 4px 8px;
        border-radius: 6px;
        border-left: 3px solid #cbd5e1; /* Subtle gray accent border */
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-weight: 500;
    }

    .schedule-wrapper {
        align-items: flex-end;
        text-align: right;
    }

    .request-timestamp {
        border-left: none;
        border-right: 3px solid #cbd5e1; /* Move border to the right for mobile */
    }
    :root {
        --primary: #4f46e5;
        --success: #10b981;
        --danger: #ef4444;
        --pending: #f59e0b;
        --bg-main: #f8fafc;
    }
    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 16px;
    }

    .report-wrapper {
        background: var(--bg-main);
        min-height: 100vh;
        padding: 40px 20px;
        font-family: 'Inter', sans-serif;
    }

    .report-container {
        max-width: 1250px;
        margin: auto;
    }

    .icon-main {
        width: 50px;
        height: 50px;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        color: var(--primary);
        font-size: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
    }

    .report-header h2 {
        font-weight: 800;
        color: #1e293b;
        margin: 0;
    }

    /* STATS */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
    }

    .stat-card {
        background: #fff;
        padding: 25px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        gap: 20px;
        border: none;
    }

    .stat-icon {
        width: 54px;
        height: 54px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .stat-total .stat-icon {
        background: #eef2ff;
        color: var(--primary);
    }

    .stat-pending .stat-icon {
        background: #fffbeb;
        color: var(--pending);
    }

    .stat-approved .stat-icon {
        background: #ecfdf5;
        color: var(--success);
    }

    .stat-rejected .stat-icon {
        background: #fef2f2;
        color: var(--danger);
    }

    .stat-title {
        font-size: 12px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        margin: 0;
    }

    .stat-count {
        font-size: 28px;
        font-weight: 800;
        margin: 0;
    }

    /* FILTERS */
    .filter-card {
        background: #fff;
        border-radius: 16px;
        padding: 20px;
    }

    .filter-row {
        display: flex;
        gap: 15px;
        align-items: flex-end;
        flex-wrap: wrap;
    }

    .filter-item {
        flex: 1;
        min-width: 140px;
    }

    .search-item {
        flex: 2;
        min-width: 250px;
    }

    .filter-label {
        font-size: 11px;
        font-weight: 700;
        color: #94a3b8;
        margin-bottom: 8px;
        display: block;
    }

    .custom-select {
        border-radius: 10px;
        border: 1.5px solid #e2e8f0;
        padding: 10px 15px;
        font-size: 14px;
        background: #fdfdfd;
    }

    .btn-reset {
        background: #f1f5f9;
        border: none;
        padding: 10px;
        border-radius: 10px;
        font-weight: 600;
        color: #475569;
    }

    .btn-export-leave {
        background: linear-gradient(135deg, #16a34a, #22c55e);
        border: none;
        padding: 10px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 13px;
        color: #fff;
        transition: 0.2s;
        box-shadow: 0 3px 10px rgba(22,163,74,0.3);
    }
    .btn-export-leave:hover:not(:disabled) { opacity: 0.88; transform: translateY(-1px); }
    .btn-export-leave:disabled { opacity: 0.6; cursor: not-allowed; }

    /* TABLE */
    .modern-table {
        width: 100%;
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
    }

        .modern-table th {
            background: #f8fafc;
            padding: 18px;
            font-size: 12px;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            border-bottom: 2.5px solid #f1f5f9;
        }

        .modern-table td {
            padding: 18px;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
        }

    .employee-cell {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .avatar {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        background: var(--primary);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 14px;
    }

    .emp-name {
        font-weight: 700;
        color: #1e293b;
        display: block;
    }

    .emp-id {
        font-size: 11px;
        color: #94a3b8;
    }

    .req-type-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 5px;
    }

    .full-day-leave {
        background: #e0f2fe;
        color: #0369a1;
    }

    .first-half-day, .second-half-day {
        background: #fef3c7;
        color: #92400e;
    }

    .early-out {
        background: #fae8ff;
        color: #86198f;
    }

    .status-pill {
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 700;
    }

    .st-approved {
        background: #d1fae5;
        color: #065f46;
    }

    .st-pending {
        background: #ffedd5;
        color: #9a3412;
    }

    .st-rejected {
