    private async Task LoadRequests()
    {
        IsLoading = true;
        try
        {
            // Update URL to your actual API Controller
            string url = $"api/LeaveRequest/GetAllRequests?viewType={FilterType}";
            if (FilterType == "Daily") url += $"&date={SelectedDate:yyyy-MM-dd}";
            else url += $"&month={SelectedMonth}&year={SelectedYear}";

            var response = await Http.GetFromJsonAsync<List<LeaveRequestModel>>(url);
            AllRecords = response ?? new();
            ApplyFilters();
        }
        catch (Exception ex) { ShowToast("Server Error: " + ex.Message, "t-error"); }
        finally { IsLoading = false; }
    }

    private void ApplyFilters()
    {
        var query = AllRecords.AsEnumerable();
        if (FilterStatus != "All") query = query.Where(x => x.Status == FilterStatus);
        if (!string.IsNullOrWhiteSpace(SearchText))
            query = query.Where(x => x.EmpName.Contains(SearchText, StringComparison.OrdinalIgnoreCase) || x.Subject.Contains(SearchText, StringComparison.OrdinalIgnoreCase));

        FilteredRecords = query.ToList();

        // Stats always reflect ALL records for the period, not the filtered subset
        TotalRequests = AllRecords.Count;
        PendingCount  = AllRecords.Count(x => x.Status == "Pending");
        ApprovedCount = AllRecords.Count(x => x.Status == "Approved");
        RejectedCount = AllRecords.Count(x => x.Status == "Rejected");

        StateHasChanged(); // UI रिफ्रेश करण्यासाठी
    }

    private void OnSearchInput(ChangeEventArgs e) { SearchText = e.Value?.ToString() ?? ""; ApplyFilters(); }
    private void ResetFilters() { FilterStatus = "All"; SearchText = ""; LoadRequests(); }

    private void OpenApproveModal(LeaveRequestModel r) { SelectedRequest = r; ShowApproveModal = true; }
    private void OpenRejectModal(LeaveRequestModel r) { SelectedRequest = r; HRComment = ""; ShowRejectModal = true; }
    private void OpenDetailsModal(LeaveRequestModel r) { SelectedRequest = r; HRComment = ""; ShowDetailsModal = true; }
    private void CloseModals() { ShowApproveModal = ShowRejectModal = ShowDetailsModal = false; SelectedRequest = null; }

    private async Task ConfirmApprove()
    {
        IsProcessing = true;
        try
        {
            var res = await Http.PutAsJsonAsync($"api/LeaveRequest/Approve/{SelectedRequest.Id}", new { HRComment });
            if (res.IsSuccessStatusCode)
            {
                ShowToast("Leave Approved Successfully", "t-success");
                // =========================================================
                // 🔥 NEW: Outpass Rejected झाल्यावर लगेच Notification API ला कॉल करा
                // =========================================================
                try
                {
                    string title = $"Your {SelectedRequest.RequestType} Request Approved";
                    string body = $"{SelectedRequest.EmpName}, your {SelectedRequest.RequestType} request has been approved.";
                    string link = "/attendance";

                    var notification = new NotificationRequest
                    {
                        EmpId = Convert.ToInt32(SelectedRequest.EmpId),
                        EmployeeName = SelectedRequest.EmpName,
                        Title = title,
                        Body = body,
                        Link = link
                    };

                    await Http.PostAsJsonAsync("api/Notifications/sendEmployeeNotification", notification);
                }
                catch (Exception ex)
                {
                    Console.WriteLine("Notification send failed: " + ex.Message);
                }
                await LoadRequests();
                CloseModals();
            }
        }
        catch { ShowToast("Operation failed", "t-error"); }
        finally { IsProcessing = false; }
    }

