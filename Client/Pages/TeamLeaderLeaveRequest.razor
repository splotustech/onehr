@page "/team-leave-requests"
@using SMART_HRMS_SYSTEM.Shared.ViewModel
@using SMART_HRMS_SYSTEM.Shared.Models
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavManager

<div class="report-wrapper">
    <div class="report-container">

        <!-- Header -->
        <div class="report-header">
            <div class="d-flex align-items-center gap-3">
                <div>
                    <h2>Leave Approval Management</h2>
                    <p>Manage Full Day, Half Day, and Early Out requests from employees.</p>
                </div>
            </div>
        </div>

        <!-- Stats Row -->
        <div class="stats-row mb-4">
            <div class="stat-card stat-total shadow-sm">
                <div class="stat-icon"><i class="bi bi-files"></i></div>
                <div class="stat-details">
                    <p class="stat-title">Total Requests</p>
                    <h3 class="stat-count">@TotalRequests</h3>
                </div>
            </div>

            <div class="stat-card stat-pending shadow-sm">
                <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-details">
                    <p class="stat-title">Pending</p>
                    <h3 class="stat-count text-warning">@PendingCount</h3>
                </div>
            </div>

            <div class="stat-card stat-approved shadow-sm">
                <div class="stat-icon"><i class="bi bi-check-all"></i></div>
                <div class="stat-details">
                    <p class="stat-title">Approved</p>
                    <h3 class="stat-count text-success">@ApprovedCount</h3>
                </div>
            </div>

            <div class="stat-card stat-rejected shadow-sm">
                <div class="stat-icon"><i class="bi bi-trash3"></i></div>
                <div class="stat-details">
                    <p class="stat-title">Rejected</p>
                    <h3 class="stat-count text-danger">@RejectedCount</h3>
                </div>
            </div>
        </div>

        <!-- Filter Card -->
        <div class="filter-card shadow-sm mb-4">
            <div class="filter-row">
                <div class="filter-item">
                    <label class="filter-label">VIEW TYPE</label>
                    <select class="form-select custom-select" @bind="FilterType" @bind:after="LoadRequests">
                        <option value="Daily">Daily</option>
                        <option value="Monthly">Monthly</option>
                    </select>
                </div>

                @if (FilterType == "Daily")
                {
                    <div class="filter-item">
                        <label class="filter-label">DATE</label>
                        <input type="date" class="form-control custom-select" @bind="SelectedDate" @bind:after="LoadRequests" />
                    </div>
                }
                else
                {
                    <div class="filter-item">
                        <label class="filter-label">MONTH</label>
                        <div class="d-flex gap-2">
                            <select class="form-select custom-select" @bind="SelectedMonth" @bind:after="LoadRequests">
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m">@System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(m)</option>
                                }
                            </select>

                        </div>
                    </div>
                    <div class="filter-item">
                        <label class="filter-label">YEAR</label>
                        <div class="d-flex gap-2">

                            <select class="form-select custom-select" @bind="SelectedYear" @bind:after="LoadRequests">
                                @for (int y = 2024; y <= DateTime.Now.Year + 1; y++)
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>
                    </div>
                }

                <div class="filter-item">
                    <label class="filter-label">STATUS</label>
                    <select class="form-select custom-select" @bind="FilterStatus" @bind:after="ApplyFilters">
                        <option value="All">All Status</option>
                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="Rejected">Rejected</option>
                    </select>
                </div>

                <div class="filter-item search-item">
                    <label class="filter-label">SEARCH EMPLOYEE</label>
                    <div class="search-box">
                        <i class="bi bi-search search-icon"></i>
                        <input class="form-control custom-select pl-search" placeholder="Name or Subject..." @oninput="OnSearchInput" />
                    </div>
                </div>

                <div class="filter-item btn-item">
                    <label class="filter-label d-none d-md-block">&nbsp;</label>
                    <button class="btn-reset w-100" @onclick="ResetFilters">
                        <i class="bi bi-arrow-counterclockwise"></i> Reset
                    </button>
                </div>
            </div>
        </div>

        <!-- Data Grid -->
        <div class="report-table-wrapper">
            @if (IsLoading)
            {
                <div class="empty-state shadow-sm">
                    <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;"></div>
                    <h5>Loading Data...</h5>
                    <p>Fetching outpass requests.</p>
                </div>
            }
            else if (!FilteredRecords.Any())
            {
                <div class="empty-state shadow-sm">
                    <div class="empty-icon placeholder-glow"><i class="bi bi-exclamation-triangle-fill text-warning" style="font-size: 2rem;"></i></div>
                    <h5 class="mt-2">No Requests Found</h5>
                    <p>No outpass requests match your current filters.</p>
                </div>
            }
            else
            {
                <table class="table modern-table">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Request Details</th>
                            <th>Schedule</th>
                            <th>Reason / Subject</th>
                            <th>TL Status</th>
                            <th>Status</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in FilteredRecords)
                        {
                            <tr>
                                <td data-label="Employee">
                                    <div class="employee-cell">
                                        <div class="avatar">@GetInitials(r.EmpName)</div>
                                        <div class="emp-info">
                                            <span class="emp-name">@r.EmpName</span>
                                            <span class="emp-id">ID: @r.EmpId</span>
                                        </div>
                                    </div>
                                </td>
                                <td data-label="Request Details">
                                    <div class="req-type-badge @r.RequestType.Replace(" ", "-").ToLower()">@r.RequestType</div>
                                    <div class="leave-meta">
                                        <span class="cat">@r.LeaveCategory</span> • <span class="type">@r.LeaveType</span>
                                    </div>
                                </td>
                                <td data-label="Schedule">
                                    <div class="schedule-wrapper">

                                        <!-- 📅 MAIN SCHEDULE (Dates & Time) -->
                                        <div class="schedule-main">
                                            @if (r.RequestType == "Full Day Leave")
                                            {
                                                <div class="date-range">
                                                    <span class="d-block fw-bold text-dark">@r.FromDate.ToString("dd MMM yyyy")</span>
                                                    @if (r.ToDate.HasValue && r.ToDate.Value.Date != r.FromDate.Date)
                                                    {
                                                        <small class="text-muted d-flex align-items-center gap-1 mt-1">
                                                            <i class="bi bi-arrow-return-right"></i> @r.ToDate.Value.ToString("dd MMM yyyy")
                                                        </small>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="date-single">
                                                    <span class="d-block fw-bold text-dark">@r.FromDate.ToString("dd MMM yyyy")</span>
                                                    <div class="time-badge mt-1">
                                                        <i class="bi bi-clock"></i>
                                                        @(r.OutTime.HasValue? DateTime.Today.Add(r.OutTime.Value).ToString("hh:mm tt") : "-")
                                                    </div>
                                                </div>
                                            }
                                        </div>

                                        <!-- 🕒 SUBMISSION TIMESTAMP -->
                                        @if (r.CreatedOn.HasValue)
                                        {
                                            <div class="request-timestamp mt-2">
                                                <i class="bi bi-calendar-plus text-primary"></i>
                                                Req: @r.CreatedOn.Value.ToString("dd MMM, hh:mm tt")
                                            </div>
                                        }

                                    </div>
                                </td>
                                <td data-label="Reason">
                                    <div class="reason-cell">
                                        <strong>@r.Subject</strong>
                                        <p class="mb-0 text-muted small text-truncate" title="@r.Reason">@r.Reason</p>
                                    </div>
                                </td>
                                <!-- TBODY मध्ये -->
                                <td data-label="TL Status">
                                    <!-- TL च्या स्टेटससाठी पिल दाखवा -->
                                    <span class="status-pill @GetStatusCss(r.TLStatus)">
                                        @(string.IsNullOrEmpty(r.TLStatus) ? "Pending" : r.TLStatus)
                                    </span>
                                </td>
                              
                                <td data-label="Status">
                                    <span class="status-pill @GetStatusCss(r.Status)">@r.Status</span>
                                </td>
                                <td data-label="Action" class="text-center">
                                    <div class="action-buttons justify-content-center">
                                        @if (string.IsNullOrEmpty(r.TLStatus) || r.TLStatus == "Pending")
                                        {
                                            <button class="btn-circle btn-approve" @onclick="() => OpenApproveModal(r)" title="Approve"><i class="bi bi-check2"></i></button>
                                            <button class="btn-circle btn-reject" @onclick="() => OpenRejectModal(r)" title="Reject"><i class="bi bi-x-lg"></i></button>
                                        }
                                        else
                                        {
                                            <button class="btn-view" @onclick="() => ShowFullDetails(r)"><i class="bi bi-info-circle"></i> Details</button>
                                            <button class="btn-circle btn-reject" @onclick="() => OpenRejectModal(r)" title="Reject"><i class="bi bi-x-lg"></i></button>

                                        }
           
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
<!-- ============================================== -->
<!-- ✅ APPROVE CONFIRM MODAL -->
<!-- ============================================== -->
@if (ShowApproveModal && SelectedRequest != null)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals">
        <div class="tl-modal tl-approve-modal animate-pop" @onclick:stopPropagation="true">

            <!-- Header -->
            <div class="tl-modal-header tl-header-green">
                <div class="tl-header-icon"><i class="bi bi-check2-circle"></i></div>
                <div>
                    <h5 class="tl-modal-title">Approve Request</h5>
                    <p class="tl-modal-sub">Confirm TL approval for this leave</p>
                </div>
                <button class="tl-close-btn" @onclick="CloseModals"><i class="bi bi-x-lg"></i></button>
            </div>

            <!-- Employee Row -->
            <div class="tl-emp-row">
                <div class="tl-emp-avatar">@GetInitials(SelectedRequest.EmpName)</div>
                <div class="tl-emp-info">
                    <span class="tl-emp-name">@SelectedRequest.EmpName</span>
                    <span class="tl-emp-meta">ID: @SelectedRequest.EmpId</span>
                </div>
                <span class="req-type-badge @SelectedRequest.RequestType.Replace(" ","-").ToLower() ms-auto">
                    @SelectedRequest.RequestType
                </span>
            </div>

            <!-- Leave Summary Grid -->
            <div class="tl-summary-grid">
                <div class="tl-summary-item">
                    <span class="tl-sum-lbl"><i class="bi bi-folder2-open"></i> Category</span>
                    <span class="tl-sum-val">@SelectedRequest.LeaveCategory</span>
                </div>
                <div class="tl-summary-item">
                    <span class="tl-sum-lbl"><i class="bi bi-cash-coin"></i> Leave Type</span>
                    <span class="tl-sum-val">@SelectedRequest.LeaveType</span>
                </div>
                <div class="tl-summary-item">
                    <span class="tl-sum-lbl"><i class="bi bi-calendar-event"></i> From</span>
                    <span class="tl-sum-val">@SelectedRequest.FromDate.ToString("dd MMM yyyy")</span>
                </div>
                <div class="tl-summary-item">
                    <span class="tl-sum-lbl"><i class="bi bi-calendar2-check"></i> To</span>
                    <span class="tl-sum-val">
                        @(SelectedRequest.ToDate.HasValue
                            ? SelectedRequest.ToDate.Value.ToString("dd MMM yyyy")
                            : SelectedRequest.FromDate.ToString("dd MMM yyyy"))
                    </span>
                </div>
            </div>

            <!-- Confirm Message -->
            <div class="tl-confirm-msg tl-confirm-green">
                <i class="bi bi-patch-check-fill"></i>
                Approving this request will notify the employee and HR department.
            </div>

            <!-- Footer -->
            <div class="tl-modal-footer">
                <button class="tl-btn-cancel" @onclick="CloseModals">Cancel</button>
                <button class="tl-btn-approve" @onclick="ConfirmApprove" disabled="@IsProcessing">
                    <i class="bi bi-check2"></i>
                    @(IsProcessing ? "Approving..." : "Yes, Approve")
                </button>
            </div>

        </div>
    </div>
}

<!-- ============================================== -->
<!-- ❌ REJECT MODAL -->
<!-- ============================================== -->
@if (ShowRejectModal && SelectedRequest != null)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals">
        <div class="tl-modal tl-reject-modal animate-pop" @onclick:stopPropagation="true">

            <!-- Header -->
            <div class="tl-modal-header tl-header-red">
                <div class="tl-header-icon"><i class="bi bi-x-circle"></i></div>
                <div>
                    <h5 class="tl-modal-title">Reject Request</h5>
                    <p class="tl-modal-sub">Provide a reason for rejection</p>
                </div>
                <button class="tl-close-btn" @onclick="CloseModals"><i class="bi bi-x-lg"></i></button>
            </div>

            <!-- Employee Row -->
            <div class="tl-emp-row">
                <div class="tl-emp-avatar tl-avatar-red">@GetInitials(SelectedRequest.EmpName)</div>
                <div class="tl-emp-info">
                    <span class="tl-emp-name">@SelectedRequest.EmpName</span>
                    <span class="tl-emp-meta">
                        @SelectedRequest.LeaveCategory &nbsp;•&nbsp; @SelectedRequest.RequestType
                    </span>
                </div>
                <div class="tl-date-badge ms-auto">
                    <i class="bi bi-calendar3"></i>
                    @SelectedRequest.FromDate.ToString("dd MMM")
                    @if (SelectedRequest.ToDate.HasValue && SelectedRequest.ToDate.Value.Date != SelectedRequest.FromDate.Date)
                    {
                        <span>→ @SelectedRequest.ToDate.Value.ToString("dd MMM")</span>
                    }
                </div>
            </div>

            <!-- Reject Reason Input -->
            <div class="tl-reject-body">
                <label class="tl-reject-label">
                    <i class="bi bi-pencil-square"></i> Reason for Rejection
                    <span class="tl-req">*</span>
                </label>
                <textarea class="tl-reject-textarea"
                          @bind="TLComment"
                          rows="4"
                          placeholder="Explain why this leave is being rejected (e.g. insufficient leaves, critical project, etc.)..."></textarea>
                @if (string.IsNullOrWhiteSpace(TLComment))
                {
                    <span class="tl-reject-hint">
                        <i class="bi bi-exclamation-circle"></i> Required — employee will see this reason.
                    </span>
                }
            </div>

            <!-- Footer -->
            <div class="tl-modal-footer">
                <button class="tl-btn-cancel" @onclick="CloseModals">Cancel</button>
                <button class="tl-btn-reject" @onclick="ConfirmReject"
                        disabled="@(IsProcessing || string.IsNullOrWhiteSpace(TLComment))">
                    <i class="bi bi-x-lg"></i>
                    @(IsProcessing ? "Rejecting..." : "Confirm Reject")
                </button>
            </div>

        </div>
    </div>
}
<!-- ============================================== -->
<!-- 📋 DETAILS MODAL -->
<!-- ============================================== -->
@if (ShowDetailsModal && SelectedRequest != null)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals">
        <div class="details-modal shadow-lg animate-pop" @onclick:stopPropagation="true">

            <!-- Header -->
            <div class="dm-header">
                <div class="dm-avatar">@GetInitials(SelectedRequest.EmpName)</div>
                <div class="dm-emp-info">
                    <h5 class="dm-emp-name">@SelectedRequest.EmpName</h5>
                    <span class="dm-emp-id">Employee ID : @SelectedRequest.EmpId</span>
                </div>
                <button class="dm-close-btn" @onclick="CloseModals"><i class="bi bi-x-lg"></i></button>
            </div>

            <!-- Request Type Badge -->
            <div class="dm-badge-row">
                <span class="req-type-badge @SelectedRequest.RequestType.Replace(" ", "-").ToLower()">
                    <i class="bi bi-tag-fill me-1"></i>@SelectedRequest.RequestType
                </span>
                <span class="dm-submitted">
                    <i class="bi bi-calendar-plus"></i>
                    Submitted : @(SelectedRequest.CreatedOn?.ToString("dd MMM yyyy, hh:mm tt") ?? "—")
                </span>
            </div>

            <div class="dm-divider"></div>

            <!-- Info Grid -->
            <div class="dm-grid">
                <div class="dm-info-item">
                    <span class="dm-label"><i class="bi bi-folder2-open"></i> Category</span>
                    <span class="dm-value">@SelectedRequest.LeaveCategory</span>
                </div>
                <div class="dm-info-item">
                    <span class="dm-label"><i class="bi bi-cash-coin"></i> Leave Type</span>
                    <span class="dm-value">@SelectedRequest.LeaveType</span>
                </div>
                <div class="dm-info-item">
                    <span class="dm-label"><i class="bi bi-calendar-event"></i> From Date</span>
                    <span class="dm-value">@SelectedRequest.FromDate.ToString("dd MMM yyyy")</span>
                </div>
                <div class="dm-info-item">
                    <span class="dm-label"><i class="bi bi-calendar2-check"></i> To Date</span>
                    <span class="dm-value">
                        @(SelectedRequest.ToDate.HasValue
                            ? SelectedRequest.ToDate.Value.ToString("dd MMM yyyy")
                            : SelectedRequest.FromDate.ToString("dd MMM yyyy"))
                    </span>
                </div>
                @if (SelectedRequest.OutTime.HasValue)
                {
                    <div class="dm-info-item dm-full">
                        <span class="dm-label"><i class="bi bi-clock"></i> Out Time</span>
                        <span class="dm-value">@DateTime.Today.Add(SelectedRequest.OutTime.Value).ToString("hh:mm tt")</span>
                    </div>
                }
            </div>

            <div class="dm-divider"></div>

            <!-- Subject & Reason -->
            <div class="dm-section">
                <div class="dm-section-title"><i class="bi bi-chat-left-text"></i> Subject</div>
                <div class="dm-section-body">@SelectedRequest.Subject</div>
            </div>
            <div class="dm-section mt-2">
                <div class="dm-section-title"><i class="bi bi-justify-left"></i> Reason</div>
                <div class="dm-section-body">
                    @(string.IsNullOrWhiteSpace(SelectedRequest.Reason) ? "No reason provided." : SelectedRequest.Reason)
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(SelectedRequest.DocumentAttachament))
            {
                <div class="dm-section mt-2">
                    <div class="dm-section-title"><i class="bi bi-paperclip"></i> Attachment</div>
                    <a href="@SelectedRequest.DocumentAttachament" target="_blank" class="dm-attachment-link">
                        <i class="bi bi-file-earmark-arrow-down"></i> View Document
                    </a>
                </div>
            }

            <div class="dm-divider"></div>

            <!-- Status Cards Row -->
            <div class="dm-status-row">
                <!-- TL Decision -->
                <div class="dm-status-card @GetStatusCardCss(SelectedRequest.TLStatus)">
                    <div class="dm-status-card-title">
                        <i class="bi bi-person-check"></i> Team Leader
                    </div>
                    <span class="status-pill @GetStatusCss(SelectedRequest.TLStatus)">
                        @(string.IsNullOrEmpty(SelectedRequest.TLStatus) ? "Pending" : SelectedRequest.TLStatus)
                    </span>
                    @if (!string.IsNullOrWhiteSpace(SelectedRequest.TLComment))
                    {
                        <p class="dm-comment"><i class="bi bi-chat-dots"></i> @SelectedRequest.TLComment</p>
                    }
                </div>

                <!-- HR Decision -->
                <div class="dm-status-card @GetStatusCardCss(SelectedRequest.Status)">
                    <div class="dm-status-card-title">
                        <i class="bi bi-building"></i> HR / Admin
                    </div>
                    <span class="status-pill @GetStatusCss(SelectedRequest.Status)">@SelectedRequest.Status</span>
                    @if (!string.IsNullOrWhiteSpace(SelectedRequest.HRComment))
                    {
                        <p class="dm-comment"><i class="bi bi-chat-dots"></i> @SelectedRequest.HRComment</p>
                    }
                </div>
            </div>

            <!-- Footer -->
            <div class="dm-footer">
                <button class="dm-btn-close" @onclick="CloseModals">
                    <i class="bi bi-x-circle"></i> Close
                </button>
            </div>

        </div>
    </div>
}

<!-- TOAST -->
@if (!string.IsNullOrEmpty(ToastMsg))
{
    <div class="toast-popup @ToastClass">@ToastMsg</div>
}

<style>
    /* Schedule Column UI */
    .schedule-wrapper {
        display: flex;
        flex-direction: column;
        min-width: 140px;
    }

    .schedule-main {
        margin-bottom: 2px;
    }

    /* Time Badge for Half Day / Early Out */
    .time-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background-color: #f1f5f9;
        color: #334155;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 8px;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
    }

        .time-badge i {
            color: #3b82f6; /* Blue icon */
            font-size: 12px;
        }

    /* Requested Time Micro-Card */
    .request-timestamp {
        font-size: 11px;
        color: #64748b;
        background: #f8fafc;
        padding: 4px 8px;
        border-radius: 6px;
        border-left: 3px solid #cbd5e1; /* Subtle gray accent border */
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-weight: 500;
    }

    .schedule-wrapper {
        align-items: flex-end;
        text-align: right;
    }

    .request-timestamp {
        border-left: none;
        border-right: 3px solid #cbd5e1; /* Move border to the right for mobile */
    }
    :root {
        --primary: #4f46e5;
        --success: #10b981;
        --danger: #ef4444;
        --pending: #f59e0b;
        --bg-main: #f8fafc;
    }
    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 16px;
    }

    .report-wrapper {
        background: var(--bg-main);
        min-height: 100vh;
        padding: 40px 20px;
        font-family: 'Inter', sans-serif;
    }

    .report-container {
        max-width: 1250px;
        margin: auto;
    }

    .icon-main {
        width: 50px;
        height: 50px;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        color: var(--primary);
        font-size: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
    }

    .report-header h2 {
        font-weight: 800;
        color: #1e293b;
        margin: 0;
    }

    /* STATS */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
    }

    .stat-card {
        background: #fff;
        padding: 25px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        gap: 20px;
        border: none;
    }

    .stat-icon {
        width: 54px;
        height: 54px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .stat-total .stat-icon {
        background: #eef2ff;
        color: var(--primary);
    }

    .stat-pending .stat-icon {
        background: #fffbeb;
        color: var(--pending);
    }

    .stat-approved .stat-icon {
        background: #ecfdf5;
        color: var(--success);
    }

    .stat-rejected .stat-icon {
        background: #fef2f2;
        color: var(--danger);
    }

    .stat-title {
        font-size: 12px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        margin: 0;
    }

    .stat-count {
        font-size: 28px;
        font-weight: 800;
        margin: 0;
    }

    /* FILTERS */
    .filter-card {
        background: #fff;
        border-radius: 16px;
        padding: 20px;
    }

    .filter-row {
        display: flex;
