    private string ToastMsg, ToastClass;

    protected override async Task OnInitializedAsync() { }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                EmployeeName = await JS.InvokeAsync<string>("localStorage.getItem", "empName");
                var empIdStr = await JS.InvokeAsync<string>("localStorage.getItem", "empId");

                if (string.IsNullOrEmpty(EmployeeName) || string.IsNullOrEmpty(empIdStr))
                {
                    NavManager.NavigateTo("/", true);
                    return;
                }

                LoggedInEmpId = int.Parse(empIdStr);
                await LoadRequests();
                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task LoadRequests()
    {
        if (LoggedInEmpId == 0) return;

        IsLoading = true;
        try
        {
            // 🔥 Backend मध्ये तुम्हाला TL च्या ID नुसार टीमचा डेटा देणारा API बनवावा लागेल.
            // उदा. api/LeaveRequest/GetTeamRequests?tlId={LoggedInEmpId}
            string url = $"api/LeaveRequest/GetTeamRequests?tlId={LoggedInEmpId}&viewType={FilterType}";
            if (FilterType == "Daily") url += $"&date={SelectedDate:yyyy-MM-dd}";
            else url += $"&month={SelectedMonth}&year={SelectedYear}";

            var response = await Http.GetFromJsonAsync<List<LeaveRequestModel>>(url);
            AllRecords = response ?? new();
            ApplyFilters();
        }
        catch (Exception ex) { ShowToast("Server Error: " + ex.Message, "t-error"); }
        finally { IsLoading = false; StateHasChanged(); }
    }

    private void ApplyFilters()
    {
        var query = AllRecords.AsEnumerable();

        // इथे फिल्टर करताना TLStatus वर फिल्टर लावा
        if (FilterStatus != "All")
        {
            if (FilterStatus == "Pending") query = query.Where(x => string.IsNullOrEmpty(x.TLStatus) || x.TLStatus == "Pending");
            else query = query.Where(x => x.TLStatus == FilterStatus);
        }

        if (!string.IsNullOrWhiteSpace(SearchText))
            query = query.Where(x => x.EmpName.Contains(SearchText, StringComparison.OrdinalIgnoreCase) || x.Subject.Contains(SearchText, StringComparison.OrdinalIgnoreCase));

        FilteredRecords = query.ToList();

        TotalRequests = FilteredRecords.Count;
        PendingCount = FilteredRecords.Count(x => string.IsNullOrEmpty(x.TLStatus) || x.TLStatus == "Pending");
        ApprovedCount = FilteredRecords.Count(x => x.TLStatus == "Approved");
        RejectedCount = FilteredRecords.Count(x => x.TLStatus == "Rejected");
          StateHasChanged(); // UI रिफ्रेश करण्यासाठी
    }

    private void OnSearchInput(ChangeEventArgs e) { SearchText = e.Value?.ToString() ?? ""; ApplyFilters(); }
    private void ResetFilters() { FilterStatus = "All"; SearchText = ""; LoadRequests(); }

    private void OpenApproveModal(LeaveRequestModel r) { SelectedRequest = r; ShowApproveModal = true; }
    private void OpenRejectModal(LeaveRequestModel r) { SelectedRequest = r; TLComment = ""; ShowRejectModal = true; }
    private void CloseModals() { ShowApproveModal = ShowRejectModal = ShowDetailsModal = false; SelectedRequest = null; }

    // ==========================================
    // 🔥 TL APPROVE LOGIC & NOTIFICATIONS
    // ==========================================
    private async Task ConfirmApprove()
    {
        IsProcessing = true;
        try
        {
            // API ला कॉल करा जो फक्त TLStatus = 'Approved' करेल
            var res = await Http.PutAsJsonAsync($"api/LeaveRequest/TLApprove/{SelectedRequest.Id}", new { });

            if (res.IsSuccessStatusCode)
            {
                ShowToast("Leave Approved Successfully", "t-success");

                await SendNotificationsAfterAction("Approved");

                await LoadRequests();
                CloseModals();
            }
        }
        catch { ShowToast("Operation failed", "t-error"); }
        finally { IsProcessing = false; }
    }

    // ==========================================
    // 🔥 TL REJECT LOGIC & NOTIFICATIONS
    // ==========================================
    private async Task ConfirmReject()
    {
        if (string.IsNullOrWhiteSpace(TLComment)) { ShowToast("Please enter rejection reason", "t-error"); return; }
        IsProcessing = true;
        try
        {
            // API ला कॉल करा जो फक्त TLStatus = 'Rejected' करेल
            var res = await Http.PutAsJsonAsync($"api/LeaveRequest/TLReject/{SelectedRequest.Id}", new { TLComment = TLComment });

            if (res.IsSuccessStatusCode)
            {
                ShowToast("Leave Rejected", "t-success");

                await SendNotificationsAfterAction("Rejected");

                await LoadRequests();
                CloseModals();
            }
        }
        catch { ShowToast("Operation failed", "t-error"); }
        finally { IsProcessing = false; }
    }

