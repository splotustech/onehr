    private void ShowToast(string msg, string cls)
    {
        ToastMsg = msg; ToastClass = cls; StateHasChanged();
        Task.Delay(3000).ContinueWith(_ => { ToastMsg = ""; InvokeAsync(StateHasChanged); });
    }

    private string GetStatusCss(string s) => s switch
    {
        "Approved" => "st-approved",
        "Rejected" => "st-rejected",
        _          => "st-pending"
    };

    private string GetStatusCardCss(string? s) => s switch
    {
        "Approved" => "dm-status-card-approved",
        "Rejected" => "dm-status-card-rejected",
        _          => "dm-status-card-pending"
    };

    private string GetInitials(string n) => string.IsNullOrWhiteSpace(n)
        ? "?"
        : string.Concat(n.Split(' ').Where(x => !string.IsNullOrWhiteSpace(x)).Select(x => x[0])).ToUpper();

    private void ShowFullDetails(LeaveRequestModel r)
    {
        SelectedRequest   = r;
        ShowDetailsModal  = true;
        ShowApproveModal  = false;
        ShowRejectModal   = false;
    }
