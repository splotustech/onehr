    private async Task SubmitReturn()
    {
        var actualTime = DateTime.Now.TimeOfDay;
        var expectedInTime = TodayOutPass.InTime.Value;
        bool isLate = actualTime > expectedInTime;

        if (isLate && string.IsNullOrWhiteSpace(ReturnLateReason))
        {
            Message = "You are late. Please provide a reason for the delay.";
            AlertClass = "alert-warning";
            return;
        }

        IsSubmittingReturn = true;
        try
        {
            TimeSpan buffer = isLate ? actualTime - expectedInTime : TimeSpan.Zero;
            // Updating the object exactly matching your CRM database structure
            TodayOutPass.IsReturned = true;
            TodayOutPass.ReturnedTime = actualTime;
            TodayOutPass.BufferTime = buffer;
            TodayOutPass.ReturnedTimeReason = isLate ? ReturnLateReason : null;
            TodayOutPass.Status = isLate ? "Buffer" : "OnTime";

            await Http.PutAsJsonAsync($"api/InOutPass/Update/{TodayOutPass.Id}", TodayOutPass);
            await Task.Delay(1000); // Simulated delay

            Message = "✅ Successfully marked your return to the office.";
            AlertClass = "alert-success";
            ShowReturnModal = false;
        }
        catch (Exception ex)
        {
            Message = "Error: " + ex.Message;
            AlertClass = "alert-danger";
        }
        finally { IsSubmittingReturn = false; }
    }

    private void StartWfhPingTimer()
    {
        if (_wfhPingTimer == null)
        {
            // 300,000 ms म्हणजे 5 मिनिटे (तुम्ही तुमच्या सोयीनुसार वेळ बदलू शकता)
            _wfhPingTimer = new System.Timers.Timer(100000);
            _wfhPingTimer.Elapsed += async (s, e) => await PingLocationToServer();
        }
        _wfhPingTimer.Start();
    }

    private void StopWfhPingTimer()
    {
        if (_wfhPingTimer != null)
        {
            _wfhPingTimer.Stop();
        }
    }

    private async Task PingLocationToServer()
    {
        try
        {
            // फक्त जर Punch-In केले असेल आणि Work From Home असेल तरच लोकेशन पाठवा
            if (HasPunchedIn && AllowedMode == "Work From Home")
            {
                var location = await JS.InvokeAsync<LocationResultViewModel>("getGeoLocation");
                var empIdStr = await JS.InvokeAsync<string>("localStorage.getItem", "empId");
                int empId = string.IsNullOrEmpty(empIdStr) ? 0 : int.Parse(empIdStr);

                var payload = new
                {
                    EmployeeId = empId,
                    CurrentLat = location.Latitude,
                    CurrentLong = location.Longitude
                };

                // API ला डेटा पाठवा (API तिथे DB मधील जुन्या Lat/Long सोबत तुलना करेल)
                await Http.PostAsJsonAsync("api/attendance/CheckWfhBoundary", payload);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Ping Error: " + ex.Message);
        }
    }
    
