            punchRequestViewModel.Lat = location.Latitude;
            punchRequestViewModel.Lng = location.Longitude;
            // 🎂 2. आजचा वाढदिवस आहे का ते चेक करा (Frontend Logic)
            // 🎂 2. आजचा वाढदिवस आहे का ते चेक करा (Frontend Logic)
            IsBirthday = false;
            if (!string.IsNullOrEmpty(birtday))
            {
                if (DateTime.TryParse(birtday, out DateTime dob))
                {
                    if (dob.Month == DateTime.Now.Month && dob.Day == DateTime.Now.Day)
                    {
                        IsBirthday = true;

                        // 🔥 जर वाढदिवस असेल आणि अजून Punch-In केले नसेल, तर पॉप-अप दाखवा
                        if (!HasPunchedIn && !IsAttendanceCompleted)
                        {
                            ShowBirthdayModal = true;
                        }
                    }
                }
            }

            var response = await Http.PostAsJsonAsync("api/attendance/Getpunch-status", punchRequestViewModel);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PunchStatusResponse>();
                Distance = result.Distance;
                IsWithinRange = result.IsWithinRange;
                AllowedMode = result.AllowedMode; // Important
                NeedsSelfie = result.NeedsSelfie; // Important

       
                if (result.Log != null)
                {
                    if (result.Log.PunchInTime != null && result.Log.PunchOutTime == null)
                    {

                        HasPunchedIn = true;
                        PunchInTime = result.Log.PunchInTime;
                        await LoadShortBreakStatus(empId);
                        _timer.Start();
                        // Resume WFH GPS tracking if still punched in
                        if (AllowedMode == "Work From Home")
                        {
                            try { await JS.InvokeVoidAsync("wfhTracking.startTracking", empId); }
                            catch (Exception ex) { Console.WriteLine("WFH tracking resume error: " + ex.Message); }
                        }
                    }
                    else if (result.Log.PunchOutTime != null)
                    {
                        HasPunchedIn = false;
                        IsAttendanceCompleted = true;
                        var total = result.Log.PunchOutTime.Value - result.Log.PunchInTime.Value;
                        WorkingHours = $"{(int)total.TotalHours:D2}:{total.Minutes:D2}:{total.Seconds:D2}";
                        StopWfhPingTimer();
                        try { await JS.InvokeVoidAsync("wfhTracking.stopTracking"); }
                        catch { }
                    }
                }


                // 🔥 मुख्य बदल येथे केला आहे 🔥
                // १. लोडिंग बंद करा म्हणजे UI वर व्हिडिओ टॅग दिसेल
                IsLoading = false;

                // २. Blazor ला UI रेंडर करायला सांगा
                StateHasChanged();

                // ३. आता व्हिडिओ टॅग DOM मध्ये आला आहे, त्यामुळे कॅमेरा सुरु करा
                if (NeedsSelfie && !HasPunchedIn && !IsAttendanceCompleted)
                {
                    await Task.Delay(500); // HTML रेंडर होण्यासाठी अर्धा सेकंद थांबा
                    await JS.InvokeVoidAsync("startVideo");
                }

                if (!IsWithinRange && AllowedMode != "Work From Home" )
                {
                    Message = $"You are {Math.Round(Distance)} meters away.";
                    AlertClass = "alert-danger";
                }
            }

            await LoadTodayOutPass();
        }
        catch (Exception ex)
        {
            Message = "Error: " + ex.Message;
            AlertClass = "alert-danger";
        }
        finally { IsLoading = false; }
    }

    private async Task ProcessPunch()
    {
        IsPunchedIn = true; IsLoading = true; Message = "";
        try
        {
            var empIdStr = await JS.InvokeAsync<string>("localStorage.getItem", "empId");
            int empId = string.IsNullOrEmpty(empIdStr) ? 1 : int.Parse(empIdStr);

           

            // जेव्हा Punch-Out होते तेव्हा:
           // StopWfhPingTimer();
            var punchRequest = new PunchRequestViewModel
            {
                EmployeeId = empId,
                Lat = punchRequestViewModel.Lat,
                Lng = punchRequestViewModel.Lng,
                WorkMode = AllowedMode,
                SelfieData = punchRequestViewModel.SelfieData
            };

            string apiUrl = HasPunchedIn ? "api/attendance/punch-out" : "api/attendance/punch-in";
            var response = await Http.PostAsJsonAsync(apiUrl, punchRequest);

            if (response.IsSuccessStatusCode)
            {
                HasPunchedIn = !HasPunchedIn;
                if (HasPunchedIn)
                {
                    Message = "✅ Punched In Successfully!";
                    AlertClass = "alert-success";
                    PunchInTime = DateTime.Now;
                    WorkingHours = "00:00:00";
                    _timer.Start();
                    await JS.InvokeVoidAsync("stopVideo");
                    // Start WFH GPS tracking after WFH punch-in
                    if (AllowedMode == "Work From Home")
                    {
                        try { await JS.InvokeVoidAsync("wfhTracking.startTracking", empId); }
                        catch (Exception ex) { Console.WriteLine("WFH tracking start error: " + ex.Message); }
                    }
                }
                else
                {
                    Message = $"✅ Punched Out! Total Working Hours: {WorkingHours}";
                    AlertClass = "alert-success";
                    HasPunchedIn = false;
                    IsAttendanceCompleted = true;
                    _timer.Stop();
                    StopWfhPingTimer();
                    try { await JS.InvokeVoidAsync("wfhTracking.stopTracking"); }
                    catch (Exception ex) { Console.WriteLine("WFH tracking stop error: " + ex.Message); }
                }
            }
            else
            {
                Message = await response.Content.ReadAsStringAsync();
                AlertClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            Message = "Server error: " + ex.Message;
            AlertClass = "alert-danger";
        }
        finally { IsLoading = false; IsPunchedIn = false; }
    }

