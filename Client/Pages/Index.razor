<!-- ============================================== -->
<!-- 🔵 2. MARK AS RETURNED MODAL (NEW) -->
<!-- ============================================== -->
@if (ShowReturnModal && TodayOutPass != null)
{
    <div class="outpass-overlay">
        <div class="outpass-modal">
            <div class="outpass-header bg-primary">
                <h5>Mark Return to Office</h5>
                <button class="outpass-close" @onclick="CloseReturnModal">×</button>
            </div>

            <div class="outpass-body">
                <p class="text-center fw-bold mb-3" style="color: #334155;">Welcome back! Please confirm your return.</p>

                @{
                    var actualTime = DateTime.Now.TimeOfDay;
                    var inTime = TodayOutPass.InTime.Value;
                    bool isLate = actualTime > inTime;
                    TimeSpan buffer = isLate ? actualTime - inTime : TimeSpan.Zero;
                }

                <div class="d-flex justify-content-between mb-3 p-3 bg-light rounded shadow-sm border">
                    <div class="text-center">
                        <small class="text-muted d-block">Expected In Time</small>
                        <b class="text-dark">@DateTime.Today.Add(inTime).ToString("hh:mm tt")</b>
                    </div>
                    <br />
                    <div class="text-center border-start ps-3">
                        <small class="text-muted d-block">Actual Return Time</small>
                        <b class="text-primary">@DateTime.Now.ToString("hh:mm tt")</b>
                    </div>
                </div>

                @if (isLate)
                {
                    <br />
                    <div class="alert alert-danger p-2 mb-3 text-center" style="font-size: 16px;">
                        <i class="oi oi-warning"></i> You are late by <b>@buffer.Hours hrs @buffer.Minutes mins</b>.
                    </div>
                    <br />
                    <div class="outpass-group">
                        <label>Reason for late return <span class="outpass-required">*</span></label>
                        <textarea class="outpass-input" rows="2" @bind="ReturnLateReason" placeholder="e.g. Traffic, Meeting extended..."></textarea>
                    </div>
                }
                else
                {

                    <br />
                    <div class="alert alert-success p-2 mb-3 text-center" style="font-size: 16px;">
                        <i class="oi oi-circle-check"></i> Great! You returned on time.
                    </div>
                }
            </div>

            <div class="outpass-footer">
                <button class="outpass-btn outpass-cancel" @onclick="CloseReturnModal">Cancel</button>
                <button class="outpass-btn outpass-save bg-primary text-white" @onclick="SubmitReturn" disabled="@IsSubmittingReturn">
                    @if (IsSubmittingReturn)
                    {
                        <span>Confirming...</span>
                    }
                    else
                    {

                        <span>Confirm Return</span>
                    }
                </button>
            </div>
        </div>
    </div>
}
