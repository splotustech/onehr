        ExpectedReturnTime = DateTime.Now.AddMinutes(SelectedBreakDuration);
        // ConfirmShortExit च्या आत शेवटी:
await JS.InvokeVoidAsync("localStorage.setItem", "expectedReturn", ExpectedReturnTime.Value.ToString("yyyy-MM-dd HH:mm:ss"));
