        {
            var elapsed = DateTime.Now - PunchInTime.Value;
            WorkingHours = $"{elapsed.Hours:D2}:{elapsed.Minutes:D2}:{elapsed.Seconds:D2}";
        }

        // 🔥 ADD THIS (every 30 sec or conditionally)
        if (DateTime.Now.Second % 30 == 0)
        {
            await LoadTodayOutPass();
        }

        await InvokeAsync(StateHasChanged);
    }

