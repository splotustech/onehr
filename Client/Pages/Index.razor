@page "/attendance"
@inject HttpClient Http
@inject IJSRuntime JS
@using SMART_HRMS_SYSTEM.Shared.Models
@using SMART_HRMS_SYSTEM.Shared.ViewModel

@inject NavigationManager NavManager
@implements IDisposable

<div class="attendance-wrapper">
    <div class="attendance-card">

        <!-- Top Badges (Employee Name & Date) -->
        <div class="top-badges">
            <div class="badge-pill">
                <i class="oi oi-person badge-icon"></i> Welcome @(string.IsNullOrEmpty(EmployeeName) ? "User" : EmployeeName)
            </div>
            <div class="badge-pill">
                <i class="oi oi-calendar badge-icon"></i> @DateTime.Now.ToString("dd MMM yyyy, dddd")
            </div>
        </div>

        <!-- Modern Header -->
        <div class="card-header-modern">
            <h2>Daily Attendance</h2>

            @if (AllowedMode == "Work From Home")
            {
                <!-- WFH असेल तर हा मेसेज दिसेल -->
                <p class="subtitle">Work From Home active. Secure your attendance with a live selfie.</p>
            }
            else
            {
                <!-- Office असेल तर तुमचा जुना मेसेज दिसेल -->
                <p class="subtitle">Mark your attendance within Office Location Only.</p>
            }
        </div>

        <!-- Alert Message -->
        @if (!string.IsNullOrEmpty(Message))
        {
            <div class="custom-alert @(AlertClass)">
                @if (AlertClass == "alert-danger")
                {
                    <i class="oi oi-warning pe-2"></i>
                }
                else
                {
                    <i class="oi oi-circle-check pe-2"></i>
                }
                <span>@Message</span>
            </div>
        }

        @if (IsLoading)
        {
            if (IsPunchedIn)
            {
                <div class="loading-state">
                    @if (HasPunchedIn)
                    {
                        <div class="pulse-spinner punch-out-spinner"></div>
                        <h6 class="fw-bold text-danger mt-3">Punching Out...</h6>
                        <p class="text-muted small">Verifying location and saving your working hours.</p>
                    }
                    else
                    {
                        <div class="pulse-spinner punch-in-spinner"></div>
                        <h6 class="fw-bold text-success mt-3">Punching In...</h6>
                        <p class="text-muted small">Please wait, marking your attendance securely.</p>
                    }
                </div>
            }
            else
            {
                <div class="loading-state">
                    <div class="pulse-spinner"></div>
                    <p>Fetching your accurate GPS location...</p>
                </div>
            }
        }
        else
        {

            @if (!string.IsNullOrEmpty(AllowedMode))
            {
                <div class="mode-indicator-container">
                    <div class="mode-tag @(AllowedMode == "Work From Home" ? "wfh-active" : "office-active")">
                        <i class="oi @(AllowedMode == "Work From Home" ? "oi-laptop" : "oi-home")"></i>
                        Work Mode: @AllowedMode
                    </div>
                </div>
            }
            <!-- Status, Location & Working Hours Grid -->
            <div class="status-grid">
                <div class="status-box">
                    <span class="status-label">Duty Status</span>
                    <span class="status-value @(HasPunchedIn ? "text-success" : "text-warning")">
                        <i class="oi @(HasPunchedIn ? "oi-check" : "oi-clock")"></i>
                        @(IsAttendanceCompleted ? "Completed" : HasPunchedIn ? "Checked In" : "Not Checked In")
                    </span>
                </div>

                <div class="status-box">
                    <span class="status-label">Location Status</span>
                    @if (AllowedMode == "Work From Home")
                    {
                        <!-- WFH असेल तर हे दिसेल -->
                        <span class="status-value" style="color: #d97706;">
                            <!-- Orange color to match WFH theme -->
                            <i class="oi oi-laptop"></i>
                            WFH (Remote)
                        </span>
                    }
                    else
                    {
                        <!-- Office असेल तर हे दिसेल (तुमचा जुना कोड) -->
                        <span class="status-value @(IsWithinRange ? "text-success" : "text-danger")">
                            <i class="oi oi-map-marker"></i>
                            @(IsWithinRange ? $"In Range ({Math.Round(Distance)}m)" : "Out of Range")
                        </span>
                    }
                </div>

                <div class="status-box">
                    <span class="status-label">Working Hours</span>
                    <span class="status-value text-info" style="font-family: monospace; font-size: 16px;">
                        <i class="oi oi-timer"></i>
                        @WorkingHours
                    </span>
                </div>
            </div>

            <!-- Big Circular Punch Button -->
            <div class="punch-section">
                @if (!string.IsNullOrEmpty(AllowedMode))
                {
                    @if (NeedsSelfie && !HasPunchedIn && !IsAttendanceCompleted)
                    {
                        <!-- 🤳 WFH Selfie Section -->
                        <div class="camera-container">
                            <div class="camera-preview-box">
                                <!-- playsinline जोडले आहे जेणेकरून मोबाईलवर व्हिडीओ फुल-स्क्रीन होणार नाही -->
                                <video id="videoFeed" autoplay playsinline muted></video>
                                <canvas id="canvas" style="display:none;"></canvas>

                                <div class="camera-overlay">
                                    <i class="oi oi-target"></i> Position your face to punch in
                                </div>
                            </div>

                            <button class="btn-take-photo" @onclick="CaptureAndPunch">
                                <i class="oi oi-camera-slr"></i> Take Photo & Punch In
                            </button>
                        </div>
                    }
                    else
                    {
                       @*  <button class="punch-btn @(IsAttendanceCompleted ? "disabled-btn" : (HasPunchedIn ? "btn-punch-out" : "btn-punch-in"))"
                        disabled="@(!IsWithinRange || IsAttendanceCompleted)"
                        @onclick="HandlePunch">
                            <div class="btn-content">
                                <i class="oi @(IsAttendanceCompleted ? "oi-check" : IconClass) punch-icon"></i>
                                <span class="punch-text">
                                    @(IsAttendanceCompleted ? "COMPLETED" : ButtonText)
                                </span>
                            </div>
                        </button> *@
                        <button class="punch-btn @(IsAttendanceCompleted ? "disabled-btn" : (HasPunchedIn ? "btn-punch-out" : "btn-punch-in"))"
                                disabled="@((AllowedMode == "Office" && !IsWithinRange) || IsAttendanceCompleted)"
                                @onclick="HandlePunch">
                            <div class="btn-content">
                                <i class="oi @(IsAttendanceCompleted ? "oi-check" : IconClass) punch-icon"></i>
                                <span class="punch-text">
                                    @(IsAttendanceCompleted ? "COMPLETED" : ButtonText)
                                </span>
                            </div>
                        </button>
                    }
                }
                else
                {
                    <button class="punch-btn @(!IsWithinRange ? "disabled-btn" : (HasPunchedIn ? "btn-punch-out" : "btn-punch-in"))"
                            disabled="@(!IsWithinRange || IsAttendanceCompleted)"
                            @onclick="HandlePunch">
                        <div class="btn-content">
                            <i class="oi @(IsAttendanceCompleted ? "oi-check" : IconClass) punch-icon"></i>
                            <span class="punch-text">
                                @(IsAttendanceCompleted ? "COMPLETED" : ButtonText)
                            </span>
                        </div>
                    </button>
                }
                @if (IsAttendanceCompleted)
                {
                    <p class="range-warning text-success mt-3">
                        <i class="oi oi-check"></i> Your attendance is already completed for today.
                    </p>
                }
                else
                {
                    @if (AllowedMode == "Work From Home")
                    {
                        @if (!HasPunchedIn)
                        {
                            <p class="range-warning text-success mt-3">
                                <i class="oi oi-camera-slr"></i> WFH Active. Please capture a selfie to punch in/out.
                            </p>
                        }
                    }
                    else
                    {
                        <!-- Office मोड चालू असेल तेव्हा -->
                        @if (!IsWithinRange)
                        {
                            <p class="range-warning text-danger mt-3">
                                <i class="oi oi-lock-locked"></i> Button locked. Please reach the office to punch.
                            </p>
                        }
                        else
                        {
                            <p class="range-warning text-success mt-3">
                                <i class="oi oi-lock-unlocked"></i> You are in the office zone. You can punch now!
                            </p>
                        }
                    }
                }
                
                <!-- 🟢 DYNAMIC IN-OUT PASS SECTION -->
                @if (HasPunchedIn && !IsAttendanceCompleted)
                {
                    <div class="mt-4 w-100 px-2">
                        <!-- ☕ १. MOVEMENT REGISTER (SHORT BREAK) SECTION -->
                       <div class="movement-section mb-3">
    @if (!IsOnShortBreak)
    {
        <button class="btn-movement w-100" @onclick="HandleShortExit">
            <i class="oi oi-media-play"></i> Movement Register (Tea/Lunch/Short Exit)
        </button>
    }
    else
    {
        <button class="btn-movement-return w-100 shadow-sm" @onclick="HandleShortReturn">
            <i class="oi oi-home"></i> Back to Desk (Mark Entry)
        </button>

        <div class="short-break-display mt-2 p-2 rounded shadow-sm border bg-white">
            <div class="d-flex justify-content-between align-items: center;">
                <div class="text-start">
                    <small class="text-muted d-block">Exit Time</small>
                    <span class="fw-bold text-dark" style="font-size: 14px;">
                        <i class="oi oi-clock text-warning"></i> 
                        @(ShortExitTime.HasValue ? DateTime.Today.Add(ShortExitTime.Value).ToString("hh:mm tt") : "-")
                    </span>
                </div>

                @if (ExpectedReturnTime.HasValue)
                {
                    <div class="text-end">
                        <small class="text-muted d-block">Return Expected</small>
                        <span class="fw-bold @(DateTime.Now > ExpectedReturnTime.Value ? "text-danger" : "text-primary")" style="font-size: 14px;">
                            <i class="oi oi-target"></i> 
                            @ExpectedReturnTime.Value.ToString("hh:mm tt")
                        </span>
                    </div>
                }
            </div>

            @if (ExpectedReturnTime.HasValue && DateTime.Now > ExpectedReturnTime.Value)
            {
                <div class="mt-2 py-1 px-2 bg-danger text-white rounded-pill text-center shadow-sm" style="font-size: 11px; font-weight: 700;">
                    <i class="oi oi-warning"></i> LATE BY @((int)(DateTime.Now - ExpectedReturnTime.Value).TotalMinutes) MINS
                </div>
            }
        </div>
    }
</div>
                        <style>
                            .short-break-display {
    background-color: #ffffff;
    border-left: 4px solid #f59e0b; /* Amber side border */
}

.short-break-display .text-danger {
    animation: blink-text 1.5s infinite;
}

@@keyframes blink-text {
    0% { opacity: 1; }
    50% { opacity: 0.5; }
    100% { opacity: 1; }
}
                            /* Movement Register Button */
                            .btn-movement {
                                background: linear-gradient(135deg, #475569, #1e293b); /* Dark Grey/Blue */
                                color: white;
                                border: none;
                                padding: 12px;
                                border-radius: 12px;
                                font-weight: 600;
                                font-size: 14px;
                                transition: 0.3s;
                                box-shadow: 0 4px 10px rgba(0,0,0,0.1);
                            }

                            .btn-movement-return {
                                background: linear-gradient(135deg, #f59e0b, #d97706); /* Amber/Orange */
                                color: white;
                                border: none;
                                padding: 12px;
                                border-radius: 12px;
                                font-weight: 600;
                                font-size: 14px;
                                animation: pulse-orange 2s infinite;
                            }

                            .short-break-timer {
                                font-size: 12px;
                                color: #d97706;
                                margin-top: 8px;
                                font-weight: bold;
                            }

                            @@keyframes pulse-orange {
                                0%

                            {
                                box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.4);
                            }

                            70% {
                                box-shadow: 0 0 0 10px rgba(245, 158, 11, 0);
                            }

                            100% {
                                box-shadow: 0 0 0 0 rgba(245, 158, 11, 0);
                            }

                            }</style>
                        <hr /> <!-- Separation line -->
                        @if (string.IsNullOrEmpty(TodayOutPass?.Status))
                        {
                            <!-- No pass applied yet -->
                            <button class="btn-gatepass w-100" @onclick="OpenOutPassModal">
                                <i class="oi oi-briefcase"></i> Apply Out Pass
                            </button>
                        }
                        else if (TodayOutPass.Status == "Pending")
                        {
                            <div class="outpass-status pending">
                                <div class="status-icon">
                                    <i class="oi oi-clock"></i>
                                </div>
                                <div class="status-content">
                                    <div class="status-title">Awaiting Approval</div>
                                    <div class="status-desc">
                                        Your Out Pass request has been submitted and is waiting for HR approval.
                                    </div>
                                </div>
                            </div>
                        
                        }
                        else if (TodayOutPass.Status == "Approved" && TodayOutPass.IsReturned != true)
                        {
                            <!-- Approved by HR, Employee went outside, now needs to Return -->
                            <button class="btn-gatepass w-100 text-white" style="background: linear-gradient(135deg, #10b981, #059669);" @onclick="OpenReturnModal">
                                <i class="oi oi-check"></i> I Have Returned to Office
                            </button>
                        }
                        else if (TodayOutPass.Status == "Rejected")
                        {
                            <!-- HR Rejected -->
                            <div class="alert alert-danger p-2 text-center shadow-sm" style="font-size:14px; border-radius:10px; border-left: 4px solid #dc3545;">
                                <i class="oi oi-warning"></i> Out Pass Rejected: @TodayOutPass.Comment
                            </div>
                            <!-- No pass applied yet -->
                            <br />
                            <button class="btn-gatepass w-100" @onclick="OpenOutPassModal">
                                <i class="oi oi-briefcase"></i> Apply Out Pass / Short Break
                            </button>
                        }
                        else if (TodayOutPass.IsReturned == true)
                        {
                            <!-- Process Completed -->
                            <div class="alert alert-success p-2 text-center shadow-sm" style="font-size:14px; border-radius:10px; border-left: 4px solid #198754;">
                                <i class="oi oi-circle-check"></i> Out Pass Process Completed.
                            </div>
                            <br>
                            <!-- No pass applied yet -->
                            <button class="btn-gatepass w-100" @onclick="OpenOutPassModal">
                                <i class="oi oi-briefcase"></i> Apply Out Pass / Short Break
                            </button>
                        }
                    </div>
                }
                <br />
                <div class="mt-4">
                    <a href="/my-report" class="view-report-btn">
                        <i class="oi oi-document"></i> View Attendance Report
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<!-- ============================================== -->
<!-- 🔴 PUNCH OUT CONFIRM MODAL -->
<!-- ============================================== -->
@if (ShowConfirmModal)
{
    <div class="modal-overlay">
        <div class="confirm-modal">
            <div class="modal-header"><h5>Confirm Punch Out</h5></div>
            <div class="modal-body">
                <p>You worked <strong>@WorkingHours</strong> today.</p>
                <p>Are you sure you want to punch out?</p>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseModal">Cancel</button>
                <button class="btn-confirm" @onclick="ConfirmPunchOut">Punch Out</button>
            </div>
        </div>
    </div>
}

<!-- ============================================== -->
<!-- 🟢 1. APPLY OUT PASS MODAL -->
@if (ShowOutPassModal)
{
    <div class="outpass-overlay">
        <div class="op-modal">

            <!-- Header -->
            <div class="op-header">
                <div class="op-header-icon">🪪</div>
                <div class="op-header-text">
                    <h5 class="op-title">In / Out Pass</h5>
                    <p class="op-sub">Fill in your departure details</p>
                </div>
                <button class="op-close" @onclick="CloseOutPassModal">✕</button>
            </div>

            <div class="op-body">

                <!-- Date -->
                <div class="op-field">
                    <label class="op-label"><span class="op-lbl-icon">📅</span> Date <span class="op-req">*</span></label>
                    <input type="date" class="op-input" @bind="OutPassDate" />
                </div>

                <!-- Out Time + In Time side by side -->
                <div class="op-time-row">
                    <div class="op-time-card op-time-out">
                        <div class="op-time-badge">OUT</div>
                        <label class="op-time-label">🚪 Out Time <span class="op-req">*</span></label>
                        <div class="op-time-selects">
                            <select class="op-tsel" @bind="endSelectedHour" @bind:event="oninput" @onchange="OnTimeChanged">
                                @for (int h = 1; h <= 12; h++)
                                {
                                    <option value="@h">@h.ToString("D2")</option>
                                }
                            </select>
                            <span class="op-tsep">:</span>
                            <select class="op-tsel" @bind="endSelectedMinute" @bind:event="oninput" @onchange="OnTimeChanged">
                                @for (int m = 0; m < 60; m++)
                                {
                                    <option value="@m">@m.ToString("D2")</option>
                                }
                            </select>
                            <select class="op-tsel op-ampm" @bind="endSelectedAmPm" @bind:event="oninput" @onchange="OnTimeChanged">
                                <option>AM</option>
                                <option>PM</option>
                            </select>
                        </div>
                    </div>

                    <div class="op-time-arrow">→</div>

                    <div class="op-time-card op-time-in">
                        <div class="op-time-badge op-badge-in">IN</div>
                        <label class="op-time-label">🏠 In Time <span class="op-req">*</span></label>
                        <div class="op-time-selects">
                            <select class="op-tsel" @bind="startSelectedHour" @bind:event="oninput" @onchange="OnTimeChanged">
                                @for (int h = 1; h <= 12; h++)
                                {
                                    <option value="@h">@h.ToString("D2")</option>
                                }
                            </select>
                            <span class="op-tsep">:</span>
                            <select class="op-tsel" @bind="startSelectedMinute" @bind:event="oninput" @onchange="OnTimeChanged">
                                @for (int m = 0; m < 60; m++)
                                {
                                    <option value="@m">@m.ToString("D2")</option>
                                }
                            </select>
                            <select class="op-tsel op-ampm" @bind="startSelectedAmPm" @bind:event="oninput" @onchange="OnTimeChanged">
                                <option>AM</option>
                                <option>PM</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Duration badge -->
                <div class="op-duration-row">
                    <span class="op-dur-label">⏱ Approx Duration</span>
                    <span class="op-dur-badge">@ApproxTimeString</span>
                </div>

                <!-- Reason -->
                <div class="op-field">
                    <label class="op-label"><span class="op-lbl-icon">📝</span> Reason <span class="op-req">*</span></label>
                    <textarea class="op-input op-textarea" rows="3"
                              @bind="OutPassReason"
                              placeholder="Briefly describe your reason for going out..."></textarea>
                </div>

            </div>

            <!-- Footer -->
            <div class="op-footer">
                <button class="op-btn-cancel" @onclick="CloseOutPassModal">Cancel</button>
                <button class="op-btn-submit" @onclick="SubmitOutPass" disabled="@IsSubmittingPass">
                    @if (IsSubmittingPass)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span><span>Submitting...</span>
                    }
                    else
                    {
                        <span>📤 Submit Request</span>
                    }
                </button>
            </div>

        </div>
    </div>
}
@if (ShowMovementModal)
{
    <div class="modal-overlay">
        <div class="sb-modal">

            <!-- Header -->
            <div class="sb-header">
                <div class="sb-header-icon">☕</div>
                <div>
                    <h5 class="sb-title">Short Break</h5>
                    <p class="sb-sub">Tell us where you're headed</p>
                </div>
                <button class="sb-close" @onclick="() => ShowMovementModal = false">✕</button>
            </div>

            <div class="sb-body">

                <!-- Reason Pills -->
                <p class="sb-label">Select Reason</p>
                <div class="sb-reason-grid">
                    @foreach (var r in new[] {
                        ("Tea Break","☕","Tea / Coffee"),
                        ("Lunch Break","🍽️","Lunch"),
                        ("Personal Work","🚶","Personal"),
                        ("Official Work","💼","Official"),
                        ("Other","📝","Other")
                    })
                    {
                        var rv = r.Item1; var icon = r.Item2; var lbl = r.Item3;
                        <button class="sb-reason-btn @(SelectedMovementReason == rv ? "sb-reason-active" : "")"
                                @onclick="() => SelectedMovementReason = rv">
                            <span class="sb-reason-icon">@icon</span>
                            <span class="sb-reason-lbl">@lbl</span>
                        </button>
                    }
                </div>

                <!-- Duration Pills -->
                <p class="sb-label mt-3">Expected Duration</p>
                <div class="sb-dur-row">
                    @foreach (var d in new[] { (5,"5m"),(10,"10m"),(15,"15m"),(20,"20m"),(30,"30m"),(45,"45m"),(60,"1hr") })
                    {
                        var dv = d.Item1; var dl = d.Item2;
                        <button class="sb-dur-btn @(SelectedBreakDuration == dv ? "sb-dur-active" : "")"
                                @onclick="() => SelectedBreakDuration = dv">
                            @dl
                        </button>
                    }
                </div>

                <!-- Return time card -->
                <div class="sb-return-card">
                    <div class="sb-return-left">
                        <span class="sb-return-icon">🕐</span>
                        <div>
                            <span class="sb-return-label">Expected return by</span>
                            <span class="sb-return-time">@DateTime.Now.AddMinutes(SelectedBreakDuration).ToString("hh:mm tt")</span>
                        </div>
                    </div>
                    <span class="sb-return-min">@SelectedBreakDuration min</span>
                </div>

            </div>

            <!-- Footer -->
            <div class="sb-footer">
                <button class="sb-btn-cancel" @onclick="() => ShowMovementModal = false">Cancel</button>
                <button class="sb-btn-start" @onclick="ConfirmShortExit">
                    <span>🚀</span> Start Break
                </button>
            </div>

        </div>
    </div>
}
@if (ShowMovementReturnModal)
{
    <div class="modal-overlay">
        <div class="lr-modal animate-pop">

            <!-- Header -->
            <div class="lr-header">
                <div class="lr-header-icon">⚠️</div>
                <div class="lr-header-text">
                    <h5 class="lr-title">Late Return Warning</h5>
                    <p class="lr-sub">Please provide a reason to continue</p>
                </div>
            </div>

            <!-- Late Time Badge -->
            <div class="lr-late-badge">
                <div class="lr-late-inner">
                    <span class="lr-late-icon">🕐</span>
                    <div>
                        <span class="lr-late-label">You are late by</span>
                        <span class="lr-late-mins">@((int)(DateTime.Now - ExpectedReturnTime.Value).TotalMinutes) minutes</span>
                    </div>
                </div>
                <div class="lr-time-row">
                    <div class="lr-time-item">
                        <span class="lr-time-lbl">Expected</span>
                        <span class="lr-time-val lr-time-green">@ExpectedReturnTime.Value.ToString("hh:mm tt")</span>
                    </div>
                    <span class="lr-time-arrow">→</span>
                    <div class="lr-time-item">
                        <span class="lr-time-lbl">Actual</span>
                        <span class="lr-time-val lr-time-red">@DateTime.Now.ToString("hh:mm tt")</span>
                    </div>
                </div>
            </div>

            <!-- Reason Input -->
            <div class="lr-body">
                <label class="lr-reason-label">Reason for delay <span class="lr-req">*</span></label>
                <textarea class="lr-textarea"
                          @bind="MovementLateReason"
                          rows="3"
                          placeholder="e.g. Traffic jam, Extended meeting, Personal emergency..."></textarea>
                @if (string.IsNullOrWhiteSpace(MovementLateReason))
                {
                    <span class="lr-hint">Required — cannot confirm without a reason.</span>
                }
            </div>

            <!-- Footer -->
            <div class="lr-footer">
                <button class="lr-btn-cancel" @onclick="() => ShowMovementReturnModal = false">Cancel</button>
                <button class="lr-btn-confirm" @onclick="ConfirmReturnNow" disabled="@string.IsNullOrWhiteSpace(MovementLateReason)">
                    Confirm Return
                </button>
            </div>

