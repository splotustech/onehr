    private TimeSpan? ConvertDropdownToTimeSpan(int hour, int minute, string amPm)
    {
        if (amPm == "PM" && hour != 12) hour += 12;
        else if (amPm == "AM" && hour == 12) hour = 0;
        return new TimeSpan(hour, minute, 0);
    }

    private void CalculateApproxTime()
    {
        if (OutTime.HasValue && InTime.HasValue)
        {
            var diff = InTime.Value - OutTime.Value;
            ApproxTimeInMinutes = diff.TotalMinutes >= 0 ? TimeSpan.FromMinutes(diff.TotalMinutes) : TimeSpan.Zero;
        }
        else { ApproxTimeInMinutes = null; }
    }

    private string ApproxTimeString => ApproxTimeInMinutes?.ToString(@"hh\:mm") ?? "00:00";

    private void OnTimeChanged()
    {
        var selectedOutTime = ConvertDropdownToTimeSpan(endSelectedHour, endSelectedMinute, endSelectedAmPm);
        var currentTime = DateTime.Now.TimeOfDay;

        if (selectedOutTime < currentTime && OutPassDate.Date == DateTime.Now.Date)
        {
            int hour = DateTime.Now.Hour;
            endSelectedHour = hour % 12 == 0 ? 12 : hour % 12;
            endSelectedMinute = DateTime.Now.Minute;
            endSelectedAmPm = hour >= 12 ? "PM" : "AM";
            selectedOutTime = ConvertDropdownToTimeSpan(endSelectedHour, endSelectedMinute, endSelectedAmPm);
        }

        OutTime = selectedOutTime;
        var selectedInTime = ConvertDropdownToTimeSpan(startSelectedHour, startSelectedMinute, startSelectedAmPm);

        if (selectedInTime < currentTime && OutPassDate.Date == DateTime.Now.Date)
        {
            int currentHour = DateTime.Now.Hour;
            startSelectedHour = currentHour % 12 == 0 ? 12 : currentHour % 12;
            startSelectedMinute = DateTime.Now.Minute;
            startSelectedAmPm = currentHour >= 12 ? "PM" : "AM";
            InTime = currentTime;
        }
        else { InTime = selectedInTime; }

        CalculateApproxTime();
    }

    private void OpenOutPassModal()
    {
        OutPassDate = DateTime.Now.Date;
        var now = DateTime.Now;

        endSelectedHour = now.Hour % 12 == 0 ? 12 : now.Hour % 12;
        endSelectedMinute = now.Minute;
        endSelectedAmPm = now.Hour >= 12 ? "PM" : "AM";
        OutTime = ConvertDropdownToTimeSpan(endSelectedHour, endSelectedMinute, endSelectedAmPm);

        var future = now.AddMinutes(60);
        startSelectedHour = future.Hour % 12 == 0 ? 12 : future.Hour % 12;
        startSelectedMinute = future.Minute;
        startSelectedAmPm = future.Hour >= 12 ? "PM" : "AM";
        InTime = ConvertDropdownToTimeSpan(startSelectedHour, startSelectedMinute, startSelectedAmPm);

        CalculateApproxTime();
        OutPassReason = "";
        ShowOutPassModal = true;
    }

    private void CloseOutPassModal() { ShowOutPassModal = false; }

    private async Task SubmitOutPass()
    {
        if (string.IsNullOrWhiteSpace(OutPassReason))
        {
            Message = "Please enter a reason.";
            AlertClass = "alert-warning";
            return;
        }

        OutTime = ConvertDropdownToTimeSpan(endSelectedHour, endSelectedMinute, endSelectedAmPm);
        InTime = ConvertDropdownToTimeSpan(startSelectedHour, startSelectedMinute, startSelectedAmPm);

        if (InTime <= OutTime)
        {
            Message = "In Time must be greater than Out Time.";
            AlertClass = "alert-warning";
            return;
        }

        IsSubmittingPass = true;

        try
        {
            var empIdStr = await JS.InvokeAsync<string>("localStorage.getItem", "empId");
            int empId = string.IsNullOrEmpty(empIdStr) ? 1 : int.Parse(empIdStr);

            CalculateApproxTime();

            var request = new TblInOutPass   // ✅ MATCH BACKEND MODEL
            {
                Empid = empId,
                Date = OutPassDate,
                OutTime = OutTime,
                InTime = InTime,
                ApproxTime = ApproxTimeInMinutes,
                Reason = OutPassReason,
                MobileNo = EmployeeMobile,
                Designation = EmployeeDepartment,
                Status = "Pending",
                IsReturned = false
            };

            var response = await Http.PostAsJsonAsync("api/InOutPass/Save", request);

            if (response.IsSuccessStatusCode)
            {
                // ✅ reload from DB (BEST PRACTICE)
                await LoadTodayOutPass();

                // =========================================================
                // 🔥 NEW: Outpass Save झाल्यावर लगेच Notification API ला कॉल करा
                // =========================================================
                try
                {
                    string title = "New Outpass Request";
                    string body = $"{EmployeeName} has requested an Out/In Pass. Please review.";
                    string link = "/outpass-request";

                    var notification = new NotificationRequest
                    {
                        EmployeeName = EmployeeName,
                        Title = title,
                        Body = body,
                        Link = link
                    };

                    await Http.PostAsJsonAsync("api/Notifications/sendHRNotification", notification);
                }
                catch (Exception ex)
                {
                    Console.WriteLine("Notification send failed: " + ex.Message);
                }
                // =========================================================
                Message = "✅ Out Pass Request sent successfully.";
                AlertClass = "alert-success";
                ShowOutPassModal = false;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Message = $"❌ Failed: {error}";
                AlertClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            Message = "Error: " + ex.Message;
            AlertClass = "alert-danger";
        }
        finally
        {
            IsSubmittingPass = false;
        }
    }
