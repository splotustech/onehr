<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- App Identity -->
    <key>CFBundleName</key>
    <string>ONE HR</string>
    <key>CFBundleDisplayName</key>
    <string>ONE HR</string>
    <key>CFBundleIdentifier</key>
    <string>com.splotuss.smarthrms</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>MinimumOSVersion</key>
    <string>15.0</string>

    <!-- UI -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIMainStoryboardFile</key>
    <string></string>
    <key>UIRequiresFullScreen</key>
    <true/>
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleDefault</string>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

    <!-- Supported orientations -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- ============================================================ -->
    <!-- LOCATION PERMISSIONS — Required for WFH GPS tracking         -->
    <!-- ============================================================ -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>ONE HR uses your location to record WFH attendance. Location is tracked while you are punched in for work-from-home.</string>

    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>ONE HR tracks your location in the background while you are working from home so your attendance is recorded even when the app is minimised.</string>

    <key>NSLocationAlwaysUsageDescription</key>
    <string>ONE HR tracks your location in the background for WFH attendance.</string>

    <!-- Enable background GPS updates -->
    <key>UIBackgroundModes</key>
    <array>
        <string>location</string>
        <string>fetch</string>
        <string>remote-notification</string>
    </array>

    <!-- ============================================================ -->
    <!-- CAMERA PERMISSION — Required for selfie punch-in photo       -->
    <!-- ============================================================ -->
    <key>NSCameraUsageDescription</key>
    <string>ONE HR uses your camera to take a photo when you punch in or out for attendance verification.</string>

    <!-- ============================================================ -->
    <!-- NOTIFICATIONS                                                  -->
    <!-- ============================================================ -->
    <!-- Remote notifications are requested at runtime in AppDelegate -->

    <!-- Allow inline media in WebView -->
    <key>WebKitMediaPlaybackAllowsInline</key>
    <true/>
    <key>AllowsInlineMediaPlayback</key>
    <true/>

</dict>
</plist>
