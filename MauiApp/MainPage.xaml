<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SPOneHRApp.MainPage"
             BackgroundColor="#F1F5F9"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto">

        <!-- Full-screen WebView â€” loads the existing Blazor PWA -->
        <WebView x:Name="webView"
                 Grid.Row="0"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill" />

        <!-- Offline banner â€” shown when there is no internet -->
        <Grid x:Name="offlineBanner"
              Grid.Row="1"
              BackgroundColor="#EF4444"
              Padding="12,8"
              IsVisible="False">
            <Label Text="No internet connection â€” GPS tracking continues in background"
                   TextColor="White"
                   FontSize="12"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
        </Grid>

    </Grid>

</ContentPage>
